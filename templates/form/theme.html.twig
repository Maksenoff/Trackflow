{% use 'form_div_layout.html.twig' %}

{% block form_row %}
<div class="form-group">
    {{- form_label(form) -}}
    {{- form_errors(form) -}}
    {{- form_widget(form) -}}
</div>
{% endblock %}

{% block form_label %}
{% if label is not same as(false) %}
<label{% if id is defined %} for="{{ id }}"{% endif %} class="form-label">
    {{ label|default(name|humanize) }}{% if required %}<span style="color:var(--danger);margin-left:3px;">*</span>{% endif %}
</label>
{% endif %}
{% endblock %}

{% block form_errors %}
{% if errors|length > 0 %}
    {% for error in errors %}
        <p style="font-size:12px;color:var(--danger);margin-top:4px;">{{ error.message }}</p>
    {% endfor %}
{% endif %}
{% endblock %}

{% block text_widget %}
<input type="text" {{ block('widget_attributes') }} class="form-input"
       {% if value is defined %}value="{{ value }}"{% endif %}>
{% endblock %}

{% block email_widget %}
<input type="email" {{ block('widget_attributes') }} class="form-input"
       {% if value is defined %}value="{{ value }}"{% endif %}>
{% endblock %}

{% block password_widget %}
<input type="password" {{ block('widget_attributes') }} class="form-input"
       {% if value is defined %}value="{{ value }}"{% endif %}>
{% endblock %}

{% block number_widget %}
<input type="number" {{ block('widget_attributes') }} class="form-input"
       {% if value is not null %}value="{{ value }}"{% endif %}>
{% endblock %}

{% block integer_widget %}
<input type="number" {{ block('widget_attributes') }} class="form-input"
       {% if value is not null %}value="{{ value }}"{% endif %}>
{% endblock %}

{% block date_widget %}
{% if widget == 'single_text' %}
<input type="date" {{ block('widget_attributes') }} class="form-input"
       style="color-scheme: dark;"
       {% if value %}value="{{ value }}"{% endif %}>
{% else %}
    {{ parent() }}
{% endif %}
{% endblock %}

{% block datetime_widget %}
{% if widget == 'single_text' %}
<input type="datetime-local" {{ block('widget_attributes') }} class="form-input"
       style="color-scheme: dark;"
       {% if value %}value="{{ value }}"{% endif %}>
{% else %}
    {{ parent() }}
{% endif %}
{% endblock %}

{% block textarea_widget %}
<textarea {{ block('widget_attributes') }} class="form-input" style="resize:vertical;min-height:90px;">{{ value }}</textarea>
{% endblock %}

{% block choice_widget_collapsed %}
<select {{ block('widget_attributes') }}{% if multiple %} multiple="multiple"{% endif %} class="form-input">
    {% if placeholder is not none %}
        <option value=""{% if not value %} selected{% endif %}>{{ placeholder }}</option>
    {% endif %}
    {% for group_label, choice in choices %}
        {% if choice is iterable %}
            <optgroup label="{{ group_label }}">
                {% for c in choice %}
                    <option value="{{ c.value }}"{% if c.value in value %} selected{% endif %}>{{ c.label }}</option>
                {% endfor %}
            </optgroup>
        {% else %}
            <option value="{{ choice.value }}"{% if choice.value in value %} selected{% endif %}>{{ choice.label }}</option>
        {% endif %}
    {% endfor %}
</select>
{% endblock %}

{% block checkbox_widget %}
<div style="display:flex;align-items:center;gap:8px;">
<input type="checkbox" {{ block('widget_attributes') }}{% if value == 'true' or checked %} checked{% endif %}
       style="width:16px;height:16px;accent-color:var(--accent);cursor:pointer;border-radius:4px;">
</div>
{% endblock %}

{% block file_widget %}
<input type="file" {{ block('widget_attributes') }}
       style="width:100%;font-size:13px;color:var(--text-2);"
       class="form-input" style="padding:8px;">
{% endblock %}
