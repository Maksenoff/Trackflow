{% extends 'base.html.twig' %}
{% block title %}Modifier séance{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_calendar') }}">Calendrier</a>
    <span class="sep">/</span>
    <span class="current">Modifier séance</span>
{% endblock %}

{% block body %}
<div style="max-width:600px;margin:0 auto;">
    <div style="margin-bottom:24px;">
        <h1 class="section-title">Modifier la séance</h1>
        <p class="section-subtitle">{{ session.date|date('d/m/Y') }} · {{ session.typeLabel }}</p>
    </div>
    <div class="card card-body">
        {{ form_start(form) }}
        {{ form_row(form.title) }}
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.date) }}</div>
            <div>{{ form_row(form.trainingType) }}</div>
        </div>
        {{ form_row(form.durationMinutes) }}
        {{ form_row(form.description) }}
        <div style="display:flex;gap:10px;padding-top:8px;">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('app_session_show', {id: session.id}) }}" class="btn btn-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
