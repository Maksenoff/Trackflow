{% extends 'base.html.twig' %}
{% block title %}Nouvelle séance{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_calendar') }}" class="hover:text-white">Calendrier</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">Nouvelle séance</span>
{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-white">Nouvelle séance</h1>
        <p class="text-gray-400 mt-1">Planifiez une séance sur le calendrier</p>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        {{ form_row(form.title) }}
        <div class="grid grid-cols-2 gap-4">
            <div>{{ form_row(form.date) }}</div>
            <div>{{ form_row(form.trainingType) }}</div>
        </div>
        {{ form_row(form.durationMinutes) }}
        {{ form_row(form.description) }}
        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Créer la séance
            </button>
            <a href="{{ path('app_calendar') }}" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
