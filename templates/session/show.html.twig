{% extends 'base.html.twig' %}
{% block title %}{{ session.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_calendar', {month: session.date|date('n'), year: session.date|date('Y')}) }}">Calendrier</a>
    <span class="sep">/</span>
    <span class="current">{{ session.title }}</span>
{% endblock %}

{% block body %}
<div style="max-width:720px;margin:0 auto;display:flex;flex-direction:column;gap:24px;">

    {# Session header card #}
    <div class="card" style="overflow:hidden;">
        <div style="height:3px;background:{{ session.colorBg }};"></div>
        <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div style="display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:16px;">
                    <div>
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
                            {% if session.trainingType %}
                                <span style="font-size:11px;font-weight:600;padding:4px 10px;border-radius:99px;
                                             background:{{ session.colorBg }}22;color:{{ session.colorBg }};border:1px solid {{ session.colorBg }}44;">
                                    {{ session.typeLabel }}
                                </span>
                            {% endif %}
                            {% if session.isPast %}
                                <span class="badge">Passée</span>
                            {% else %}
                                <span class="badge badge-green">À venir</span>
                            {% endif %}
                        </div>
                        <h1 style="font-size:22px;font-weight:700;color:var(--text-1);margin:0 0 8px;">{{ session.title }}</h1>
                        <div style="display:flex;align-items:center;gap:16px;font-size:13px;color:var(--text-2);">
                            <span style="display:flex;align-items:center;gap:6px;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                {{ session.date|date_fr('l d F Y')|capitalize }}
                            </span>
                            {% if session.durationMinutes %}
                                <span style="display:flex;align-items:center;gap:6px;">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                    {{ session.durationMinutes }} min
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;flex-shrink:0;align-self:flex-start;">
                        <a href="{{ path('app_session_edit', {id: session.id}) }}" class="btn btn-secondary btn-sm">
                            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Modifier
                        </a>
                        <form action="{{ path('app_session_delete', {id: session.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-session' ~ session.id) }}">
                            <button type="submit" onclick="return confirm('Supprimer cette séance ?')" class="btn btn-danger btn-sm">
                                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Programme / notes de séance #}
    <div class="card" style="overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;display:flex;align-items:center;gap:8px;">
                <svg width="14" height="14" fill="none" stroke="var(--text-3)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Programme de la séance
            </h2>
            <a href="{{ path('app_session_edit', {id: session.id}) }}"
               style="font-size:12px;color:var(--text-3);text-decoration:none;display:flex;align-items:center;gap:4px;transition:color .15s;"
               onmouseover="this.style.color='var(--accent)'"
               onmouseout="this.style.color='var(--text-3)'">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Modifier
            </a>
        </div>
        <div style="padding:20px;">
            {% if session.description %}
                <pre style="color:var(--text-2);font-size:13px;line-height:1.7;white-space:pre-wrap;font-family:inherit;margin:0;">{{ session.description }}</pre>
            {% else %}
                <div class="empty-state" style="padding:32px 20px;">
                    <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p>Aucun programme renseigné.</p>
                    <a href="{{ path('app_session_edit', {id: session.id}) }}"
                       style="font-size:12px;color:var(--accent);text-decoration:none;margin-top:6px;display:inline-block;">
                        Ajouter le contenu →
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    {# Athlete feedbacks #}
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <h2 style="font-size:16px;font-weight:600;color:var(--text-1);margin:0;">
                Ressentis athlètes
                <span style="font-size:13px;font-weight:400;color:var(--text-3);margin-left:8px;">{{ session.athleteSessions|length }}</span>
            </h2>
        </div>

        {% if session.athleteSessions is empty %}
            <div class="card">
                <div class="empty-state" style="padding:40px;">
                    <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    <p>Aucun ressenti enregistré pour l'instant.</p>
                    {% if session.isPast %}
                        <p style="font-size:12px;color:var(--text-3);margin:4px 0 0;">Les athlètes peuvent l'ajouter depuis leur profil.</p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            {# Difficulty average #}
            {% set totalDiff = 0 %}
            {% set countDiff = 0 %}
            {% for asl in session.athleteSessions %}
                {% if asl.difficulty is not null %}
                    {% set totalDiff = totalDiff + asl.difficulty %}
                    {% set countDiff = countDiff + 1 %}
                {% endif %}
            {% endfor %}
            {% if countDiff > 0 %}
                {% set avgDiff = (totalDiff / countDiff)|round(1) %}
                {% set avgColor = avgDiff <= 2 ? '#34d399' : (avgDiff <= 4 ? '#a3e635' : (avgDiff <= 6 ? '#fbbf24' : (avgDiff <= 8 ? '#fb923c' : '#f87171'))) %}
                {% set avgLabel = avgDiff <= 2 ? 'Très facile' : (avgDiff <= 4 ? 'Facile' : (avgDiff <= 6 ? 'Modéré' : (avgDiff <= 8 ? 'Difficile' : 'Maximum'))) %}
                <div class="card" style="overflow:hidden;border-color:{{ avgColor }}33;">
                    <div style="height:2px;background:linear-gradient(90deg,{{ avgColor }},{{ avgColor }}00);"></div>
                    <div class="card-body" style="display:flex;align-items:center;gap:24px;">
                        <div style="flex-shrink:0;text-align:center;">
                            <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0 0 4px;font-weight:600;">RPE moyen</p>
                            <p style="font-size:40px;font-weight:800;font-family:monospace;margin:0;line-height:1;color:{{ avgColor }};">
                                {{ avgDiff }}<span style="font-size:16px;font-weight:400;color:var(--text-3);">/10</span>
                            </p>
                            <p style="font-size:12px;font-weight:600;margin:4px 0 0;color:{{ avgColor }};">{{ avgLabel }}</p>
                        </div>
                        <div style="flex:1;">
                            <div style="display:flex;gap:4px;margin-bottom:8px;">
                                {% for i in 1..10 %}
                                    <div style="flex:1;height:8px;border-radius:4px;transition:background .2s;
                                                background:{% if i <= avgDiff %}{{ avgColor }}{% else %}var(--border-2){% endif %};"></div>
                                {% endfor %}
                            </div>
                            <p style="font-size:12px;color:var(--text-3);margin:0;">
                                {{ countDiff }} retour{% if countDiff > 1 %}s{% endif %} sur {{ session.athleteSessions|length }} athlète{% if session.athleteSessions|length > 1 %}s{% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div style="display:flex;flex-direction:column;gap:12px;">
                {% for asl in session.athleteSessions %}
                    <div class="card card-body" style="padding:16px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;">
                            <div style="display:flex;align-items:flex-start;gap:12px;">
                                <div class="avatar" style="background:rgba(var(--accent-rgb),.15);color:var(--accent);font-size:12px;font-weight:700;flex-shrink:0;">
                                    {{ asl.athlete.firstName|slice(0,1) }}{{ asl.athlete.lastName|slice(0,1) }}
                                </div>
                                <div>
                                    <a href="{{ path('app_athlete_show', {id: asl.athlete.id}) }}"
                                       style="font-weight:500;color:var(--text-1);text-decoration:none;font-size:13px;transition:color .15s;"
                                       onmouseover="this.style.color='var(--accent)'"
                                       onmouseout="this.style.color='var(--text-1)'">
                                        {{ asl.athlete.fullName }}
                                    </a>
                                    <p style="font-size:12px;color:var(--text-3);margin:2px 0 0;">{{ asl.athlete.discipline }}</p>
                                    {% if asl.comment %}
                                        <p style="font-size:13px;color:var(--text-2);margin:8px 0 0;font-style:italic;line-height:1.5;">"{{ asl.comment }}"</p>
                                    {% endif %}
                                </div>
                            </div>
                            {% if asl.difficulty is not null %}
                                {% set d = asl.difficulty %}
                                {% set dColor = d <= 2 ? '#34d399' : (d <= 4 ? '#a3e635' : (d <= 6 ? '#fbbf24' : (d <= 8 ? '#fb923c' : '#f87171'))) %}
                                <div style="text-align:right;flex-shrink:0;">
                                    <p style="font-size:26px;font-weight:800;font-family:monospace;margin:0;line-height:1;color:{{ dColor }};">
                                        {{ d }}<span style="font-size:11px;font-weight:400;color:var(--text-3);">/10</span>
                                    </p>
                                    <div style="display:flex;gap:2px;margin-top:6px;justify-content:flex-end;">
                                        {% for j in 1..10 %}
                                            <div style="width:12px;height:4px;border-radius:2px;background:{{ j <= d ? dColor : 'var(--border-2)' }};"></div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
