{% extends 'base.html.twig' %}
{% block title %}{{ session.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_calendar', {month: session.date|date('n'), year: session.date|date('Y')}) }}" class="hover:text-white transition-colors">Calendrier</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">{{ session.title }}</span>
{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto space-y-6">

    {# Session header card #}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <div class="h-2" style="background: {{ session.colorBg }}"></div>
        <div class="p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        {% if session.trainingType %}
                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full"
                                  style="background: {{ session.colorBg }}22; color: {{ session.colorBg }}; border: 1px solid {{ session.colorBg }}44">
                                {{ session.typeLabel }}
                            </span>
                        {% endif %}
                        {% if session.isPast %}
                            <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">Passée</span>
                        {% else %}
                            <span class="text-xs text-emerald-400 bg-emerald-900/30 border border-emerald-800/50 px-2 py-0.5 rounded-full">À venir</span>
                        {% endif %}
                    </div>
                    <h1 class="text-2xl font-bold text-white">{{ session.title }}</h1>
                    <div class="flex items-center gap-4 mt-2 text-sm text-gray-400">
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {{ session.date|date('l d F Y')|capitalize }}
                        </span>
                        {% if session.durationMinutes %}
                            <span class="flex items-center gap-1.5">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                {{ session.durationMinutes }} min
                            </span>
                        {% endif %}
                    </div>
                </div>
                <div class="flex gap-2 shrink-0">
                    <a href="{{ path('app_session_edit', {id: session.id}) }}"
                       class="flex items-center gap-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Modifier
                    </a>
                    <form action="{{ path('app_session_delete', {id: session.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-session' ~ session.id) }}">
                        <button type="submit" onclick="return confirm('Supprimer cette séance ?')"
                                class="flex items-center gap-1.5 bg-gray-800 hover:bg-red-900/40 hover:text-red-400 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>

    {# Programme / notes de séance #}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Programme de la séance
            </h2>
            <a href="{{ path('app_session_edit', {id: session.id}) }}"
               class="text-xs text-gray-600 hover:text-indigo-400 transition-colors flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Modifier
            </a>
        </div>
        <div class="p-6">
            {% if session.description %}
                <pre class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap font-sans">{{ session.description }}</pre>
            {% else %}
                <div class="text-center py-8">
                    <svg class="w-8 h-8 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p class="text-gray-500 text-sm">Aucun programme renseigné.</p>
                    <a href="{{ path('app_session_edit', {id: session.id}) }}"
                       class="inline-block mt-2 text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
                        Ajouter le contenu de la séance →
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    {# Athlete feedbacks #}
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-white">
                Ressentis athlètes
                <span class="text-sm font-normal text-gray-500 ml-2">{{ session.athleteSessions|length }} / ?</span>
            </h2>
        </div>

        {% if session.athleteSessions is empty %}
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center">
                <svg class="w-10 h-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <p class="text-gray-500 text-sm">Aucun ressenti enregistré pour l'instant.</p>
                {% if session.isPast %}
                    <p class="text-gray-600 text-xs mt-1">Les athlètes peuvent l'ajouter depuis leur profil.</p>
                {% endif %}
            </div>
        {% else %}
            {# Difficulty average #}
            {% set totalDiff = 0 %}
            {% set countDiff = 0 %}
            {% for asl in session.athleteSessions %}
                {% if asl.difficulty is not null %}
                    {% set totalDiff = totalDiff + asl.difficulty %}
                    {% set countDiff = countDiff + 1 %}
                {% endif %}
            {% endfor %}
            {% if countDiff > 0 %}
                {% set avgDiff = (totalDiff / countDiff)|round(1) %}
                <div class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-4 flex items-center gap-4">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wide">Difficulté moyenne</p>
                        <p class="text-3xl font-bold mt-0.5
                            {% if avgDiff <= 3 %}text-emerald-400
                            {% elseif avgDiff <= 6 %}text-yellow-400
                            {% else %}text-red-400{% endif %}">
                            {{ avgDiff }}<span class="text-base font-normal text-gray-500">/10</span>
                        </p>
                    </div>
                    <div class="flex-1">
                        <div class="flex gap-1">
                            {% for i in 0..10 %}
                                <div class="flex-1 h-2 rounded-full transition-colors
                                    {% if i <= avgDiff %}
                                        {% if avgDiff <= 3 %}bg-emerald-500{% elseif avgDiff <= 6 %}bg-yellow-500{% else %}bg-red-500{% endif %}
                                    {% else %}bg-gray-800{% endif %}">
                                </div>
                            {% endfor %}
                        </div>
                        <p class="text-xs text-gray-500 mt-1">{{ countDiff }} retour{% if countDiff > 1 %}s{% endif %}</p>
                    </div>
                </div>
            {% endif %}

            <div class="space-y-3">
                {% for asl in session.athleteSessions %}
                    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-start gap-3">
                                <div class="w-9 h-9 rounded-full bg-indigo-600/20 flex items-center justify-center text-indigo-300 font-bold text-sm shrink-0">
                                    {{ asl.athlete.firstName|slice(0,1) }}{{ asl.athlete.lastName|slice(0,1) }}
                                </div>
                                <div>
                                    <a href="{{ path('app_athlete_show', {id: asl.athlete.id}) }}"
                                       class="font-medium text-white hover:text-indigo-300 transition-colors text-sm">
                                        {{ asl.athlete.fullName }}
                                    </a>
                                    <p class="text-xs text-gray-500 mt-0.5">{{ asl.athlete.discipline }}</p>
                                    {% if asl.comment %}
                                        <p class="text-sm text-gray-400 mt-2 italic leading-relaxed">"{{ asl.comment }}"</p>
                                    {% endif %}
                                </div>
                            </div>
                            {% if asl.difficulty is not null %}
                                <div class="text-right shrink-0">
                                    <p class="text-2xl font-bold
                                        {% if asl.difficulty <= 3 %}text-emerald-400
                                        {% elseif asl.difficulty <= 6 %}text-yellow-400
                                        {% else %}text-red-400{% endif %}">
                                        {{ asl.difficulty }}<span class="text-xs font-normal text-gray-500">/10</span>
                                    </p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
