{% extends 'base.html.twig' %}
{% block title %}Nouvel objectif{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}">{{ athlete.fullName }}</a>
    <span class="sep">/</span>
    <span class="current">Nouvel objectif</span>
{% endblock %}

{% block body %}
<div style="max-width:640px;margin:0 auto;">
    <div style="margin-bottom:24px;">
        <h1 class="section-title">Nouvel objectif</h1>
        <p class="section-subtitle">{{ athlete.fullName }}</p>
    </div>
    <div class="card card-body">
        {{ form_start(form, {}) }}
        {{ form_row(form.title) }}
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.discipline) }}</div>
            <div>{{ form_row(form.deadline) }}</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.targetValue) }}</div>
            <div>{{ form_row(form.unit) }}</div>
        </div>
        {{ form_row(form.status) }}
        {{ form_row(form.notes) }}
        <div style="display:flex;gap:10px;padding-top:8px;">
            <button type="submit" class="btn btn-primary">
                Créer l'objectif
            </button>
            <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="btn btn-secondary">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
