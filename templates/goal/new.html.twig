{% extends 'base.html.twig' %}
{% block title %}Nouvel objectif{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="hover:text-white">{{ athlete.fullName }}</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">Nouvel objectif</span>
{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-white">Nouvel objectif</h1>
        <p class="text-gray-400 mt-1">{{ athlete.fullName }}</p>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        {{ form_row(form.title) }}
        <div class="grid grid-cols-2 gap-4">
            <div>{{ form_row(form.discipline) }}</div>
            <div>{{ form_row(form.deadline) }}</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>{{ form_row(form.targetValue) }}</div>
            <div>{{ form_row(form.unit) }}</div>
        </div>
        {{ form_row(form.status) }}
        {{ form_row(form.notes) }}
        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Créer l'objectif
            </button>
            <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
