{% extends 'base.html.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block breadcrumb %}
    <span class="current">Tableau de bord</span>
{% endblock %}

{% block body %}

{% set allPerfsJson = [] %}
{% for perf in recentPerformances %}
    {% set trend = perfTrends[perf.id] is defined ? perfTrends[perf.id] : null %}
    {% set allPerfsJson = allPerfsJson|merge([{
        athleteId:   perf.athlete.id,
        athleteName: perf.athlete.fullName,
        discipline:  perf.discipline,
        date:        perf.recordedAt|date('d/m/Y'),
        value:       perf.formattedValue,
        isPB:        perf.isPersonalBest,
        isComp:      perf.isCompetition is defined ? perf.isCompetition : false,
        trend:       trend,
    }]) %}
{% endfor %}

{% set myPerfsJson = [] %}
{% for perf in myPerformances %}
    {% set trend = myPerfTrends[perf.id] is defined ? myPerfTrends[perf.id] : null %}
    {% set isSB = myPerfSBIds[perf.id] is defined %}
    {% set myPerfsJson = myPerfsJson|merge([{
        athleteId:   perf.athlete.id,
        athleteName: perf.athlete.fullName,
        discipline:  perf.discipline,
        date:        perf.recordedAt|date('d/m/Y'),
        value:       perf.formattedValue,
        isPB:        perf.isPersonalBest,
        isSB:        isSB,
        isComp:      perf.isCompetition is defined ? perf.isCompetition : false,
        trend:       trend,
    }]) %}
{% endfor %}

<div x-data="{
    perfMode: 'all',
    allPerfs: {{ allPerfsJson|json_encode }},
    myPerfs:  {{ myPerfsJson|json_encode }},
    hasLinked: {{ linkedAthlete ? 'true' : 'false' }},
    get perfs() { return this.perfMode === 'mine' ? this.myPerfs : this.allPerfs; },
    athleteUrl(id) { return '{{ path('app_athlete_show', {id: 0}) }}'.replace('/0', '/' + id); },
}">

    {# ── Header ── #}
    <div class="page-header">
        <div>
            <h1 class="section-title">Bonjour, {{ app.user.firstName }} 👋</h1>
            <p class="section-subtitle">{{ totalAthletes }} athlète{{ totalAthletes > 1 ? 's' : '' }} suivi{{ totalAthletes > 1 ? 's' : '' }}</p>
        </div>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            {% if linkedAthlete %}
            <div class="tf-tabs">
                <button class="tf-tab" :class="perfMode === 'all' ? 'active' : ''" @click="perfMode = 'all'">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Vue coach
                </button>
                <button class="tf-tab" :class="perfMode === 'mine' ? 'active' : ''" @click="perfMode = 'mine'">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Mes perfs
                </button>
            </div>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_athlete_new') }}" class="btn btn-primary">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                Nouvel athlète
            </a>
            {% endif %}
        </div>
    </div>

    {# ── Main grid ── #}
    <div class="grid-main" style="margin-top:0;">

        {# Col gauche — séances + compétitions #}
        <div style="display:flex;flex-direction:column;gap:24px;">

            {# Prochaine séance #}
            <div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                    <h2 style="font-size:13px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.8px;">Entraînements</h2>
                    <a href="{{ path('app_calendar') }}" class="btn btn-ghost btn-sm">Calendrier →</a>
                </div>

                {% if nextSession %}
                    <a href="{{ path('app_session_show', {id: nextSession.id}) }}"
                       class="card"
                       style="display:block;text-decoration:none;padding:20px;background:linear-gradient(135deg,var(--accent-subtle),rgba(34,211,238,0.06));border-color:rgba(99,102,241,0.3);margin-bottom:10px;transition:all .2s;">
                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
                            <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--accent-hover);">Prochaine séance</span>
                            <span style="font-size:10px;color:var(--text-3);">·</span>
                            <span style="font-size:10px;color:var(--text-2);">{{ nextSession.date|date('d/m/Y') }}</span>
                        </div>
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div style="font-size:18px;font-weight:800;color:var(--text-1);">{{ nextSession.title }}</div>
                                {% if nextSession.description %}
                                    <div style="font-size:13px;color:var(--text-2);margin-top:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ nextSession.description }}</div>
                                {% endif %}
                                {% if nextSession.trainingType %}
                                    <span class="badge" style="margin-top:10px;background-color:{{ nextSession.trainingType.color }}22;color:{{ nextSession.trainingType.color }};border:1px solid {{ nextSession.trainingType.color }}44;">
                                        {{ nextSession.trainingType.name }}
                                    </span>
                                {% endif %}
                            </div>
                            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:var(--accent);flex-shrink:0;margin-top:4px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </a>
                {% endif %}

                {% if upcomingSessions|length > 1 %}
                    <div class="card" style="overflow:hidden;">
                        <div style="padding:12px 20px;border-bottom:1px solid var(--border);font-size:12.5px;font-weight:600;color:var(--text-2);">Séances à venir</div>
                        {% for session in upcomingSessions %}{% if not loop.first %}
                            <a href="{{ path('app_session_show', {id: session.id}) }}" class="list-item">
                                <div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:{% if session.trainingType %}{{ session.trainingType.color }}{% else %}var(--text-3){% endif %};"></div>
                                <div style="flex:1;min-width:0;">
                                    <div class="list-item-title truncate">{{ session.title }}</div>
                                    {% if session.trainingType %}<div class="list-item-sub">{{ session.trainingType.name }}</div>{% endif %}
                                </div>
                                <div style="font-size:11px;color:var(--text-3);flex-shrink:0;">{{ session.date|date('d/m') }}</div>
                            </a>
                        {% endif %}{% endfor %}
                    </div>
                {% elseif not nextSession %}
                    <div class="card" style="text-align:center;padding:32px;">
                        <p style="color:var(--text-2);font-size:13px;">Aucune séance planifiée</p>
                        <a href="{{ path('app_session_new') }}" class="btn btn-ghost btn-sm" style="margin-top:10px;">+ Créer une séance</a>
                    </div>
                {% endif %}
            </div>

            {# Compétitions à venir #}
            <div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                    <h2 style="font-size:13px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.8px;">Compétitions</h2>
                    <a href="{{ path('app_competition_calendar') }}" class="btn btn-ghost btn-sm">Calendrier →</a>
                </div>

                {% if nextCompetition %}
                    <a href="{{ path('app_competition_show', {id: nextCompetition.id}) }}"
                       class="card"
                       style="display:block;text-decoration:none;padding:20px;background-color:{{ nextCompetition.colorBg }}12;border-color:{{ nextCompetition.colorBg }}44;margin-bottom:10px;transition:all .2s;">
                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
                            <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:{{ nextCompetition.colorBg }};">Prochaine compétition</span>
                            <span style="font-size:10px;color:var(--text-3);">·</span>
                            <span style="font-size:10px;color:var(--text-2);">{{ nextCompetition.date|date('d/m/Y') }}</span>
                        </div>
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div style="font-size:18px;font-weight:800;color:var(--text-1);">{{ nextCompetition.title }}</div>
                                {% if nextCompetition.location %}
                                    <div style="font-size:13px;color:var(--text-2);margin-top:4px;">{{ nextCompetition.location }}</div>
                                {% endif %}
                                {% if nextCompetition.competitionType %}
                                    <span class="badge" style="margin-top:10px;background-color:{{ nextCompetition.colorBg }}22;color:{{ nextCompetition.colorBg }};border:1px solid {{ nextCompetition.colorBg }}44;">
                                        {{ nextCompetition.typeLabel }}
                                    </span>
                                {% endif %}
                            </div>
                            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:{{ nextCompetition.colorBg }};flex-shrink:0;margin-top:4px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </a>
                {% endif %}

                {% if upcomingCompetitions|length > 1 %}
                    <div class="card" style="overflow:hidden;">
                        <div style="padding:12px 20px;border-bottom:1px solid var(--border);font-size:12.5px;font-weight:600;color:var(--text-2);">À venir</div>
                        {% for competition in upcomingCompetitions %}{% if not loop.first %}
                            <a href="{{ path('app_competition_show', {id: competition.id}) }}" class="list-item">
                                <div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:{{ competition.colorBg }};"></div>
                                <div style="flex:1;min-width:0;">
                                    <div class="list-item-title truncate">{{ competition.title }}</div>
                                    <div class="list-item-sub">{{ competition.typeLabel }}{% if competition.location %} · {{ competition.location }}{% endif %}</div>
                                </div>
                                <div style="font-size:11px;color:var(--text-3);flex-shrink:0;">{{ competition.date|date('d/m') }}</div>
                            </a>
                        {% endif %}{% endfor %}
                    </div>
                {% elseif not nextCompetition %}
                    <div class="card" style="text-align:center;padding:32px;">
                        <p style="color:var(--text-2);font-size:13px;">Aucune compétition planifiée</p>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_competition_new') }}" class="btn btn-ghost btn-sm" style="margin-top:10px;">+ Ajouter</a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Col droite — performances ── #}
        <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                <h2 style="font-size:13px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.8px;">
                    Performances récentes
                    <span x-show="perfMode === 'mine'" class="badge badge-indigo" style="margin-left:6px;">Moi</span>
                </h2>
                <a href="{{ path('app_athlete_index') }}" class="btn btn-ghost btn-sm">Athlètes →</a>
            </div>

            <div class="card" style="overflow:hidden;">
                <template x-if="perfs.length === 0">
                    <div style="padding:40px;text-align:center;color:var(--text-2);font-size:13px;"
                         x-text="perfMode === 'mine' ? 'Aucune performance enregistrée pour toi.' : 'Aucune performance enregistrée.'"></div>
                </template>

                <template x-for="perf in perfs" :key="perf.athleteId + '-' + perf.discipline + '-' + perf.date">
                    <a :href="athleteUrl(perf.athleteId)" class="list-item">
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;">
                                <span class="list-item-title truncate" x-text="perf.athleteName"></span>
                                <template x-if="perfMode === 'all' && perf.isComp">
                                    <span style="font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;background:var(--warning-bg);color:var(--warning);flex-shrink:0;">COMPÉT</span>
                                </template>
                            </div>
                            <div class="list-item-sub" x-text="perf.discipline + ' · ' + perf.date"></div>
                        </div>
                        <div style="text-align:right;flex-shrink:0;">
                            <div style="font-size:13.5px;font-weight:700;color:var(--accent-hover);font-family:monospace;" x-text="perf.value"></div>
                            <div style="display:flex;align-items:center;justify-content:flex-end;gap:4px;margin-top:2px;">
                                <template x-if="perf.isPB">
                                    <span style="font-size:9px;font-weight:700;color:var(--warning);">PB</span>
                                </template>
                                <template x-if="!perf.isPB && perf.isSB && perfMode === 'mine'">
                                    <span style="font-size:9px;font-weight:700;color:var(--success);">SB</span>
                                </template>
                                <template x-if="perf.trend">
                                    <span style="font-size:11px;font-weight:600;font-family:monospace;"
                                          :style="perf.trend.improved === null ? 'color:var(--text-3)' : (perf.trend.improved ? 'color:var(--success)' : 'color:var(--danger)')"
                                          x-text="perf.trend.diff"></span>
                                </template>
                            </div>
                        </div>
                    </a>
                </template>
            </div>
        </div>

    </div>
</div>
{% endblock %}
