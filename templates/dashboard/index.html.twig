{% extends 'base.html.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block breadcrumb %}
    <span class="current">Tableau de bord</span>
{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;gap:32px;">

    {# ── Page header ── #}
    <div class="page-header">
        <div>
            <h1 class="section-title">Vue d'ensemble</h1>
            <p class="section-subtitle">Suivi de tous vos athlètes · {{ "now"|date("d F Y") }}</p>
        </div>
        <a href="{{ path('app_athlete_new') }}" class="btn btn-primary">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouvel athlète
        </a>
    </div>

    {# ── Stats ── #}
    <div class="grid-stats" data-stagger>
        <div class="stat-card indigo">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:12px;color:var(--text-2);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">Athlètes</span>
                <div class="stat-icon indigo">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
            </div>
            <div class="stat-value animate-count">
                <span data-count="{{ totalAthletes }}">{{ totalAthletes }}</span>
            </div>
            <div class="stat-label">athlètes suivis</div>
        </div>

        <div class="stat-card cyan">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:12px;color:var(--text-2);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">Séances / mois</span>
                <div class="stat-icon cyan">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
            </div>
            <div class="stat-value animate-count">
                <span data-count="{{ sessionsThisMonth }}">{{ sessionsThisMonth }}</span>
            </div>
            <div class="stat-label">ce mois-ci</div>
        </div>

        <div class="stat-card green">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:12px;color:var(--text-2);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">Objectifs atteints</span>
                <div class="stat-icon green">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <div class="stat-value animate-count">
                <span data-count="{{ goalsAchieved }}">{{ goalsAchieved }}</span>
            </div>
            <div class="stat-label">complétés</div>
        </div>

        <div class="stat-card amber">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:12px;color:var(--text-2);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">En progression</span>
                <div class="stat-icon amber">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
            </div>
            <div class="stat-value animate-count">
                <span data-count="{{ goalsInProgress }}">{{ goalsInProgress }}</span>
            </div>
            <div class="stat-label">objectifs actifs</div>
        </div>
    </div>

    {# ── Main grid ── #}
    <div class="grid-main">

        {# Athletes list #}
        <div class="card">
            <div class="card-header">
                <span class="card-title">Athlètes</span>
                <a href="{{ path('app_athlete_index') }}" class="btn btn-ghost btn-sm">
                    Voir tous
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
            {% if athletes is empty %}
                <div class="empty-state">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <h3>Aucun athlète</h3>
                    <p>Commencez par ajouter votre premier athlète</p>
                    <a href="{{ path('app_athlete_new') }}" class="btn btn-primary" style="margin-top:16px;">+ Ajouter</a>
                </div>
            {% else %}
                <div data-stagger>
                {% for athlete in athletes %}
                    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="list-item">
                        <div class="avatar avatar-md avatar-sq">
                            {% if athlete.photo %}
                                <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}">
                            {% else %}
                                {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                            {% endif %}
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div class="list-item-title truncate">{{ athlete.fullName }}</div>
                            <div class="list-item-sub truncate">
                                {{ athlete.discipline }}{% if athlete.age %} · {{ athlete.age }} ans{% endif %}
                            </div>
                        </div>
                        <div style="text-align:right;flex-shrink:0;">
                            <div style="font-size:13px;font-weight:700;color:var(--text-1);">{{ athlete.athleteSessions|length }}</div>
                            <div style="font-size:11px;color:var(--text-3);">séance{% if athlete.athleteSessions|length > 1 %}s{% endif %}</div>
                        </div>
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:var(--text-3);flex-shrink:0;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Recent performances #}
        <div class="card">
            <div class="card-header">
                <span class="card-title">Dernières performances</span>
            </div>
            {% if recentPerformances is empty %}
                <div class="empty-state" style="padding:40px 20px;">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    <h3>Aucune performance</h3>
                    <p>Pas encore de données</p>
                </div>
            {% else %}
                <div>
                {% for perf in recentPerformances %}
                    <div class="list-item" style="align-items:flex-start;">
                        <div style="flex:1;min-width:0;">
                            <div class="list-item-title truncate">{{ perf.athlete.fullName }}</div>
                            <div class="list-item-sub">{{ perf.discipline }}</div>
                        </div>
                        <div style="text-align:right;flex-shrink:0;">
                            <div class="{% if perf.isPersonalBest %}pb-val{% endif %}" style="font-size:14px;font-weight:700;{% if not perf.isPersonalBest %}color:var(--text-1);{% endif %}">
                                {{ perf.formattedValue }}
                                {% if perf.isPersonalBest %}
                                    <span style="font-size:10px;background:rgba(255,215,0,.12);color:#FFD700;padding:1px 5px;border-radius:4px;margin-left:3px;">PB</span>
                                {% endif %}
                            </div>
                            <div style="font-size:11px;color:var(--text-3);">{{ perf.recordedAt|date('d/m/Y') }}</div>
                        </div>
                    </div>
                {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
