{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block breadcrumb %}
    <span class="text-white font-semibold">Tableau de bord</span>
{% endblock %}

{% block body %}
<div class="space-y-8">

    {# Header #}
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Tableau de bord</h1>
            <p class="text-gray-400 mt-1">Vue d'ensemble de tous vos athlètes</p>
        </div>
        <a href="{{ path('app_athlete_new') }}"
           class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvel athlète
        </a>
    </div>

    {# Stats cards #}
    <div class="grid grid-cols-4 gap-4">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm text-gray-400">Athlètes</span>
                <div class="w-8 h-8 bg-indigo-600/20 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-white">{{ totalAthletes }}</p>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm text-gray-400">Séances ce mois</span>
                <div class="w-8 h-8 bg-emerald-600/20 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-white">{{ sessionsThisMonth }}</p>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm text-gray-400">Objectifs atteints</span>
                <div class="w-8 h-8 bg-yellow-600/20 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-white">{{ goalsAchieved }}</p>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm text-gray-400">Objectifs en cours</span>
                <div class="w-8 h-8 bg-blue-600/20 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-white">{{ goalsInProgress }}</p>
        </div>
    </div>

    <div class="grid grid-cols-3 gap-6">
        {# Athletes list #}
        <div class="col-span-2 bg-gray-900 border border-gray-800 rounded-xl">
            <div class="p-5 border-b border-gray-800 flex items-center justify-between">
                <h2 class="font-semibold text-white">Athlètes</h2>
                <a href="{{ path('app_athlete_index') }}" class="text-sm text-indigo-400 hover:text-indigo-300">Voir tous →</a>
            </div>
            {% if athletes is empty %}
                <div class="p-10 text-center">
                    <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <p class="text-gray-400 mb-4">Aucun athlète pour l'instant</p>
                    <a href="{{ path('app_athlete_new') }}" class="text-indigo-400 hover:text-indigo-300 text-sm font-medium">
                        + Ajouter votre premier athlète
                    </a>
                </div>
            {% else %}
                <div class="divide-y divide-gray-800">
                    {% for athlete in athletes %}
                        <a href="{{ path('app_athlete_show', {id: athlete.id}) }}"
                           class="flex items-center gap-4 px-5 py-4 hover:bg-gray-800/50 transition-colors">
                            <div class="w-10 h-10 rounded-full bg-indigo-600/30 flex items-center justify-center text-indigo-300 font-bold text-sm shrink-0 overflow-hidden">
                                {% if athlete.photo %}
                                    <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}" class="w-full h-full object-cover">
                                {% else %}
                                    {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-white truncate">{{ athlete.fullName }}</p>
                                <p class="text-sm text-gray-400 truncate">{{ athlete.discipline }}{% if athlete.age %} · {{ athlete.age }} ans{% endif %}</p>
                            </div>
                            <div class="text-xs text-gray-500">
                                {{ athlete.athleteSessions|length }} séance{% if athlete.athleteSessions|length > 1 %}s{% endif %}
                            </div>
                            <svg class="w-4 h-4 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Recent performances #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl">
            <div class="p-5 border-b border-gray-800">
                <h2 class="font-semibold text-white">Dernières performances</h2>
            </div>
            {% if recentPerformances is empty %}
                <div class="p-8 text-center text-gray-500 text-sm">
                    Aucune performance enregistrée
                </div>
            {% else %}
                <div class="divide-y divide-gray-800">
                    {% for perf in recentPerformances %}
                        <div class="px-5 py-3">
                            <div class="flex items-center justify-between">
                                <div class="min-w-0 flex-1">
                                    <p class="text-sm font-medium text-white truncate">{{ perf.athlete.fullName }}</p>
                                    <p class="text-xs text-gray-400">{{ perf.discipline }}</p>
                                </div>
                                <div class="text-right shrink-0 ml-2">
                                    <p class="text-sm font-bold {% if perf.isPersonalBest %}text-yellow-400{% else %}text-white{% endif %}">
                                        {{ perf.formattedValue }}
                                        {% if perf.isPersonalBest %}<span class="text-xs">PB</span>{% endif %}
                                    </p>
                                    <p class="text-xs text-gray-500">{{ perf.recordedAt|date('d/m') }}</p>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
