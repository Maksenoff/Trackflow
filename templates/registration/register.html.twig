<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer un compte — TrackFlow</title>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body style="margin:0;min-height:100vh;display:flex;font-family:system-ui,sans-serif;background:#0d1117;color:#f3f4f6">

    {# ── Panneau gauche — identique à la page de connexion ── #}
    <div style="width:50%;background:linear-gradient(135deg,#1e1b4b 0%,#312e81 45%,#4338ca 100%);display:flex;flex-direction:column;position:relative;overflow:hidden"
         class="hidden lg:flex">

        <div style="position:absolute;width:480px;height:480px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(129,140,248,0.2)"></div>
        <div style="position:absolute;width:320px;height:320px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(129,140,248,0.3)"></div>
        <div style="position:absolute;width:160px;height:160px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(165,180,252,0.35)"></div>
        <div style="position:absolute;width:580px;height:580px;top:-120px;right:-160px;border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.18),transparent 70%)"></div>
        <div style="position:absolute;width:280px;height:280px;bottom:60px;left:-80px;border-radius:50%;background:radial-gradient(circle,rgba(129,140,248,0.12),transparent 70%)"></div>

        <div style="position:relative;display:flex;flex-direction:column;height:100%;padding:44px 52px">
            <div style="display:flex;align-items:center;gap:10px">
                <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <span style="font-size:17px;font-weight:700;color:white;letter-spacing:-0.3px">TrackFlow</span>
            </div>

            <div style="flex:1;display:flex;flex-direction:column;justify-content:center;gap:40px">
                <div>
                    <p style="font-size:44px;font-weight:800;color:white;line-height:1.1;margin:0 0 14px">
                        Chaque<br>seconde<br><span style="color:#a5b4fc">compte.</span>
                    </p>
                    <p style="font-size:14px;color:rgba(199,210,254,0.55);line-height:1.6;margin:0;max-width:240px">
                        Performances, résultats FFA et objectifs — tout au même endroit.
                    </p>
                </div>

                <div style="display:flex;flex-direction:column;gap:10px">
                    <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Performances &amp; records</p>
                            <p style="font-size:12px;color:rgba(165,180,252,0.55);margin:0;line-height:1.5">Historique complet, meilleures marques, graphiques d'évolution par discipline.</p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Sync athle.fr</p>
                            <p style="font-size:12px;color:rgba(165,180,252,0.55);margin:0;line-height:1.5">Import automatique des résultats FFA depuis bases.athle.fr.</p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Calendrier &amp; séances</p>
                            <p style="font-size:12px;color:rgba(165,180,252,0.55);margin:0;line-height:1.5">Planification des entraînements, suivi des charges et types de séance.</p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Objectifs &amp; vidéos</p>
                            <p style="font-size:12px;color:rgba(165,180,252,0.55);margin:0;line-height:1.5">Suivi des objectifs de saison et bibliothèque vidéo par athlète.</p>
                        </div>
                    </div>
                </div>
            </div>

            <p style="font-size:12px;color:rgba(165,180,252,0.3)">© TrackFlow {{ "now"|date("Y") }}</p>
        </div>
    </div>

    {# ── Panneau droit — formulaire ── #}
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:32px 24px;overflow-y:auto">
        <div style="width:100%;max-width:400px;padding:24px 0">

            {# Logo centré #}
            <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:28px">
                <div style="width:36px;height:36px;border-radius:10px;background:#6366f1;display:flex;align-items:center;justify-content:center">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <span style="font-size:18px;font-weight:700;color:white;letter-spacing:-0.3px">TrackFlow</span>
            </div>

            {# Carte #}
            <div style="background:#161b22;border:1px solid #30363d;border-radius:16px;padding:32px">

                <h1 style="font-size:20px;font-weight:700;color:white;margin:0 0 6px">Créer un compte</h1>
                <p style="font-size:13px;color:#8b949e;margin:0 0 24px">Rejoignez TrackFlow pour suivre vos performances.</p>

                {# Flash messages #}
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div style="font-size:13px;padding:11px 14px;border-radius:10px;margin-bottom:16px;
                             {% if type == 'error' %}background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);color:#f87171
                             {% else %}background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.25);color:#a5b4fc{% endif %}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                {{ form_start(form, {attr: {style: 'display:flex;flex-direction:column;gap:16px', novalidate: 'novalidate'}}) }}

                {# ── Prénom / Nom ── #}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div>
                        <label style="display:block;font-size:13px;font-weight:500;color:#c9d1d9;margin-bottom:6px">Prénom</label>
                        <input type="text"
                               name="{{ form.firstName.vars.full_name }}"
                               value="{{ form.firstName.vars.value }}"
                               id="{{ form.firstName.vars.id }}"
                               placeholder="Prénom"
                               style="width:100%;box-sizing:border-box;background:#0d1117;border:1px solid #30363d;color:white;border-radius:10px;padding:10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s"
                               onfocus="this.style.borderColor='#6366f1';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.15)'"
                               onblur="this.style.borderColor='#30363d';this.style.boxShadow='none'">
                        {% if form.firstName.vars.errors|length > 0 %}
                            <p style="font-size:12px;color:#f87171;margin:5px 0 0">{{ form_errors(form.firstName) }}</p>
                        {% endif %}
                    </div>
                    <div>
                        <label style="display:block;font-size:13px;font-weight:500;color:#c9d1d9;margin-bottom:6px">Nom</label>
                        <input type="text"
                               name="{{ form.lastName.vars.full_name }}"
                               value="{{ form.lastName.vars.value }}"
                               id="{{ form.lastName.vars.id }}"
                               placeholder="Nom"
                               style="width:100%;box-sizing:border-box;background:#0d1117;border:1px solid #30363d;color:white;border-radius:10px;padding:10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s"
                               onfocus="this.style.borderColor='#6366f1';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.15)'"
                               onblur="this.style.borderColor='#30363d';this.style.boxShadow='none'">
                        {% if form.lastName.vars.errors|length > 0 %}
                            <p style="font-size:12px;color:#f87171;margin:5px 0 0">{{ form_errors(form.lastName) }}</p>
                        {% endif %}
                    </div>
                </div>

                {# ── Email ── #}
                <div>
                    <label style="display:block;font-size:13px;font-weight:500;color:#c9d1d9;margin-bottom:6px">Email</label>
                    <input type="email"
                           name="{{ form.email.vars.full_name }}"
                           value="{{ form.email.vars.value }}"
                           id="{{ form.email.vars.id }}"
                           placeholder="vous@exemple.fr"
                           style="width:100%;box-sizing:border-box;background:#0d1117;border:1px solid #30363d;color:white;border-radius:10px;padding:10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s"
                           onfocus="this.style.borderColor='#6366f1';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.15)'"
                           onblur="this.style.borderColor='#30363d';this.style.boxShadow='none'">
                    {% if form.email.vars.errors|length > 0 %}
                        <p style="font-size:12px;color:#f87171;margin:5px 0 0">{{ form_errors(form.email) }}</p>
                    {% endif %}
                </div>

                {# ── Mot de passe ── #}
                <div x-data="{ show1: false }">
                    <label style="display:block;font-size:13px;font-weight:500;color:#c9d1d9;margin-bottom:6px">Mot de passe</label>
                    <div style="position:relative">
                        <input :type="show1 ? 'text' : 'password'"
                               name="{{ form.plainPassword.first.vars.full_name }}"
                               id="{{ form.plainPassword.first.vars.id }}"
                               placeholder="Min. 8 caractères"
                               autocomplete="new-password"
                               style="width:100%;box-sizing:border-box;background:#0d1117;border:1px solid #30363d;color:white;border-radius:10px;padding:10px 42px 10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s"
                               onfocus="this.style.borderColor='#6366f1';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.15)'"
                               onblur="this.style.borderColor='#30363d';this.style.boxShadow='none'">
                        <button type="button" @click="show1 = !show1"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;cursor:pointer;color:#6e7681;display:flex;align-items:center"
                                onmouseover="this.style.color='#c9d1d9'" onmouseout="this.style.color='#6e7681'">
                            <svg x-show="!show1" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg x-show="show1" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.first.vars.errors|length > 0 %}
                        <p style="font-size:12px;color:#f87171;margin:5px 0 0">{{ form_errors(form.plainPassword.first) }}</p>
                    {% endif %}
                </div>

                {# ── Confirmer le mot de passe ── #}
                <div x-data="{ show2: false }">
                    <label style="display:block;font-size:13px;font-weight:500;color:#c9d1d9;margin-bottom:6px">Confirmer le mot de passe</label>
                    <div style="position:relative">
                        <input :type="show2 ? 'text' : 'password'"
                               name="{{ form.plainPassword.second.vars.full_name }}"
                               id="{{ form.plainPassword.second.vars.id }}"
                               placeholder="Répétez le mot de passe"
                               autocomplete="new-password"
                               style="width:100%;box-sizing:border-box;background:#0d1117;border:1px solid #30363d;color:white;border-radius:10px;padding:10px 42px 10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s"
                               onfocus="this.style.borderColor='#6366f1';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.15)'"
                               onblur="this.style.borderColor='#30363d';this.style.boxShadow='none'">
                        <button type="button" @click="show2 = !show2"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;cursor:pointer;color:#6e7681;display:flex;align-items:center"
                                onmouseover="this.style.color='#c9d1d9'" onmouseout="this.style.color='#6e7681'">
                            <svg x-show="!show2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg x-show="show2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.second.vars.errors|length > 0 %}
                        <p style="font-size:12px;color:#f87171;margin:5px 0 0">{{ form_errors(form.plainPassword.second) }}</p>
                    {% endif %}
                </div>

                {# ── Bouton submit ── #}
                <button type="submit"
                        style="width:100%;background:#6366f1;color:white;font-size:14px;font-weight:600;padding:11px;border:none;border-radius:10px;cursor:pointer;transition:background .15s"
                        onmouseover="this.style.background='#4f46e5'"
                        onmouseout="this.style.background='#6366f1'">
                    Créer mon compte
                </button>

                {# ── Lien connexion ── #}
                <p style="text-align:center;font-size:13px;color:#484f58;margin:4px 0 0;padding-top:16px;border-top:1px solid #21262d">
                    Déjà un compte ?
                    <a href="{{ path('app_login') }}" style="color:#6366f1;font-weight:500;text-decoration:none"
                       onmouseover="this.style.color='#818cf8'"
                       onmouseout="this.style.color='#6366f1'">Se connecter</a>
                </p>

                {{ form_widget(form._token) }}
                {{ form_end(form, {'render_rest': false}) }}
            </div>
        </div>
    </div>

</body>
</html>
