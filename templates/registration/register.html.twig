<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer un compte — TrackFlow</title>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    <style>
        :root,[data-theme="dark"]{
            --bg:#06060f;--bg-2:#0c0c1d;
            --border:rgba(255,255,255,0.07);
            --text-1:#f1f5f9;--text-2:#94a3b8;--text-3:#64748b;
            --accent:#6366f1;--accent-hover:#4f46e5;--accent-rgb:99,102,241;
            --card-bg:#0f0f23;--card-border:rgba(255,255,255,0.07);
            --input-bg:#06060f;--input-border:rgba(255,255,255,0.10);
            --feature-bg:rgba(0,0,0,0.2);--feature-border:rgba(255,255,255,0.06);
            --left-sub:rgba(165,180,252,0.55);--left-footer:rgba(165,180,252,0.3);
            --divider:rgba(255,255,255,0.06);--danger:#f87171;
        }
        [data-theme="light"]{
            --bg:#f0f4ff;--bg-2:#e8eeff;
            --border:rgba(0,0,0,0.08);
            --text-1:#0f172a;--text-2:#475569;--text-3:#94a3b8;
            --accent:#4f46e5;--accent-hover:#4338ca;--accent-rgb:79,70,229;
            --card-bg:#ffffff;--card-border:rgba(0,0,0,0.08);
            --input-bg:#f8faff;--input-border:rgba(0,0,0,0.12);
            --feature-bg:rgba(0,0,0,0.15);--feature-border:rgba(255,255,255,0.08);
            --left-sub:rgba(165,180,252,0.7);--left-footer:rgba(165,180,252,0.4);
            --divider:rgba(0,0,0,0.06);--danger:#ef4444;
        }
        *,*::before,*::after{box-sizing:border-box}
        body{margin:0;min-height:100vh;display:flex;font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text-1);transition:background .3s,color .3s}
        .login-left{width:50%;background:linear-gradient(135deg,#1e1b4b 0%,#312e81 45%,#4338ca 100%);display:flex;flex-direction:column;position:relative;overflow:hidden}
        @media(max-width:1023px){.login-left{display:none!important}}
        .login-right{flex:1;display:flex;align-items:center;justify-content:center;padding:32px 24px;overflow-y:auto;position:relative}
        .login-card{width:100%;max-width:400px;padding:24px 0}
        .card-box{background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:32px;transition:background .3s,border-color .3s}
        .form-field{display:flex;flex-direction:column;gap:6px}
        .form-field label{font-size:13px;font-weight:500;color:var(--text-2)}
        .form-field input{width:100%;background:var(--input-bg);border:1px solid var(--input-border);color:var(--text-1);border-radius:10px;padding:10px 14px;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s;font-family:inherit}
        .form-field input.pw-input{padding-right:42px}
        .form-field input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(var(--accent-rgb),.15)}
        .form-field input::placeholder{color:var(--text-3)}
        .field-error{font-size:12px;color:var(--danger);margin:4px 0 0}
        .pw-wrap{position:relative}
        .pw-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;cursor:pointer;color:var(--text-3);display:flex;align-items:center;transition:color .15s}
        .pw-eye:hover{color:var(--text-2)}
        .submit-btn{width:100%;background:var(--accent);color:white;font-size:14px;font-weight:600;padding:11px;border:none;border-radius:10px;cursor:pointer;transition:background .15s,transform .1s;font-family:inherit}
        .submit-btn:hover{background:var(--accent-hover)}
        .submit-btn:active{transform:scale(0.98)}
        .theme-toggle-login{position:absolute;top:20px;right:20px;background:var(--card-bg);border:1px solid var(--card-border);border-radius:10px;padding:8px;cursor:pointer;color:var(--text-2);display:flex;align-items:center;transition:background .3s,border-color .3s}
        .theme-toggle-login:hover{color:var(--text-1)}
        .logo-row{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:28px}
        .logo-mark{width:36px;height:36px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .logo-name{font-size:18px;font-weight:700;color:var(--text-1);letter-spacing:-.3px}
        .card-title{font-size:20px;font-weight:700;color:var(--text-1);margin:0 0 6px}
        .card-sub{font-size:13px;color:var(--text-2);margin:0 0 24px}
        .form-footer{text-align:center;font-size:13px;color:var(--text-3);margin:4px 0 0;padding-top:16px;border-top:1px solid var(--divider)}
        .form-footer a{color:var(--accent);font-weight:500;text-decoration:none}
        .form-footer a:hover{color:var(--accent-hover)}
        .name-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
        .flash-msg{font-size:13px;padding:11px 14px;border-radius:10px;margin-bottom:16px}
        .flash-error{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171}
        .flash-info{background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);color:#a5b4fc}
    </style>
</head>
<body>

    <button class="theme-toggle-login" onclick="TF_Login.toggleTheme()" title="Changer le thème">
        <svg id="ltt-sun" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
            <circle cx="12" cy="12" r="5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg id="ltt-moon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
    </button>

    {# ── Panneau gauche — branding ── #}
    <div class="login-left">
        <div style="position:absolute;width:480px;height:480px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(129,140,248,0.2)"></div>
        <div style="position:absolute;width:320px;height:320px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(129,140,248,0.3)"></div>
        <div style="position:absolute;width:160px;height:160px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(165,180,252,0.35)"></div>
        <div style="position:absolute;width:580px;height:580px;top:-120px;right:-160px;border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.18),transparent 70%)"></div>
        <div style="position:absolute;width:280px;height:280px;bottom:60px;left:-80px;border-radius:50%;background:radial-gradient(circle,rgba(129,140,248,0.12),transparent 70%)"></div>

        <div style="position:relative;display:flex;flex-direction:column;height:100%;padding:44px 52px">
            <div style="display:flex;align-items:center;gap:10px">
                <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <span style="font-size:17px;font-weight:700;color:white;letter-spacing:-0.3px">TrackFlow</span>
            </div>

            <div style="flex:1;display:flex;flex-direction:column;justify-content:center;gap:40px">
                <div>
                    <p style="font-size:44px;font-weight:800;color:white;line-height:1.1;margin:0 0 14px">
                        Chaque<br>seconde<br><span style="color:#a5b4fc">compte.</span>
                    </p>
                    <p style="font-size:14px;color:var(--left-sub);line-height:1.6;margin:0;max-width:240px">
                        Performances, résultats FFA et objectifs — tout au même endroit.
                    </p>
                </div>

                <div style="display:flex;flex-direction:column;gap:10px">
                    <div style="display:flex;align-items:flex-start;gap:14px;background:var(--feature-bg);border:1px solid var(--feature-border);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Performances &amp; records</p>
                            <p style="font-size:12px;color:var(--left-sub);margin:0;line-height:1.5">Historique complet, meilleures marques, graphiques d'évolution par discipline.</p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:14px;background:var(--feature-bg);border:1px solid var(--feature-border);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Sync athle.fr</p>
                            <p style="font-size:12px;color:var(--left-sub);margin:0;line-height:1.5">Import automatique des résultats FFA depuis bases.athle.fr.</p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:14px;background:var(--feature-bg);border:1px solid var(--feature-border);border-radius:12px;padding:14px 16px">
                        <div style="width:36px;height:36px;border-radius:9px;background:rgba(99,102,241,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
                            <svg width="16" height="16" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                            <p style="font-size:14px;font-weight:600;color:white;margin:0 0 3px">Calendrier &amp; séances</p>
                            <p style="font-size:12px;color:var(--left-sub);margin:0;line-height:1.5">Planification des entraînements, suivi des charges et types de séance.</p>
                        </div>
                    </div>
                </div>
            </div>

            <p style="font-size:12px;color:var(--left-footer)">© TrackFlow {{ "now"|date("Y") }}</p>
        </div>
    </div>

    {# ── Panneau droit — formulaire ── #}
    <div class="login-right">
        <div class="login-card">

            <div class="logo-row">
                <div class="logo-mark">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <span class="logo-name">TrackFlow</span>
            </div>

            <div class="card-box">
                <h1 class="card-title">Créer un compte</h1>
                <p class="card-sub">Rejoignez TrackFlow pour suivre vos performances.</p>

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash-msg {{ type == 'error' ? 'flash-error' : 'flash-info' }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                {{ form_start(form, {attr: {style: 'display:flex;flex-direction:column;gap:16px', novalidate: 'novalidate'}}) }}

                <div class="name-grid">
                    <div class="form-field">
                        <label for="{{ form.firstName.vars.id }}">Prénom</label>
                        <input type="text"
                               name="{{ form.firstName.vars.full_name }}"
                               value="{{ form.firstName.vars.value }}"
                               id="{{ form.firstName.vars.id }}"
                               placeholder="Prénom">
                        {% if form.firstName.vars.errors|length > 0 %}
                            <p class="field-error">{{ form_errors(form.firstName) }}</p>
                        {% endif %}
                    </div>
                    <div class="form-field">
                        <label for="{{ form.lastName.vars.id }}">Nom</label>
                        <input type="text"
                               name="{{ form.lastName.vars.full_name }}"
                               value="{{ form.lastName.vars.value }}"
                               id="{{ form.lastName.vars.id }}"
                               placeholder="Nom">
                        {% if form.lastName.vars.errors|length > 0 %}
                            <p class="field-error">{{ form_errors(form.lastName) }}</p>
                        {% endif %}
                    </div>
                </div>

                <div class="form-field">
                    <label for="{{ form.email.vars.id }}">Email</label>
                    <input type="email"
                           name="{{ form.email.vars.full_name }}"
                           value="{{ form.email.vars.value }}"
                           id="{{ form.email.vars.id }}"
                           placeholder="vous@exemple.fr">
                    {% if form.email.vars.errors|length > 0 %}
                        <p class="field-error">{{ form_errors(form.email) }}</p>
                    {% endif %}
                </div>

                <div class="form-field" x-data="{ show1: false }">
                    <label for="{{ form.plainPassword.first.vars.id }}">Mot de passe</label>
                    <div class="pw-wrap">
                        <input :type="show1 ? 'text' : 'password'" class="pw-input"
                               name="{{ form.plainPassword.first.vars.full_name }}"
                               id="{{ form.plainPassword.first.vars.id }}"
                               placeholder="Min. 8 caractères"
                               autocomplete="new-password">
                        <button type="button" class="pw-eye" @click="show1 = !show1">
                            <svg x-show="!show1" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg x-show="show1" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.first.vars.errors|length > 0 %}
                        <p class="field-error">{{ form_errors(form.plainPassword.first) }}</p>
                    {% endif %}
                </div>

                <div class="form-field" x-data="{ show2: false }">
                    <label for="{{ form.plainPassword.second.vars.id }}">Confirmer le mot de passe</label>
                    <div class="pw-wrap">
                        <input :type="show2 ? 'text' : 'password'" class="pw-input"
                               name="{{ form.plainPassword.second.vars.full_name }}"
                               id="{{ form.plainPassword.second.vars.id }}"
                               placeholder="Répétez le mot de passe"
                               autocomplete="new-password">
                        <button type="button" class="pw-eye" @click="show2 = !show2">
                            <svg x-show="!show2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg x-show="show2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                            </svg>
                        </button>
                    </div>
                    {% if form.plainPassword.second.vars.errors|length > 0 %}
                        <p class="field-error">{{ form_errors(form.plainPassword.second) }}</p>
                    {% endif %}
                </div>

                <button type="submit" class="submit-btn">Créer mon compte</button>

                <p class="form-footer">
                    Déjà un compte ?
                    <a href="{{ path('app_login') }}">Se connecter</a>
                </p>

                {{ form_widget(form._token) }}
                {{ form_end(form, {'render_rest': false}) }}
            </div>
        </div>
    </div>

    <script>
    <script>
window.TF_Login = window.TF_Login || {
    toggleTheme() {
        const html = document.documentElement;
        const isDark = html.getAttribute('data-theme') === 'dark';
        const next = isDark ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('tf-theme', next);
        document.getElementById('ltt-sun').style.display = isDark ? 'block' : 'none';
        document.getElementById('ltt-moon').style.display = isDark ? 'none' : 'block';
    },
    init() {
        const saved = localStorage.getItem('tf-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', saved);
        document.getElementById('ltt-sun').style.display = saved === 'light' ? 'block' : 'none';
        document.getElementById('ltt-moon').style.display = saved === 'dark' ? 'block' : 'none';
    }
};

window.TF_Login.init();
</script>
    </script>

</body>
</html>
