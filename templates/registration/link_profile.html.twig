{% extends 'base.html.twig' %}
{% block title %}Créer mon profil athlète{% endblock %}

{% block breadcrumb %}
    <span class="current">Créer mon profil</span>
{% endblock %}

{% block body %}
<div id="js-form-ids"
    data-ffa-url="{{ form.ffaProfileUrl.vars.id }}"
    data-first-name="{{ form.firstName.vars.id }}"
    data-last-name="{{ form.lastName.vars.id }}"
    data-birth-date="{{ form.birthDate.vars.id }}"
    data-gender="{{ form.gender.vars.id }}"
    style="display:none"></div>

<div style="max-width:640px;margin:0 auto;" x-data="newAthlete()" x-init="init()">

    <div style="margin-bottom:24px;display:flex;align-items:flex-start;justify-content:space-between;gap:16px;">
        <div>
            <h1 class="section-title">Créer mon profil athlète</h1>
            <p class="section-subtitle">Liez votre compte à votre profil FFA pour synchroniser vos résultats automatiquement.</p>
        </div>
        <a href="{{ path('app_athlete_index') }}" class="btn btn-ghost btn-sm" style="white-space:nowrap;margin-top:4px;">
            Passer
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>

    {# Step 1 — Choose mode #}
    <div x-show="step === 'choose'" x-transition style="display:grid;grid-template-columns:1fr 1fr;gap:16px;" data-stagger>
        <button type="button" @click="step = 'licence'"
                class="card card-hover card-accent-hover"
                style="padding:24px;text-align:left;background:none;cursor:pointer;border:none;width:100%;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(var(--accent-rgb),.15);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <svg width="20" height="20" fill="none" stroke="var(--accent)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
            </div>
            <h3 style="font-size:15px;font-weight:600;color:var(--text-1);margin:0 0 6px">Avec mon profil athle.fr</h3>
            <p style="font-size:13px;color:var(--text-2);margin:0;line-height:1.5">Collez l'URL de votre profil athle.fr pour préremplir et synchroniser vos résultats.</p>
        </button>

        <button type="button" @click="step = 'form'"
                class="card card-hover"
                style="padding:24px;text-align:left;background:none;cursor:pointer;border:none;width:100%;">
            <div style="width:40px;height:40px;border-radius:10px;background:var(--bg-hover);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <svg width="20" height="20" fill="none" stroke="var(--text-2)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <h3 style="font-size:15px;font-weight:600;color:var(--text-1);margin:0 0 6px">Manuellement</h3>
            <p style="font-size:13px;color:var(--text-2);margin:0;line-height:1.5">Remplissez vos informations vous-même.</p>
        </button>
    </div>

    {# Step 2 — URL lookup #}
    <div x-show="step === 'licence'" x-transition class="card card-body">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
            <button type="button" @click="step = 'choose'" class="btn btn-ghost btn-sm" style="padding:6px;">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <h2 style="font-size:16px;font-weight:600;color:var(--text-1);margin:0">Recherche via athle.fr</h2>
        </div>

        <p style="font-size:13px;color:var(--text-2);margin:0 0 16px;line-height:1.6">
            Allez sur <strong style="color:var(--text-1)">athle.fr</strong> ou <strong style="color:var(--text-1)">bases.athle.fr</strong>, trouvez votre profil, puis copiez l'URL.
        </p>

        <div style="display:flex;gap:10px;">
            <input type="text"
                   x-model="urlInput"
                   @keydown.enter="lookupUrl()"
                   placeholder="https://www.athle.fr/athlete/… ou https://bases.athle.fr/…"
                   class="form-input"
                   style="flex:1;">
            <button type="button" @click="lookupUrl()"
                    :disabled="lookupLoading || !urlInput.trim()"
                    class="btn btn-primary">
                <svg x-show="lookupLoading" width="14" height="14" fill="none" viewBox="0 0 24 24" style="animation:spin 1s linear infinite">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity:.25"/>
                    <path fill="currentColor" d="M4 12a8 8 0 018-8v8z" style="opacity:.75"/>
                </svg>
                <span x-text="lookupLoading ? 'Chargement…' : 'Importer'"></span>
            </button>
        </div>

        <div x-show="lookupError" x-text="lookupError"
             style="margin-top:12px;font-size:13px;color:var(--danger);background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:10px 14px;display:none"></div>
    </div>

    {# Step 3 — Form #}
    <div x-show="step === 'form'" class="card card-body">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
            <button type="button" @click="step = 'choose'" class="btn btn-ghost btn-sm" style="padding:6px;">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <h2 style="font-size:16px;font-weight:600;color:var(--text-1);margin:0">Mes informations</h2>
            <span x-show="prefilled" class="badge badge-green" style="display:none">
                <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Prérempli via athle.fr
            </span>
            <span x-show="syncReady" class="badge badge-indigo" style="display:none">
                <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
                Sync résultats activée
            </span>
        </div>

        {{ form_start(form, {attr: {class: 'space-y-5', enctype: 'multipart/form-data', novalidate: 'novalidate', 'data-turbo': 'false'}}) }}

        {{ form_row(form.ffaProfileUrl) }}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>{{ form_row(form.firstName) }}</div>
            <div>{{ form_row(form.lastName) }}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>{{ form_row(form.birthDate) }}</div>
            <div>{{ form_row(form.gender) }}</div>
        </div>

        <div>
            <p class="form-label">Spécialités</p>
            <input type="hidden" name="disciplines_raw" id="disciplines_raw_link" value="[]">
            <div style="display:flex;flex-wrap:wrap;gap:8px;" id="disc-pills-link">
                {% for label, value in disciplines %}
                    <button type="button"
                            class="disc-pill btn btn-sm"
                            data-value="{{ value }}"
                            data-hidden="disciplines_raw_link"
                            onclick="discPillToggle(this)">
                        {{ label }}
                    </button>
                {% endfor %}
            </div>
        </div>

        {{ form_row(form.notes) }}
        {{ form_row(form.photoFile) }}

        <div style="padding-top:8px;">
            <button type="submit" class="btn btn-primary">Créer mon profil</button>
        </div>
        {{ form_end(form) }}
    </div>

</div>

<style>
@keyframes spin{to{transform:rotate(360deg)}}
.disc-pill{background:var(--bg-hover);color:var(--text-2);border:1px solid var(--border);}
.disc-pill.active{background:var(--accent);color:#fff;border-color:var(--accent);}
</style>

<script>
(function () {
    var ids = document.getElementById('js-form-ids').dataset;

    function newAthlete() {
        return {
            step: 'choose',
            urlInput: '',
            lookupLoading: false,
            lookupError: '',
            prefilled: false,
            syncReady: false,

            init() {
                {% if form.vars.submitted %}
                this.step = 'form';
                {% endif %}
            },

            lookupUrl() {
                var url = this.urlInput.trim();
                if (!url) return;
                this.lookupLoading = true;
                this.lookupError   = '';
                var fd = new FormData();
                fd.append('url', url);
                fetch('{{ path('app_athlete_lookup_ffa') }}', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: fd,
                })
                .then(r => r.json())
                .then(data => {
                    this.lookupLoading = false;
                    if (data.error && !data.firstName && !data.lastName) {
                        this.lookupError = data.error;
                        return;
                    }
                    this.prefilled = !!data.firstName;
                    this.syncReady = !!data.basesUrl;
                    this.step      = 'form';
                    this.$nextTick(() => this.prefill(data));
                })
                .catch(err => {
                    this.lookupLoading = false;
                    this.lookupError   = 'Erreur réseau (' + err.message + ')';
                });
            },

            prefill(data) {
                var profileUrl = data.basesUrl || this.urlInput.trim();
                var fields = {
                    [ids.ffaUrl]:    profileUrl,
                    [ids.firstName]: data.firstName  || '',
                    [ids.lastName]:  data.lastName   || '',
                    [ids.birthDate]: data.birthDate  || '',
                    [ids.gender]:    data.gender     || '',
                };
                Object.entries(fields).forEach(([id, val]) => {
                    if (!val) return;
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.value = val;
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                    el.dispatchEvent(new Event('input',  { bubbles: true }));
                });
                if (data.discipline && data.discipline.length > 0) {
                    var discs = Array.isArray(data.discipline) ? data.discipline : [data.discipline];
                    document.querySelectorAll('#disc-pills-link .disc-pill').forEach(function(btn) {
                        if (discs.includes(btn.dataset.value) && !btn.classList.contains('active')) {
                            discPillToggle(btn);
                        }
                    });
                }
            },
        };
    }

    window.newAthlete = newAthlete;
}());

function discPillToggle(btn) {
    var hiddenInput = document.getElementById(btn.dataset.hidden);
    if (!hiddenInput) return;
    var selected = JSON.parse(hiddenInput.value || '[]');
    var val = btn.dataset.value;
    var idx = selected.indexOf(val);
    if (idx === -1) {
        selected.push(val);
        btn.classList.add('active');
    } else {
        selected.splice(idx, 1);
        btn.classList.remove('active');
    }
    hiddenInput.value = JSON.stringify(selected);
}
</script>
{% endblock %}
