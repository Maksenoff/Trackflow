{% extends 'base.html.twig' %}
{% block title %}Types de séances{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_calendar') }}">Calendrier</a>
    <span class="sep">/</span>
    <span class="current">Types de séances</span>
{% endblock %}

{% block body %}
<div style="max-width:560px;margin:0 auto;display:flex;flex-direction:column;gap:24px;">

    <div>
        <h1 class="section-title">Types de séances</h1>
        <p class="section-subtitle">Gérez les pastilles de type utilisées dans le calendrier.</p>
    </div>

    {# Liste des types existants #}
    <div class="card" style="overflow:hidden;">
        <div id="tt-list">
            {% if types is empty %}
                <div id="tt-empty" class="empty-state" style="padding:48px;">
                    <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 012-2z"/></svg>
                    <p>Aucun type créé.</p>
                </div>
            {% else %}
                {% for type in types %}
                    {{ include('training_type/_item.html.twig') }}
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# Créer un nouveau type #}
    <div class="card card-body"
         x-data="{
             color: '#6366f1',
             palette: ['#ef4444','#f97316','#f59e0b','#eab308','#84cc16','#22c55e','#10b981','#14b8a6','#06b6d4','#3b82f6','#6366f1','#8b5cf6','#a855f7','#ec4899','#f43f5e','#64748b'],
             async createType(e) {
                 const form = e.target;
                 const res = await fetch(form.action, {
                     method: 'POST',
                     headers: { 'X-Requested-With': 'XMLHttpRequest' },
                     body: new URLSearchParams(new FormData(form))
                 });
                 const json = await res.json();
                 if (json.ok) {
                     document.getElementById('tt-empty')?.remove();
                     document.getElementById('tt-list').insertAdjacentHTML('beforeend', json.html);
                     form.reset();
                     this.color = '#6366f1';
                 }
             }
         }">
        <h2 style="font-size:12px;font-weight:600;color:var(--text-3);margin:0 0 20px;text-transform:uppercase;letter-spacing:.07em;">Nouveau type</h2>
        {{ form_start(form, {attr: {'@submit.prevent': 'createType($event)', style: 'display:flex;flex-direction:column;gap:16px;'}}) }}
            <input type="hidden" name="training_type[color]" :value="color">
            {% do form.color.setRendered() %}
            {{ form_row(form.name) }}
            <div>
                <p class="form-label">Couleur</p>
                <div style="display:grid;grid-template-columns:repeat(8,1fr);gap:8px;">
                    <template x-for="c in palette" :key="c">
                        <button type="button" @click="color = c"
                                :style="'aspect-ratio:1;border-radius:8px;cursor:pointer;border:none;background:' + c + ';opacity:' + (color === c ? '1' : '.55') + ';transform:' + (color === c ? 'scale(1.15)' : 'scale(1)') + ';box-shadow:' + (color === c ? '0 0 0 3px var(--bg-card-solid), 0 0 0 5px ' + c : 'none') + ';transition:all .15s;'">
                        </button>
                    </template>
                </div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:12px;">
                    <span style="width:24px;height:24px;border-radius:6px;flex-shrink:0;" :style="'background:' + color + ';box-shadow:0 0 8px ' + color + '60'"></span>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="color"></span>
                </div>
            </div>
            <div>
                <button type="submit" class="btn btn-primary">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Ajouter
                </button>
            </div>
        {{ form_end(form) }}
    </div>

    <a href="{{ path('app_calendar') }}" class="btn btn-ghost btn-sm" style="align-self:flex-start;">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Retour au calendrier
    </a>

</div>
{% endblock %}
