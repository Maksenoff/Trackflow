{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Utilisateurs</span>
{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;gap:24px;">

    {# Header #}
    <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
            <h1 class="section-title">Utilisateurs</h1>
            <p class="section-subtitle">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}</p>
        </div>
    </div>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding:12px 16px;border-radius:12px;font-size:13px;font-weight:500;
                {% if type == 'success' %}background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.25);color:#34d399;
                {% elseif type == 'error' %}background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171;
                {% else %}background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);color:#a5b4fc;{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Table #}
    <div class="card" style="overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead>
                <tr style="border-bottom:1px solid var(--border);">
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Utilisateur</th>
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Email</th>
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Rôle</th>
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Profil lié</th>
                    <th style="text-align:right;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr style="border-bottom:1px solid var(--border);transition:background .15s;"
                    onmouseover="this.style.background='var(--bg-hover)'"
                    onmouseout="this.style.background=''">
                    <td style="padding:16px 20px;">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div class="avatar" style="background:rgba(var(--accent-rgb),.2);color:var(--accent);font-size:11px;font-weight:700;flex-shrink:0;">
                                {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                            </div>
                            <div>
                                <p style="font-weight:500;color:var(--text-1);margin:0;">{{ user.fullName }}</p>
                                {% if user == app.user %}
                                    <span style="font-size:11px;color:var(--accent);">Vous</span>
                                {% endif %}
                            </div>
                        </div>
                    </td>
                    <td style="padding:16px 20px;color:var(--text-2);">{{ user.email }}</td>
                    <td style="padding:16px 20px;">
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span class="badge" style="background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);">
                                <span style="width:6px;height:6px;border-radius:50%;background:#f87171;display:inline-block;margin-right:4px;"></span>
                                Admin
                            </span>
                        {% elseif 'ROLE_COACH' in user.roles %}
                            <span class="badge" style="background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2);">
                                <span style="width:6px;height:6px;border-radius:50%;background:#fbbf24;display:inline-block;margin-right:4px;"></span>
                                Coach
                            </span>
                        {% else %}
                            <span class="badge badge-indigo">
                                <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block;margin-right:4px;"></span>
                                Athlète
                            </span>
                        {% endif %}
                    </td>
                    <td style="padding:16px 20px;">
                        {% if user.linkedAthlete %}
                            <a href="{{ path('app_athlete_show', {id: user.linkedAthlete.id}) }}"
                               style="color:var(--accent);text-decoration:none;transition:opacity .15s;"
                               onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">
                                {{ user.linkedAthlete.fullName }}
                            </a>
                        {% else %}
                            <span style="color:var(--text-3);">—</span>
                        {% endif %}
                    </td>
                    <td style="padding:16px 20px;">
                        <div style="display:flex;align-items:center;justify-content:flex-end;gap:8px;">
                            <a href="{{ path('app_user_edit', {id: user.id}) }}" class="btn btn-secondary btn-sm">
                                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                Modifier
                            </a>
                            {% if user != app.user %}
                            <form action="{{ path('app_user_delete', {id: user.id}) }}" method="post"
                                  x-data
                                  @submit.prevent="if(confirm('Supprimer {{ user.fullName }} ?')) $el.submit()">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-user' ~ user.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Supprimer
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" style="padding:48px 20px;text-align:center;color:var(--text-3);">Aucun utilisateur.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
