{% extends 'base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Utilisateurs</span>
{% endblock %}

{% block body %}
<div>
    <div class="page-header">
        <div>
            <h1 class="section-title">Utilisateurs</h1>
            <p class="section-subtitle">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}</p>
        </div>
    </div>

    {% if users is empty %}
        <div class="card">
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <h3>Aucun utilisateur</h3>
            </div>
        </div>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;" data-stagger>
            {% for user in users %}
                <a href="{{ path('app_user_edit', {id: user.id}) }}"
                   class="card card-hover card-accent-hover"
                   style="display:flex;align-items:center;gap:14px;padding:18px 20px;text-decoration:none;">

                    <div class="tf-avatar avatar-sq" style="width:44px;height:44px;font-size:15px;border-radius:12px;flex-shrink:0;">
                        {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                    </div>

                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                            <span style="font-size:14px;font-weight:700;color:var(--text-1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ user.fullName }}</span>
                            {% if user == app.user %}
                                <span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:999px;background:var(--accent-subtle);color:var(--accent-hover);border:1px solid rgba(99,102,241,.3);flex-shrink:0;">Vous</span>
                            {% endif %}
                        </div>
                        <div style="margin-top:6px;">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);">
                                    <svg width="9" height="9" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                    Admin
                                </span>
                            {% elseif 'ROLE_COACH' in user.roles %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2);">
                                    <svg width="9" height="9" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    Coach
                                </span>
                            {% else %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:var(--accent-subtle);color:var(--accent-hover);border:1px solid rgba(99,102,241,.25);">
                                    <svg width="9" height="9" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                    Athlète
                                </span>
                            {% endif %}
                        </div>
                    </div>

                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
