{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <a href="{{ path('app_user_index') }}" class="hover:text-white transition-colors">Utilisateurs</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-semibold">{{ user.fullName }}</span>
{% endblock %}

{% block body %}
<div class="max-w-xl space-y-6">

    {# Header #}
    <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-xl bg-indigo-600/20 flex items-center justify-center text-indigo-300 font-bold text-xl shrink-0">
            {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
        </div>
        <div>
            <h1 class="text-2xl font-bold text-white">{{ user.fullName }}</h1>
            <p class="text-gray-500 text-sm">{{ user.email }}</p>
        </div>
    </div>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="rounded-xl px-5 py-3 text-sm font-medium
                {% if type == 'success' %}bg-emerald-900/40 border border-emerald-700 text-emerald-300
                {% elseif type == 'error' %}bg-red-900/40 border border-red-700 text-red-300
                {% else %}bg-blue-900/40 border border-blue-700 text-blue-300{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Form #}
    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        {# Identité #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Identité</h2>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.firstName, null, {label_attr: {class: 'block text-sm text-gray-400 mb-1.5'}}) }}
                    {{ form_widget(form.firstName, {attr: {class: 'w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName, null, {label_attr: {class: 'block text-sm text-gray-400 mb-1.5'}}) }}
                    {{ form_widget(form.lastName, {attr: {class: 'w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div>
                {{ form_label(form.email, null, {label_attr: {class: 'block text-sm text-gray-400 mb-1.5'}}) }}
                {{ form_widget(form.email, {attr: {class: 'w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.email) }}
            </div>
        </div>

        {# Rôle #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Rôle</h2>

            {# Select Symfony désactivé — juste pour marquer le champ comme rendu #}
            {{ form_widget(form.roles, {attr: {style: 'display:none', disabled: 'disabled'}}) }}

            <div class="grid grid-cols-3 gap-3"
                 x-data="{ selected: '{{ currentRole }}' }">
                {# Input hidden piloté par Alpine — soumet la vraie valeur #}
                <input type="hidden" name="user_edit[roles]" :value="selected">
                {% for choice in form.roles.vars.choices %}
                <button type="button"
                        @click="selected = '{{ choice.value }}'"
                        :class="selected === '{{ choice.value }}'
                            ? 'border-indigo-500 bg-indigo-600/20 text-white'
                            : 'border-gray-700 text-gray-400 hover:border-gray-600 hover:text-white'"
                        class="border rounded-xl px-4 py-3 text-center text-sm font-medium transition-all cursor-pointer">
                    {% if choice.value == 'ROLE_ADMIN' %}
                        <svg class="w-5 h-5 mx-auto mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    {% elseif choice.value == 'ROLE_COACH' %}
                        <svg class="w-5 h-5 mx-auto mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    {% else %}
                        <svg class="w-5 h-5 mx-auto mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    {% endif %}
                    {{ choice.label }}
                </button>
                {% endfor %}
            </div>

            {% if user == app.user %}
            <p class="text-xs text-amber-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Attention : vous modifiez votre propre compte.
            </p>
            {% endif %}
        </div>

        {# Profil athlète lié #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <div>
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Profil athlète lié</h2>
                <p class="text-xs text-gray-600 mt-1">Associe cet utilisateur à un profil athlète existant.</p>
            </div>
            {{ form_widget(form.linkedAthlete, {attr: {class: 'w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.linkedAthlete) }}
        </div>

        {# Actions #}
        <div class="flex items-center gap-3">
            <button type="submit"
                    class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Enregistrer
            </button>
            <a href="{{ path('app_user_index') }}"
               class="text-sm text-gray-500 hover:text-gray-300 transition-colors px-3 py-2.5">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
