{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <a href="{{ path('app_user_index') }}">Utilisateurs</a>
    <span class="sep">/</span>
    <span class="current">{{ user.fullName }}</span>
{% endblock %}

{% block body %}
<div style="max-width:540px;display:flex;flex-direction:column;gap:24px;">

    {# Header #}
    <div style="display:flex;align-items:center;gap:16px;">
        <div class="avatar avatar-lg" style="background:rgba(var(--accent-rgb),.2);color:var(--accent);font-size:18px;font-weight:700;border-radius:14px;">
            {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
        </div>
        <div>
            <h1 class="section-title">{{ user.fullName }}</h1>
            <p style="color:var(--text-3);font-size:13px;margin:2px 0 0;">{{ user.email }}</p>
        </div>
    </div>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding:12px 16px;border-radius:12px;font-size:13px;font-weight:500;
                {% if type == 'success' %}background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.25);color:#34d399;
                {% elseif type == 'error' %}background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171;
                {% else %}background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);color:#a5b4fc;{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {{ form_start(form) }}

        {# Identité #}
        <div class="card card-body" style="display:flex;flex-direction:column;gap:16px;">
            <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0;">Identité</h2>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    {{ form_label(form.firstName, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.firstName, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.lastName, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div>
                {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.email, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.email) }}
            </div>
        </div>

        {# Rôle #}
        <div class="card card-body" style="display:flex;flex-direction:column;gap:16px;">
            <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0;">Rôle</h2>

            {# Select Symfony désactivé — juste pour marquer le champ comme rendu #}
            {{ form_widget(form.roles, {attr: {style: 'display:none', disabled: 'disabled'}}) }}

            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;"
                 x-data="{ selected: '{{ currentRole }}' }">
                <input type="hidden" name="user_edit[roles]" :value="selected">
                {% for choice in form.roles.vars.choices %}
                <button type="button"
                        @click="selected = '{{ choice.value }}'"
                        :class="selected === '{{ choice.value }}' ? 'active' : ''"
                        style="border-radius:12px;padding:14px 8px;text-align:center;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;background:var(--bg-2);border:1px solid var(--border);color:var(--text-2);"
                        :style="selected === '{{ choice.value }}'
                            ? 'border-color:var(--accent);background:rgba(var(--accent-rgb),.12);color:var(--text-1);'
                            : ''">
                    {% if choice.value == 'ROLE_ADMIN' %}
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:block;margin:0 auto 8px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    {% elseif choice.value == 'ROLE_COACH' %}
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:block;margin:0 auto 8px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    {% else %}
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:block;margin:0 auto 8px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    {% endif %}
                    {{ choice.label }}
                </button>
                {% endfor %}
            </div>

            {% if user == app.user %}
            <p style="font-size:12px;color:#fbbf24;display:flex;align-items:center;gap:6px;margin:0;">
                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Attention : vous modifiez votre propre compte.
            </p>
            {% endif %}
        </div>

        {# Profil athlète lié #}
        <div class="card card-body" style="display:flex;flex-direction:column;gap:12px;">
            <div>
                <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 4px;">Profil athlète lié</h2>
                <p style="font-size:12px;color:var(--text-3);margin:0;">Associe cet utilisateur à un profil athlète existant.</p>
            </div>
            {{ form_widget(form.linkedAthlete, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.linkedAthlete) }}
        </div>

        {# Actions #}
        <div style="display:flex;align-items:center;gap:12px;">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Enregistrer
            </button>
            <a href="{{ path('app_user_index') }}" class="btn btn-ghost">Annuler</a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
