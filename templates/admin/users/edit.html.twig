{% extends 'base.html.twig' %}
{% block title %}Modifier {{ user.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <a href="{{ path('app_user_index') }}">Utilisateurs</a>
    <span class="sep">/</span>
    <span class="current">{{ user.fullName }}</span>
{% endblock %}

{% block body %}
{{ form_start(form) }}
<div style="display:flex;flex-direction:column;gap:24px;">

    {# ── Header ── #}
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <div class="tf-avatar" style="width:56px;height:56px;font-size:20px;border-radius:14px;flex-shrink:0;">
            {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
        </div>
        <div style="flex:1;min-width:0;">
            <h1 style="font-size:22px;font-weight:700;color:var(--text-1);margin:0;line-height:1.2;">{{ user.fullName }}</h1>
            <p style="font-size:13px;color:var(--text-3);margin:4px 0 0;">{{ user.email }}</p>
        </div>
        {% if user == app.user %}
            <span style="font-size:11px;font-weight:600;padding:4px 12px;border-radius:999px;background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.25);flex-shrink:0;">Votre compte</span>
        {% endif %}
        <a href="{{ path('app_user_index') }}" class="btn btn-ghost btn-sm" style="flex-shrink:0;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Retour
        </a>
    </div>

    {# ── Grid principal ── #}
    <div class="user-edit-grid">

        {# ── Colonne gauche ── #}
        <div style="display:flex;flex-direction:column;gap:20px;">

            {# Identité #}
            <div class="card card-body" style="display:flex;flex-direction:column;gap:18px;">
                <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;margin:0;">Identité</h2>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div>
                        {{ form_label(form.firstName, null, {label_attr: {class: 'form-label'}}) }}
                        {{ form_widget(form.firstName, {attr: {class: 'form-input'}}) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                    <div>
                        {{ form_label(form.lastName, null, {label_attr: {class: 'form-label'}}) }}
                        {{ form_widget(form.lastName, {attr: {class: 'form-input'}}) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                </div>
                <div>
                    {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.email, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>

            {# Profil athlète lié #}
            <div class="card card-body" style="display:flex;flex-direction:column;gap:12px;">
                <div>
                    <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;margin:0 0 4px;">Profil athlète lié</h2>
                    <p style="font-size:12px;color:var(--text-3);margin:0;">Associe cet utilisateur à un profil athlète existant.</p>
                </div>
                {{ form_widget(form.linkedAthlete, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.linkedAthlete) }}
            </div>

        </div>

        {# ── Colonne droite — Rôle ── #}
        <div class="card" style="display:flex;flex-direction:column;overflow:hidden;">
            <div style="padding:16px 20px;border-bottom:1px solid var(--border);">
                <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;margin:0;">Rôle</h2>
            </div>

            {{ form_widget(form.roles, {attr: {style: 'display:none', disabled: 'disabled'}}) }}

            <div style="display:flex;flex-direction:column;flex:1;min-height:0;"
                 x-data="{ selected: '{{ currentRole }}' }">
                <input type="hidden" name="user_edit[roles]" :value="selected">

                {% for choice in form.roles.vars.choices %}
                {% if choice.value == 'ROLE_ADMIN' %}
                    {% set rc = {color:'#f87171', bg:'rgba(239,68,68,.07)', bar:'#f87171', desc:'Accès complet à toutes les fonctionnalités'} %}
                {% elseif choice.value == 'ROLE_COACH' %}
                    {% set rc = {color:'#fbbf24', bg:'rgba(251,191,36,.07)', bar:'#fbbf24', desc:'Gestion des athlètes et des séances'} %}
                {% else %}
                    {% set rc = {color:'var(--accent-hover)', bg:'var(--accent-subtle)', bar:'var(--accent)', desc:'Consultation de ses propres données'} %}
                {% endif %}

                <button type="button" @click="selected = '{{ choice.value }}'"
                        :style="selected === '{{ choice.value }}' ? 'background:{{ rc.bg }};' : 'background:transparent;'"
                        style="display:flex;align-items:stretch;gap:0;border:none;cursor:pointer;text-align:left;transition:background .15s;width:100%;flex:1;border-bottom:1px solid var(--border);position:relative;overflow:hidden;">

                    {# barre gauche colorée #}
                    <span style="width:3px;flex-shrink:0;border-radius:0 2px 2px 0;transition:all .15s;"
                          :style="selected === '{{ choice.value }}' ? 'background:{{ rc.bar }};box-shadow:0 0 8px {{ rc.bar }}60;' : 'background:transparent;'"></span>

                    <div style="display:flex;align-items:center;gap:14px;padding:18px 18px;flex:1;min-width:0;">
                        {# icône #}
                        <div style="width:36px;height:36px;border-radius:var(--radius-sm);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;"
                             :style="selected === '{{ choice.value }}' ? 'background:{{ rc.bg }};border:1px solid {{ rc.bar }}50;' : 'background:var(--bg-hover);border:1px solid var(--border);'">
                            {% if choice.value == 'ROLE_ADMIN' %}
                                <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke-width="1.8"
                                     :style="{ stroke: selected === '{{ choice.value }}' ? '{{ rc.color }}' : 'var(--text-3)' }">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                            {% elseif choice.value == 'ROLE_COACH' %}
                                <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke-width="1.8"
                                     :style="{ stroke: selected === '{{ choice.value }}' ? '{{ rc.color }}' : 'var(--text-3)' }">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                            {% else %}
                                <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke-width="1.8"
                                     :style="{ stroke: selected === '{{ choice.value }}' ? '{{ rc.color }}' : 'var(--text-3)' }">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            {% endif %}
                        </div>

                        {# texte #}
                        <div style="flex:1;min-width:0;">
                            <p style="font-size:13px;font-weight:600;margin:0 0 3px;transition:color .15s;"
                               :style="{ color: selected === '{{ choice.value }}' ? '{{ rc.color }}' : 'var(--text-1)' }">{{ choice.label }}</p>
                            <p style="font-size:11px;margin:0;line-height:1.5;color:var(--text-3);">{{ rc.desc }}</p>
                        </div>
                    </div>
                </button>
                {% endfor %}

                {% if user == app.user %}
                <div style="display:flex;align-items:center;gap:8px;padding:10px 16px;background:rgba(251,191,36,.04);border-top:1px solid rgba(251,191,36,.15);margin-top:auto;">
                    <svg width="12" height="12" fill="none" stroke="#fbbf24" viewBox="0 0 24 24" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    <p style="font-size:11px;color:#fbbf24;margin:0;">Vous modifiez votre propre compte.</p>
                </div>
                {% endif %}
            </div>
        </div>

    </div>

    {# ── Actions ── #}
    <div style="display:flex;align-items:center;gap:10px;">
        <button type="submit" class="btn btn-primary">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Enregistrer
        </button>
        <a href="{{ path('app_user_index') }}" class="btn btn-ghost">Annuler</a>
    </div>

</div>
{{ form_end(form) }}

{% endblock %}
