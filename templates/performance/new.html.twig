{% extends 'base.html.twig' %}
{% block title %}Nouvelle performance{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}">{{ athlete.fullName }}</a>
    <span class="sep">/</span>
    <span class="current">Nouvelle performance</span>
{% endblock %}

{% block body %}
<div style="max-width:600px;margin:0 auto;">
    <div style="margin-bottom:24px;">
        <h1 class="section-title">Nouvelle performance</h1>
        <p class="section-subtitle">{{ athlete.fullName }}</p>
    </div>
    <div class="card card-body">
        {{ form_start(form) }}
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.discipline) }}</div>
            <div>{{ form_row(form.recordedAt) }}</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.value) }}</div>
            <div>{{ form_row(form.unit) }}</div>
        </div>
        <div style="display:flex;gap:24px;">
            <div>{{ form_row(form.isPersonalBest) }}</div>
            <div>{{ form_row(form.isCompetition) }}</div>
        </div>
        {{ form_row(form.notes) }}
        <div style="display:flex;gap:10px;padding-top:8px;">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="btn btn-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
