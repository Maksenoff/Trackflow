{% extends 'base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Utilisateurs</span>
{% endblock %}

{% block body %}
<div>
    <div class="page-header">
        <div>
            <h1 class="section-title">Utilisateurs</h1>
            <p class="section-subtitle">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}</p>
        </div>
    </div>

    {% if users is empty %}
        <div class="card">
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <h3>Aucun utilisateur</h3>
            </div>
        </div>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;" data-stagger>
            {% for user in users %}
            <div class="card" style="overflow:hidden;"
                 x-data="{ showRole: false, showLink: false }">

                {# Header carte #}
                <div style="display:flex;align-items:center;gap:14px;padding:18px 20px 14px;">
                    <div class="tf-avatar" style="width:44px;height:44px;font-size:15px;border-radius:12px;flex-shrink:0;">
                        {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                    </div>
                    <div style="flex:1;min-width:0;">
                        <p style="font-size:14px;font-weight:700;color:var(--text-1);margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ user.fullName }}</p>
                        <p style="font-size:12px;color:var(--text-3);margin:2px 0 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ user.email }}</p>
                    </div>
                </div>

                {# Séparateur #}
                <div style="height:1px;background:var(--border);margin:0 20px;"></div>

                {# Rôle #}
                <div style="padding:12px 20px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;font-weight:500;">Rôle</span>
                            {% set roles = user.roles %}
                            {% if 'ROLE_ADMIN' in roles %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);">Admin</span>
                            {% elseif 'ROLE_COACH' in roles %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2);">Coach</span>
                            {% else %}
                                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:var(--accent-subtle);color:var(--accent-hover);border:1px solid rgba(99,102,241,.25);">Athlète</span>
                            {% endif %}
                        </div>
                        <button @click="showRole = !showRole; showLink = false" class="btn-icon-subtle" :class="showRole ? 'active' : ''">
                            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </button>
                    </div>

                    <div x-show="showRole" x-transition.duration.150ms style="margin-top:10px;">
                        <form action="{{ path('app_user_change_role', {id: user.id}) }}" method="post"
                              style="display:flex;gap:8px;align-items:center;">
                            <input type="hidden" name="_token" value="{{ csrf_token('role-user' ~ user.id) }}">
                            <select name="role" class="form-input" style="flex:1;font-size:12px;padding:7px 10px;">
                                <option value="ROLE_ATHLETE" {% if 'ROLE_ADMIN' not in roles and 'ROLE_COACH' not in roles %}selected{% endif %}>Athlète</option>
                                <option value="ROLE_COACH" {% if 'ROLE_COACH' in roles and 'ROLE_ADMIN' not in roles %}selected{% endif %}>Coach</option>
                                <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in roles %}selected{% endif %}>Admin</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">OK</button>
                            <button type="button" @click="showRole = false" class="btn btn-ghost btn-sm">✕</button>
                        </form>
                    </div>
                </div>

                {# Profil lié #}
                <div style="padding:0 20px 16px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                        <div style="display:flex;align-items:center;gap:8px;min-width:0;">
                            <span style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;font-weight:500;flex-shrink:0;">Profil</span>
                            {% if user.linkedAthlete %}
                                <a href="{{ path('app_athlete_show', {id: user.linkedAthlete.id}) }}"
                                   style="font-size:12px;font-weight:500;color:var(--accent-hover);text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:opacity .15s;"
                                   onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">
                                    {{ user.linkedAthlete.fullName }}
                                </a>
                            {% else %}
                                <span style="font-size:12px;color:var(--text-3);">Non lié</span>
                            {% endif %}
                        </div>
                        <button @click="showLink = !showLink; showRole = false" class="btn-icon-subtle" :class="showLink ? 'active' : ''">
                            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </button>
                    </div>

                    <div x-show="showLink" x-transition.duration.150ms style="margin-top:10px;">
                        <form action="{{ path('app_user_link_athlete', {id: user.id}) }}" method="post"
                              style="display:flex;gap:8px;align-items:center;">
                            <input type="hidden" name="_token" value="{{ csrf_token('link-user' ~ user.id) }}">
                            <select name="athlete_id" class="form-input" style="flex:1;font-size:12px;padding:7px 10px;">
                                <option value="">— Aucun —</option>
                                {% for athlete in athletes %}
                                    <option value="{{ athlete.id }}" {% if user.linkedAthlete and user.linkedAthlete.id == athlete.id %}selected{% endif %}>
                                        {{ athlete.fullName }}
                                    </option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">OK</button>
                            <button type="button" @click="showLink = false" class="btn btn-ghost btn-sm">✕</button>
                        </form>
                    </div>
                </div>

            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
