{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">Utilisateurs</span>
{% endblock %}

{% block body %}
<div class="space-y-6">

    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Utilisateurs</h1>
            <p class="text-sm text-gray-400 mt-1">Gérer les comptes et les liens avec les profils athlètes.</p>
        </div>
        <span class="text-sm text-gray-500">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }}</span>
    </div>

    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="px-4 py-3 rounded-xl text-sm font-medium
                {% if label == 'success' %}bg-emerald-900/40 border border-emerald-700/50 text-emerald-300
                {% elseif label == 'error' %}bg-red-900/40 border border-red-700/50 text-red-300
                {% else %}bg-indigo-900/40 border border-indigo-700/50 text-indigo-300{% endif %}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-800">
                    <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Utilisateur</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Rôle</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Profil athlète lié</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for user in users %}
                    <tr class="hover:bg-gray-800/40 transition-colors" x-data="{ showLink: false, showRole: false }">
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-indigo-600/30 rounded-full flex items-center justify-center text-xs font-bold text-indigo-300 shrink-0">
                                    {{ user.firstName|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <p class="font-medium text-white">{{ user.fullName }}</p>
                                    <p class="text-xs text-gray-500">{{ user.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-2">
                                {% set roles = user.roles %}
                                {% if 'ROLE_ADMIN' in roles %}
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-red-900/30 text-red-400 border border-red-800/50 font-medium">Admin</span>
                                {% elseif 'ROLE_COACH' in roles %}
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-900/30 text-indigo-400 border border-indigo-800/50 font-medium">Coach</span>
                                {% else %}
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400 border border-gray-700 font-medium">Athlète</span>
                                {% endif %}
                                <button @click="showRole = !showRole" class="text-gray-600 hover:text-gray-400 transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </button>
                            </div>
                            <div x-show="showRole" x-transition class="mt-2">
                                <form action="{{ path('app_user_change_role', {id: user.id}) }}" method="post" class="flex items-center gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('role-user' ~ user.id) }}">
                                    <select name="role" class="bg-gray-800 border border-gray-700 text-white text-xs rounded-lg px-2 py-1.5 focus:outline-none focus:border-indigo-500">
                                        <option value="ROLE_ATHLETE" {% if 'ROLE_ADMIN' not in roles and 'ROLE_COACH' not in roles %}selected{% endif %}>Athlète</option>
                                        <option value="ROLE_COACH" {% if 'ROLE_COACH' in roles and 'ROLE_ADMIN' not in roles %}selected{% endif %}>Coach</option>
                                        <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in roles %}selected{% endif %}>Admin</option>
                                    </select>
                                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-2.5 py-1.5 rounded-lg text-xs font-medium transition-colors">OK</button>
                                    <button type="button" @click="showRole = false" class="text-gray-500 hover:text-gray-300 px-2 py-1.5 text-xs">Annuler</button>
                                </form>
                            </div>
                        </td>
                        <td class="px-5 py-4">
                            {% if user.linkedAthlete %}
                                <div class="flex items-center gap-2">
                                    <a href="{{ path('app_athlete_show', {id: user.linkedAthlete.id}) }}"
                                       class="text-indigo-400 hover:text-indigo-300 font-medium transition-colors">
                                        {{ user.linkedAthlete.fullName }}
                                    </a>
                                    <button @click="showLink = !showLink" class="text-gray-600 hover:text-gray-400 transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </button>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-2">
                                    <span class="text-gray-600 text-xs italic">Aucun profil lié</span>
                                    <button @click="showLink = !showLink"
                                            class="text-xs text-indigo-400 hover:text-indigo-300 font-medium transition-colors">
                                        + Lier
                                    </button>
                                </div>
                            {% endif %}
                            <div x-show="showLink" x-transition class="mt-2">
                                <form action="{{ path('app_user_link_athlete', {id: user.id}) }}" method="post" class="flex items-center gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('link-user' ~ user.id) }}">
                                    <select name="athlete_id" class="bg-gray-800 border border-gray-700 text-white text-xs rounded-lg px-2 py-1.5 focus:outline-none focus:border-indigo-500">
                                        <option value="">— Aucun (dissocier) —</option>
                                        {% for athlete in athletes %}
                                            <option value="{{ athlete.id }}" {% if user.linkedAthlete and user.linkedAthlete.id == athlete.id %}selected{% endif %}>
                                                {{ athlete.fullName }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-2.5 py-1.5 rounded-lg text-xs font-medium transition-colors">OK</button>
                                    <button type="button" @click="showLink = false" class="text-gray-500 hover:text-gray-300 px-2 py-1.5 text-xs">Annuler</button>
                                </form>
                            </div>
                        </td>
                        <td class="px-5 py-4 text-right">
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-5 py-12 text-center text-gray-500">Aucun utilisateur.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
