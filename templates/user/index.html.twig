{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Utilisateurs</span>
{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;gap:24px;">

    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;">
        <div>
            <h1 class="section-title">Utilisateurs</h1>
            <p class="section-subtitle">Gérer les comptes et les liens avec les profils athlètes.</p>
        </div>
        <span class="badge badge-indigo">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }}</span>
    </div>

    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div style="padding:12px 16px;border-radius:12px;font-size:13px;font-weight:500;
                {% if label == 'success' %}background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.25);color:#34d399;
                {% elseif label == 'error' %}background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171;
                {% else %}background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);color:#a5b4fc;{% endif %}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card" style="overflow:hidden">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead>
                <tr style="border-bottom:1px solid var(--border);">
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Utilisateur</th>
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Rôle</th>
                    <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;">Profil athlète lié</th>
                    <th style="padding:12px 20px;"></th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr style="border-bottom:1px solid var(--border);transition:background .15s;"
                        x-data="{ showLink: false, showRole: false }"
                        onmouseover="this.style.background='var(--bg-hover)'"
                        onmouseout="this.style.background='transparent'">
                        <td style="padding:16px 20px;">
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="avatar" style="background:rgba(var(--accent-rgb),.2);color:var(--accent);font-size:12px;font-weight:700;">
                                    {{ user.firstName|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <p style="font-weight:500;color:var(--text-1);margin:0;">{{ user.fullName }}</p>
                                    <p style="font-size:12px;color:var(--text-3);margin:2px 0 0;">{{ user.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td style="padding:16px 20px;">
                            <div style="display:flex;align-items:center;gap:8px;">
                                {% set roles = user.roles %}
                                {% if 'ROLE_ADMIN' in roles %}
                                    <span class="badge" style="background:rgba(239,68,68,.12);color:#f87171;border:1px solid rgba(239,68,68,.25);">Admin</span>
                                {% elseif 'ROLE_COACH' in roles %}
                                    <span class="badge badge-indigo">Coach</span>
                                {% else %}
                                    <span class="badge">Athlète</span>
                                {% endif %}
                                <button @click="showRole = !showRole"
                                        style="background:none;border:none;padding:4px;cursor:pointer;color:var(--text-3);border-radius:6px;transition:color .15s;"
                                        onmouseover="this.style.color='var(--text-2)'"
                                        onmouseout="this.style.color='var(--text-3)'">
                                    <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </button>
                            </div>
                            <div x-show="showRole" x-transition style="margin-top:8px;display:none;">
                                <form action="{{ path('app_user_change_role', {id: user.id}) }}" method="post"
                                      style="display:flex;align-items:center;gap:8px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('role-user' ~ user.id) }}">
                                    <select name="role" class="form-input" style="font-size:12px;padding:6px 10px;">
                                        <option value="ROLE_ATHLETE" {% if 'ROLE_ADMIN' not in roles and 'ROLE_COACH' not in roles %}selected{% endif %}>Athlète</option>
                                        <option value="ROLE_COACH" {% if 'ROLE_COACH' in roles and 'ROLE_ADMIN' not in roles %}selected{% endif %}>Coach</option>
                                        <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in roles %}selected{% endif %}>Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">OK</button>
                                    <button type="button" @click="showRole = false" class="btn btn-ghost btn-sm">Annuler</button>
                                </form>
                            </div>
                        </td>
                        <td style="padding:16px 20px;">
                            {% if user.linkedAthlete %}
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <a href="{{ path('app_athlete_show', {id: user.linkedAthlete.id}) }}"
                                       style="color:var(--accent);font-weight:500;text-decoration:none;font-size:13px;transition:color .15s;"
                                       onmouseover="this.style.opacity='.8'"
                                       onmouseout="this.style.opacity='1'">
                                        {{ user.linkedAthlete.fullName }}
                                    </a>
                                    <button @click="showLink = !showLink"
                                            style="background:none;border:none;padding:4px;cursor:pointer;color:var(--text-3);border-radius:6px;transition:color .15s;"
                                            onmouseover="this.style.color='var(--text-2)'"
                                            onmouseout="this.style.color='var(--text-3)'">
                                        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </button>
                                </div>
                            {% else %}
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <span style="font-size:12px;color:var(--text-3);font-style:italic;">Aucun profil lié</span>
                                    <button @click="showLink = !showLink"
                                            style="background:none;border:none;padding:0;cursor:pointer;font-size:12px;color:var(--accent);font-weight:500;transition:opacity .15s;"
                                            onmouseover="this.style.opacity='.7'"
                                            onmouseout="this.style.opacity='1'">
                                        + Lier
                                    </button>
                                </div>
                            {% endif %}
                            <div x-show="showLink" x-transition style="margin-top:8px;display:none;">
                                <form action="{{ path('app_user_link_athlete', {id: user.id}) }}" method="post"
                                      style="display:flex;align-items:center;gap:8px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('link-user' ~ user.id) }}">
                                    <select name="athlete_id" class="form-input" style="font-size:12px;padding:6px 10px;">
                                        <option value="">— Aucun (dissocier) —</option>
                                        {% for athlete in athletes %}
                                            <option value="{{ athlete.id }}" {% if user.linkedAthlete and user.linkedAthlete.id == athlete.id %}selected{% endif %}>
                                                {{ athlete.fullName }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">OK</button>
                                    <button type="button" @click="showLink = false" class="btn btn-ghost btn-sm">Annuler</button>
                                </form>
                            </div>
                        </td>
                        <td style="padding:16px 20px;text-align:right;"></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="padding:48px 20px;text-align:center;color:var(--text-3);">Aucun utilisateur.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
