{% extends 'base.html.twig' %}
{% block title %}Calendrier{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">Calendrier</span>
{% endblock %}

{% block body %}
<div id="cal-root" class="space-y-5"
     x-data="{
        dayModal: false,
        dayDate: '',
        daySessions: [],
        openDay(dateStr, sessions) {
            this.dayDate = dateStr;
            this.daySessions = sessions;
            this.dayModal = true;
        },

     }">

    {# ── Header ── #}
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white capitalize">{{ monthName }}</h1>
            {% set total = 0 %}{% for d, s in byDay %}{% set total = total + s|length %}{% endfor %}
            <p class="text-gray-400 mt-1">{{ total }} séance{% if total > 1 %}s{% endif %} programmée{% if total > 1 %}s{% endif %}</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}"
               data-nav-date="{{ prevYear }}-{{ '%02d'|format(prevMonth) }}-01"
               data-nav-url="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}"
               class="flex items-center gap-1 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Précédent
            </a>
            {% if month != currentMonth or year != currentYear %}
                <a href="{{ path('app_calendar') }}" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    Aujourd'hui
                </a>
            {% endif %}
            <a href="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}"
               data-nav-date="{{ nextYear }}-{{ '%02d'|format(nextMonth) }}-01"
               data-nav-url="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}"
               class="flex items-center gap-1 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                Suivant
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="{{ path('app_session_new') }}"
               class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors ml-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nouvelle séance
            </a>
        </div>
    </div>

    {# ── Légende ── #}
    {% if trainingTypes is not empty %}
    <div class="flex flex-wrap gap-2 items-center">
        {% for tt in trainingTypes %}
            <span class="flex items-center gap-1.5 bg-gray-900 border border-gray-800 px-2.5 py-1 rounded-lg text-xs text-gray-400">
                <span class="w-2 h-2 rounded-full shrink-0" style="background: {{ tt.color }}"></span>
                {{ tt.name }}
            </span>
        {% endfor %}
        <a href="{{ path('app_training_type_index') }}"
           class="flex items-center gap-1 text-xs text-gray-600 hover:text-indigo-400 transition-colors ml-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Gérer
        </a>
    </div>
    {% else %}
    <div class="text-xs text-gray-500">
        Aucun type configuré —
        <a href="{{ path('app_training_type_index') }}" class="text-indigo-400 hover:text-indigo-300">Créer des types</a>
    </div>
    {% endif %}

    {# ── Grille calendrier ── #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden select-none">

        {# En-têtes jours #}
        <div class="grid grid-cols-7 border-b border-gray-800 rounded-t-xl overflow-hidden">
            {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                <div class="py-3 text-center text-xs font-semibold uppercase tracking-wide
                    {% if day in ['Sam', 'Dim'] %}text-gray-600{% else %}text-gray-500{% endif %}">{{ day }}</div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-7 auto-rows-fr">

            {# Cases vides en début #}
            {% for i in 1..(firstWeekday - 1) %}
                <div class="min-h-28 border-b border-r border-gray-800/40 bg-gray-950/40"></div>
            {% endfor %}

            {# Cases jours #}
            {% set isCurrentMonthView = month == currentMonth and year == currentYear %}
            {% set todayWeekRow = isCurrentMonthView ? ((today + firstWeekday - 2) // 7) : -1 %}

            {% for day in 1..daysInMonth %}
                {% set col = ((day + firstWeekday - 2) % 7) + 1 %}
                {% set isWeekend = col >= 6 %}
                {% set isToday = day == today and isCurrentMonthView %}
                {% set dayWeekRow = (day + firstWeekday - 2) // 7 %}
                {% set isCurrentWeek = isCurrentMonthView and dayWeekRow == todayWeekRow %}
                {% set daySessions = byDay[day] ?? [] %}
                {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}

                {% set allSessData = [] %}
                {% for s in daySessions %}
                    {% set allSessData = allSessData|merge([{
                        id: s.id,
                        title: s.title,
                        typeLabel: s.typeLabel,
                        color: s.colorBg,
                        duration: s.durationMinutes,
                        showUrl: path('app_session_show', {id: s.id}),
                    }]) %}
                {% endfor %}

                <div class="min-h-28 border-b border-r border-gray-800/40 p-1.5 group transition-colors relative
                    {% if isToday %}bg-indigo-950/30
                    {% elseif isCurrentWeek %}bg-gray-800/60
                    {% elseif isWeekend %}bg-gray-950/50
                    {% else %}bg-gray-900{% endif %}"
                     data-date="{{ dateStr }}">

                    {# Numéro + bouton ajout rapide #}
                    <div class="flex items-start justify-between mb-1">
                        <span @click="{{ allSessData|length > 0 ? 'openDay(\'' ~ '%02d'|format(day) ~ '/' ~ '%02d'|format(month) ~ '/' ~ year ~ '\', ' ~ allSessData|json_encode ~ ')' : '' }}"
                              class="w-7 h-7 flex items-center justify-center rounded-full text-sm font-medium transition-colors
                                  {% if isToday %}bg-indigo-600 text-white font-bold ring-2 ring-indigo-400/50 ring-offset-1 ring-offset-transparent
                                  {% elseif isCurrentWeek %}text-gray-300 font-medium
                                  {% elseif isWeekend %}text-gray-600
                                  {% else %}text-gray-400 group-hover:text-white{% endif %}
                                  {{ allSessData|length > 0 ? 'cursor-pointer hover:ring-2 hover:ring-indigo-500/50' : '' }}">
                            {{ day }}
                        </span>
                        <a href="{{ path('app_session_new') }}?date={{ dateStr }}"
                           class="opacity-0 group-hover:opacity-100 w-5 h-5 flex items-center justify-center rounded text-gray-500 hover:text-indigo-400 hover:bg-gray-700 transition-all">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                        </a>
                    </div>

                    {# Pastilles séances — drag & drop + hover tooltip + clic → fiche #}
                    <div data-sessions>
                        {% for s in daySessions|slice(0, 3) %}
                            <div class="relative group/pill mb-0.5 cursor-grab active:cursor-grabbing"
                                 draggable="true"
                                 data-session-id="{{ s.id }}">
                                <a href="{{ path('app_session_show', {id: s.id}) }}"
                                   draggable="false"
                                   class="flex items-center gap-1 px-1.5 py-0.5 rounded text-xs truncate
                                          hover:brightness-125 transition-all block"
                                   style="background: {{ s.colorBg }}22; border-left: 2px solid {{ s.colorBg }}">
                                    <span class="truncate font-medium text-white/90 leading-tight">{{ s.title }}</span>
                                </a>

                                {# Tooltip au survol #}
                                <div class="absolute bottom-full {% if col >= 5 %}right-0{% else %}left-0{% endif %} mb-1.5 z-50 w-52 pointer-events-none
                                            opacity-0 group-hover/pill:opacity-100 transition-opacity duration-150
                                            bg-gray-800 border border-gray-700 rounded-xl shadow-2xl overflow-hidden">
                                    <div class="h-1 shrink-0" style="background: {{ s.colorBg }}"></div>
                                    <div class="p-3">
                                        {% if s.typeLabel %}
                                            <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-1.5"
                                                  style="background: {{ s.colorBg }}25; color: {{ s.colorBg }}; border: 1px solid {{ s.colorBg }}40">
                                                {{ s.typeLabel }}
                                            </span>
                                        {% endif %}
                                        <p class="text-sm font-semibold text-white leading-tight">{{ s.title }}</p>
                                        <div class="flex items-center gap-2 mt-1.5 text-xs text-gray-400">
                                            {% if s.durationMinutes %}
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                    {{ s.durationMinutes }} min
                                                </span>
                                            {% endif %}
                                            {% set fc = s.athleteSessions|length %}
                                            {% if fc > 0 %}
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                                    {{ fc }} ressenti{% if fc > 1 %}s{% endif %}
                                                </span>
                                            {% endif %}
                                        </div>
                                        {% if s.description %}
                                            <p class="text-xs text-gray-400 mt-1.5 italic leading-relaxed line-clamp-2">{{ s.description }}</p>
                                        {% endif %}
                                        <p class="text-xs text-indigo-400 mt-2 font-medium">Cliquer pour voir la fiche →</p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% if daySessions|length > 3 %}
                        <p class="text-xs text-gray-500 px-1 cursor-pointer hover:text-gray-300"
                           @click.stop="openDay('{{ '%02d'|format(day) }}/{{ '%02d'|format(month) }}/{{ year }}', {{ allSessData|json_encode }})">
                            +{{ daySessions|length - 3 }} autres
                        </p>
                    {% endif %}
                </div>
            {% endfor %}

            {# Cases vides en fin #}
            {% set lastCol = ((daysInMonth + firstWeekday - 2) % 7) + 1 %}
            {% if lastCol < 7 %}
                {% for i in (lastCol + 1)..7 %}
                    <div class="min-h-28 border-b border-r border-gray-800/40 bg-gray-950/40"></div>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# ── Navigation bas de page ── #}
    <div class="flex items-center justify-between">
        <a href="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}"
           data-nav-date="{{ prevYear }}-{{ '%02d'|format(prevMonth) }}-01"
           data-nav-url="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}"
           class="flex items-center gap-1 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Précédent
        </a>
        <a href="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}"
           data-nav-date="{{ nextYear }}-{{ '%02d'|format(nextMonth) }}-01"
           data-nav-url="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}"
           class="flex items-center gap-1 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
            Suivant
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>

    {# ═══════════════════════════════════════
       Modal VUE JOUR (clic numéro ou "+N autres")
       ═══════════════════════════════════════ #}
    <div x-show="dayModal"
         x-transition:enter="ease-out duration-150" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-100" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50"
         @click.self="dayModal = false"
         style="display:none">

        <div class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-md shadow-2xl overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
                <h3 class="font-semibold text-white" x-text="'Séances du ' + dayDate"></h3>
                <button @click="dayModal = false" class="text-gray-500 hover:text-white p-1 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="px-5 py-4 space-y-2 max-h-80 overflow-y-auto">
                <template x-for="s in daySessions" :key="s.id">
                    <a :href="s.showUrl"
                       class="flex items-center gap-3 bg-gray-800 rounded-xl px-4 py-3 hover:bg-gray-750 transition-colors">
                        <div class="w-1 h-10 rounded-full shrink-0" :style="'background:' + s.color"></div>
                        <div class="flex-1 min-w-0">
                            <p class="font-medium text-white text-sm truncate" x-text="s.title"></p>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span class="text-xs" :style="'color:' + s.color" x-text="s.typeLabel"></span>
                                <span x-show="s.duration" class="text-xs text-gray-500" x-text="s.duration + ' min'"></span>
                            </div>
                        </div>
                        <svg class="w-4 h-4 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </template>
            </div>
            <div class="px-5 py-4 border-t border-gray-800">
                <a :href="'/sessions/new?date=' + dayDate.split('/').reverse().join('-')"
                   class="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Ajouter une séance ce jour
                </a>
            </div>
        </div>
    </div>

</div>

<script>
(function () {
    /* Drag & drop intra-mois uniquement.
       Pour changer de mois : modifier la séance directement. */
    var dragging = null;
    var lastCell = null;

    function clearHL() {
        if (lastCell) { lastCell.style.outline = lastCell.style.outlineOffset = ''; lastCell = null; }
    }

    document.addEventListener('dragstart', function(e) {
        var pill = e.target.closest('[data-session-id]');
        if (!pill) return;
        dragging = {id: pill.dataset.sessionId, el: pill};
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', dragging.id);
        setTimeout(function() { if (dragging) dragging.el.style.opacity = '0.4'; }, 0);
    });

    document.addEventListener('dragend', function() {
        if (dragging) dragging.el.style.opacity = '';
        dragging = null;
        clearHL();
    });

    document.addEventListener('dragover', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        if (lastCell !== cell) {
            clearHL();
            cell.style.outline = '2px solid rgba(99,102,241,0.6)';
            cell.style.outlineOffset = '-2px';
            lastCell = cell;
        }
    });

    document.addEventListener('drop', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        var id = dragging.id, el = dragging.el;
        dragging = null; clearHL();
        el.style.opacity = '';
        var cont = cell.querySelector('[data-sessions]');
        if (cont) cont.appendChild(el);
        fetch('/sessions/' + id + '/reschedule', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({date: cell.dataset.date})
        }).then(function(r) { if (!r.ok) location.reload(); }).catch(location.reload);
    });
}());
</script>
{% endblock %}
