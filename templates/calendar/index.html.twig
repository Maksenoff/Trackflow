{% extends 'base.html.twig' %}
{% block title %}Calendrier{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Calendrier</span>
{% endblock %}

{% block body %}

{# ── Données du mois pour Alpine ── #}
{% set allDaysData = {} %}
{% for day in 1..daysInMonth %}
    {% set daySessions = byDay[day] ?? [] %}
    {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}
    {% set sessData = [] %}
    {% for s in daySessions %}
        {% set sessData = sessData|merge([{
            id: s.id,
            title: s.title,
            typeLabel: s.typeLabel,
            color: s.colorBg,
            duration: s.durationMinutes,
            showUrl: path('app_session_show', {id: s.id}),
        }]) %}
    {% endfor %}
    {% set allDaysData = allDaysData|merge({(day): {dateStr: dateStr, dayLabel: '%02d'|format(day) ~ '/' ~ '%02d'|format(month) ~ '/' ~ year, sessions: sessData}}) %}
{% endfor %}

<style>
    /* ── Vue mobile du calendrier ── */
    @media (max-width: 767px) {
        /* Cellules compactes */
        .cal-cell { min-height: 48px !important; padding: 4px !important; cursor: pointer; }
        .cal-cell-empty { min-height: 48px !important; }
        /* Cacher les pastilles texte et tooltip desktop */
        .cal-pills { display: none !important; }
        .cal-overflow { display: none !important; }
        .cal-add-btn { display: none !important; }
        /* Afficher les dots mobiles */
        .cal-dots { display: flex !important; }
        /* Panneau jour mobile visible */
        #mobile-day-panel { display: block !important; }
        /* Cacher la navigation bas de page */
        .cal-bottom-nav { display: none; }
    }
    @media (min-width: 768px) {
        /* Desktop : cacher les dots, montrer panneau desktop */
        .cal-dots { display: none !important; }
        #mobile-day-panel { display: none !important; }
    }
    /* Cellule sélectionnée sur mobile */
    .cal-cell.cal-selected { outline: 2px solid rgba(99,102,241,0.8); outline-offset: -2px; }
    /* Tooltip hover sur desktop */
    @media(min-width:768px){
        .cal-pill-wrap:hover .cal-tooltip { opacity: 1 !important; }
        .cal-cell:hover .cal-add-btn { opacity: 1 !important; }
    }
</style>

<div id="cal-root" style="display:flex;flex-direction:column;gap:20px;"
     x-data="{
        /* ── Desktop modal ── */
        dayModal: false,
        dayDate: '',
        daySessions: [],
        openDay(dayLabel, sessions) {
            this.dayDate = dayLabel;
            this.daySessions = sessions;
            this.dayModal = true;
        },

        /* ── Mobile panel ── */
        panelDay: '',
        panelDateStr: '',
        panelSessions: [],
        activeDay: null,

        selectDay(day, dayLabel, dateStr, sessions, el) {
            // Desktop overflow click → modal
            if (window.innerWidth >= 768) {
                if (sessions.length > 0) this.openDay(dayLabel, sessions);
                return;
            }
            // Mobile → panneau
            this.activeDay = day;
            this.panelDay = dayLabel;
            this.panelDateStr = dateStr;
            this.panelSessions = sessions;
            // Remove previous highlight
            document.querySelectorAll('.cal-cell.cal-selected').forEach(c => c.classList.remove('cal-selected'));
            if (el) el.classList.add('cal-selected');
            // Scroll to panel
            this.$nextTick(() => {
                var p = document.getElementById('mobile-day-panel');
                if (p) p.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
        },
     }"
     x-init="
        // Sur mobile : sélectionner aujourd'hui par défaut
        if (window.innerWidth < 768) {
            var todayCell = document.querySelector('[data-today]');
            if (todayCell) {
                var d = todayCell.dataset;
                selectDay(parseInt(d.day), d.dayLabel, d.dateStr, JSON.parse(d.sessions), todayCell);
            }
        }
     ">

    {# ── Header ── #}
    <div style="display:flex;flex-direction:column;gap:12px;" class="sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="section-title" style="text-transform:capitalize">{{ monthName }}</h1>
            {% set total = 0 %}{% for d, s in byDay %}{% set total = total + s|length %}{% endfor %}
            <p class="section-subtitle">{{ total }} séance{% if total > 1 %}s{% endif %} programmée{% if total > 1 %}s{% endif %}</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
            <a href="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}" class="btn btn-secondary btn-sm">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Précédent
            </a>
            {% if month != currentMonth or year != currentYear %}
                <a href="{{ path('app_calendar') }}" class="btn btn-secondary btn-sm">Aujourd'hui</a>
            {% endif %}
            <a href="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}" class="btn btn-secondary btn-sm">
                Suivant
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="{{ path('app_session_new') }}" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nouvelle séance
            </a>
        </div>
    </div>

    {# ── Légende ── #}
    {% if trainingTypes is not empty %}
    <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
        {% for tt in trainingTypes %}
            <span style="display:flex;align-items:center;gap:6px;background:var(--bg-2);border:1px solid var(--border);padding:4px 10px;border-radius:8px;font-size:12px;color:var(--text-2);">
                <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:{{ tt.color }}"></span>
                {{ tt.name }}
            </span>
        {% endfor %}
        <a href="{{ path('app_training_type_index') }}" style="display:flex;align-items:center;gap:4px;font-size:12px;color:var(--text-3);text-decoration:none;margin-left:4px;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-3)'">
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Gérer
        </a>
    </div>
    {% else %}
    <div style="font-size:12px;color:var(--text-3);">
        Aucun type configuré —
        <a href="{{ path('app_training_type_index') }}" style="color:var(--accent);text-decoration:none;">Créer des types</a>
    </div>
    {% endif %}

    {# ── Grille calendrier ── #}
    <div class="card" style="overflow:hidden;user-select:none;">

        {# En-têtes jours — abréviations courtes sur mobile #}
        <div class="grid grid-cols-7" style="border-bottom:1px solid var(--border);">
            {% for day in [['Lun','L'], ['Mar','M'], ['Mer','M'], ['Jeu','J'], ['Ven','V'], ['Sam','S'], ['Dim','D']] %}
                <div style="padding:8px 4px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:{{ day[0] in ['Sam', 'Dim'] ? 'var(--text-3)' : 'var(--text-2)' }};">
                    <span class="hidden sm:inline">{{ day[0] }}</span>
                    <span class="sm:hidden">{{ day[1] }}</span>
                </div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-7 auto-rows-fr">

            {# Cases vides début #}
            {% for i in 1..(firstWeekday - 1) %}
                <div class="cal-cell-empty min-h-28" style="border-bottom:1px solid var(--border);border-right:1px solid var(--border);background:var(--bg);opacity:.5;"></div>
            {% endfor %}

            {# Cases jours #}
            {% set isCurrentMonthView = month == currentMonth and year == currentYear %}
            {% set todayWeekRow = isCurrentMonthView ? ((today + firstWeekday - 2) // 7) : -1 %}

            {% for day in 1..daysInMonth %}
                {% set col = ((day + firstWeekday - 2) % 7) + 1 %}
                {% set isWeekend = col >= 6 %}
                {% set isToday = day == today and isCurrentMonthView %}
                {% set dayWeekRow = (day + firstWeekday - 2) // 7 %}
                {% set isCurrentWeek = isCurrentMonthView and dayWeekRow == todayWeekRow %}
                {% set daySessions = byDay[day] ?? [] %}
                {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}
                {% set dayLabel = '%02d'|format(day) ~ '/' ~ '%02d'|format(month) ~ '/' ~ year %}

                {% set allSessData = [] %}
                {% for s in daySessions %}
                    {% set allSessData = allSessData|merge([{
                        id: s.id,
                        title: s.title,
                        typeLabel: s.typeLabel,
                        color: s.colorBg,
                        duration: s.durationMinutes,
                        showUrl: path('app_session_show', {id: s.id}),
                    }]) %}
                {% endfor %}

                <div class="cal-cell min-h-28 group relative"
                     style="border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:6px;transition:background .15s;
                     background:{% if isToday %}rgba(var(--accent-rgb),.08){% elseif isCurrentWeek %}var(--bg-hover){% elseif isWeekend %}var(--bg){% else %}var(--bg-2){% endif %};"
                     data-date="{{ dateStr }}"
                     data-day="{{ day }}"
                     data-day-label="{{ dayLabel }}"
                     data-sessions="{{ allSessData|json_encode|e('html_attr') }}"
                     {% if isToday %}data-today{% endif %}
                     @click="selectDay({{ day }}, '{{ dayLabel }}', '{{ dateStr }}', {{ allSessData|json_encode }}, $el)">

                    {# Numéro du jour #}
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:4px;">
                        <span style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:13px;font-weight:500;transition:all .15s;
                            {% if isToday %}background:var(--accent);color:#fff;font-weight:700;box-shadow:0 0 0 3px rgba(var(--accent-rgb),.25);
                            {% elseif isCurrentWeek %}color:var(--text-1);
                            {% elseif isWeekend %}color:var(--text-3);
                            {% else %}color:var(--text-2);{% endif %}">
                            {{ day }}
                        </span>
                        {# Bouton ajout rapide — desktop uniquement #}
                        <a href="{{ path('app_session_new') }}?date={{ dateStr }}"
                           @click.stop
                           class="cal-add-btn"
                           style="opacity:0;width:20px;height:20px;display:flex;align-items:center;justify-content:center;border-radius:6px;color:var(--text-3);text-decoration:none;transition:all .15s;"
                           onmouseover="this.style.color='var(--accent)';this.style.background='var(--bg-hover)'"
                           onmouseout="this.style.color='var(--text-3)';this.style.background='transparent'">
                            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                        </a>
                    </div>

                    {# ── MOBILE : points colorés ── #}
                    <div class="cal-dots hidden items-center gap-0.5 flex-wrap mt-0.5">
                        {% for s in daySessions|slice(0, 4) %}
                            <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: {{ s.colorBg }}"></span>
                        {% endfor %}
                        {% if daySessions|length > 4 %}
                            <span style="font-size:8px;color:var(--text-3);line-height:1;">+{{ daySessions|length - 4 }}</span>
                        {% endif %}
                    </div>

                    {# ── DESKTOP : pastilles texte ── #}
                    <div class="cal-pills" data-sessions>
                        {% for s in daySessions|slice(0, 3) %}
                            <div class="cal-pill-wrap"
                                 style="position:relative;margin-bottom:2px;cursor:grab;"
                                 draggable="true"
                                 data-session-id="{{ s.id }}">
                                <a href="{{ path('app_session_show', {id: s.id}) }}"
                                   draggable="false"
                                   @click.stop
                                   style="display:flex;align-items:center;gap:4px;padding:2px 6px;border-radius:4px;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-decoration:none;transition:filter .15s;background:{{ s.colorBg }}22;border-left:2px solid {{ s.colorBg }};"
                                   onmouseover="this.style.filter='brightness(1.3)'"
                                   onmouseout="this.style.filter='brightness(1)'">
                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500;color:var(--text-1);line-height:1.4;">{{ s.title }}</span>
                                </a>

                                {# Tooltip survol desktop #}
                                <div class="cal-tooltip"
                                     style="position:absolute;bottom:100%;{% if col >= 5 %}right:0;{% else %}left:0;{% endif %}margin-bottom:6px;z-index:50;width:208px;pointer-events:none;opacity:0;transition:opacity .15s;background:var(--bg-card-solid);border:1px solid var(--border-strong);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.35);overflow:hidden;">
                                    <div style="height:3px;flex-shrink:0;background:{{ s.colorBg }};"></div>
                                    <div style="padding:12px;">
                                        {% if s.typeLabel %}
                                            <span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;margin-bottom:6px;background:{{ s.colorBg }}25;color:{{ s.colorBg }};border:1px solid {{ s.colorBg }}40;">
                                                {{ s.typeLabel }}
                                            </span>
                                        {% endif %}
                                        <p style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;line-height:1.3;">{{ s.title }}</p>
                                        {% if s.durationMinutes %}
                                            <div style="display:flex;align-items:center;gap:4px;margin-top:6px;font-size:11px;color:var(--text-2);">
                                                <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                {{ s.durationMinutes }} min
                                            </div>
                                        {% endif %}
                                        {% if s.description %}
                                            <p style="font-size:11px;color:var(--text-2);margin:6px 0 0;font-style:italic;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ s.description }}</p>
                                        {% endif %}
                                        <p style="font-size:11px;color:var(--accent);margin:8px 0 0;font-weight:500;">Cliquer pour voir la fiche →</p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# Overflow desktop #}
                    {% if daySessions|length > 3 %}
                        <p class="cal-overflow"
                           style="font-size:11px;color:var(--text-3);padding:0 4px;cursor:pointer;transition:color .15s;"
                           onmouseover="this.style.color='var(--text-2)'"
                           onmouseout="this.style.color='var(--text-3)'"
                           @click.stop="openDay('{{ dayLabel }}', {{ allSessData|json_encode }})">
                            +{{ daySessions|length - 3 }} autres
                        </p>
                    {% endif %}
                </div>
            {% endfor %}

            {# Cases vides fin #}
            {% set lastCol = ((daysInMonth + firstWeekday - 2) % 7) + 1 %}
            {% if lastCol < 7 %}
                {% for i in (lastCol + 1)..7 %}
                    <div class="cal-cell-empty min-h-28" style="border-bottom:1px solid var(--border);border-right:1px solid var(--border);background:var(--bg);opacity:.5;"></div>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# ── MOBILE : Panneau jour sélectionné ── #}
    <div id="mobile-day-panel" class="card" style="display:none;overflow:hidden;">

        {# Header panneau #}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);">
            <h3 style="font-size:14px;font-weight:600;color:var(--text-1);margin:0;" x-text="panelDay ? 'Séances du ' + panelDay : 'Sélectionne un jour'"></h3>
            <a x-show="panelDateStr"
               :href="'/sessions/new?date=' + panelDateStr"
               class="btn btn-primary btn-sm" style="display:none;">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Ajouter
            </a>
        </div>

        {# Liste des séances #}
        <template x-if="panelSessions.length === 0">
            <div style="padding:32px 16px;text-align:center;">
                <p style="font-size:13px;color:var(--text-3);" x-text="panelDay ? 'Aucune séance ce jour.' : 'Appuie sur un jour pour voir ses séances.'"></p>
            </div>
        </template>

        <template x-if="panelSessions.length > 0">
            <div>
                <template x-for="s in panelSessions" :key="s.id">
                    <a :href="s.showUrl" class="list-item" style="text-decoration:none;">
                        <div style="width:3px;align-self:stretch;border-radius:2px;flex-shrink:0;" :style="'background:' + s.color"></div>
                        <div style="flex:1;min-width:0;">
                            <p style="font-weight:600;font-size:13px;color:var(--text-1);margin:0;" x-text="s.title"></p>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
                                <span style="font-size:11px;font-weight:500;" :style="'color:' + s.color" x-text="s.typeLabel"></span>
                                <template x-if="s.duration">
                                    <span style="font-size:11px;color:var(--text-3);" x-text="s.duration + ' min'"></span>
                                </template>
                            </div>
                        </div>
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </template>
            </div>
        </template>
    </div>

    {# ── Navigation bas de page (desktop) ── #}
    <div class="cal-bottom-nav" style="display:flex;align-items:center;justify-content:space-between;">
        <a href="{{ path('app_calendar', {month: prevMonth, year: prevYear}) }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Précédent
        </a>
        <a href="{{ path('app_calendar', {month: nextMonth, year: nextYear}) }}" class="btn btn-secondary btn-sm">
            Suivant
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>

    {# ── Modal desktop (overflow "+N autres") ── #}
    <div x-show="dayModal"
         x-transition:enter="ease-out duration-150" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-100" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="modal-backdrop"
         @click.self="dayModal = false"
         style="display:none">

        <div class="modal" style="max-width:440px;overflow:hidden;">
            <div class="modal-header">
                <h3 class="modal-title" x-text="'Séances du ' + dayDate"></h3>
                <button @click="dayModal = false" class="btn btn-ghost btn-sm" style="padding:6px;">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div style="padding:16px;display:flex;flex-direction:column;gap:8px;max-height:320px;overflow-y:auto;">
                <template x-for="s in daySessions" :key="s.id">
                    <a :href="s.showUrl" class="list-item" style="text-decoration:none;">
                        <div style="width:3px;height:36px;border-radius:2px;flex-shrink:0;" :style="'background:' + s.color"></div>
                        <div style="flex:1;min-width:0;">
                            <p style="font-weight:500;font-size:13px;color:var(--text-1);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" x-text="s.title"></p>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:2px;">
                                <span style="font-size:11px;" :style="'color:' + s.color" x-text="s.typeLabel"></span>
                                <span x-show="s.duration" style="font-size:11px;color:var(--text-3);" x-text="s.duration + ' min'"></span>
                            </div>
                        </div>
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </template>
            </div>
            <div style="padding:16px;border-top:1px solid var(--border);">
                <a :href="'/sessions/new?date=' + dayDate.split('/').reverse().join('-')"
                   class="btn btn-primary" style="width:100%;justify-content:center;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Ajouter une séance ce jour
                </a>
            </div>
        </div>
    </div>

</div>

<script>
(function () {
    /* Drag & drop desktop uniquement */
    var dragging = null;
    var lastCell = null;

    function clearHL() {
        if (lastCell) { lastCell.style.outline = lastCell.style.outlineOffset = ''; lastCell = null; }
    }

    document.addEventListener('dragstart', function(e) {
        if (window.innerWidth < 768) return;
        var pill = e.target.closest('[data-session-id]');
        if (!pill) return;
        dragging = {id: pill.dataset.sessionId, el: pill};
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', dragging.id);
        setTimeout(function() { if (dragging) dragging.el.style.opacity = '0.4'; }, 0);
    });

    document.addEventListener('dragend', function() {
        if (dragging) dragging.el.style.opacity = '';
        dragging = null;
        clearHL();
    });

    document.addEventListener('dragover', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        if (lastCell !== cell) {
            clearHL();
            cell.style.outline = '2px solid rgba(99,102,241,0.6)';
            cell.style.outlineOffset = '-2px';
            lastCell = cell;
        }
    });

    document.addEventListener('drop', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        var id = dragging.id, el = dragging.el;
        dragging = null; clearHL();
        el.style.opacity = '';
        var cont = cell.querySelector('[data-sessions]');
        if (cont) cont.appendChild(el);
        fetch('/sessions/' + id + '/reschedule', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({date: cell.dataset.date})
        }).then(function(r) { if (!r.ok) location.reload(); }).catch(location.reload);
    });
}());

// ── Tooltips calendrier : position:fixed pour échapper à overflow:hidden ──
(function() {
    function initTooltips() {
        document.querySelectorAll('.cal-pill-wrap').forEach(function(wrap) {
            if (wrap._tipInit) return;
            wrap._tipInit = true;
            var tip = wrap.querySelector('.cal-tooltip');
            if (!tip) return;

            wrap.addEventListener('mouseenter', function() {
                var r   = wrap.getBoundingClientRect();
                var tipW = 208;
                var tipH = tip.offsetHeight || 180;

                tip.style.position = 'fixed';
                tip.style.width    = tipW + 'px';
                tip.style.margin   = '0';

                // Horizontal
                if (r.right + tipW > window.innerWidth - 8) {
                    tip.style.right = (window.innerWidth - r.right) + 'px';
                    tip.style.left  = 'auto';
                } else {
                    tip.style.left  = r.left + 'px';
                    tip.style.right = 'auto';
                }

                // Vertical : au-dessus si la place le permet, sinon en-dessous
                if (r.top > tipH + 12) {
                    tip.style.bottom = (window.innerHeight - r.top + 6) + 'px';
                    tip.style.top    = 'auto';
                } else {
                    tip.style.top    = (r.bottom + 6) + 'px';
                    tip.style.bottom = 'auto';
                }
            });
        });
    }
    initTooltips();
}());
</script>
{% endblock %}
