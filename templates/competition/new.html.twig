{% extends 'base.html.twig' %}
{% block title %}Nouvelle compétition{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar') }}">Compétitions</a>
    <span class="sep">/</span>
    <span class="current">Nouvelle compétition</span>
{% endblock %}

{% block body %}
<div style="max-width:640px;margin:0 auto;">
    <div style="margin-bottom:24px;">
        <h1 class="section-title">Nouvelle compétition</h1>
        <p class="section-subtitle">Ajoutez une compétition au calendrier</p>
    </div>
    <div class="card card-body">
        {{ form_start(form, {attr: {class: 'space-y-5', enctype: 'multipart/form-data', 'data-turbo': 'false'}}) }}
        {{ form_row(form.title) }}
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.date) }}</div>
            <div>{{ form_row(form.competitionType) }}</div>
        </div>
        {{ form_row(form.location) }}
        {{ form_row(form.websiteUrl) }}
        {{ form_row(form.documentFile) }}
        {{ form_row(form.description) }}
        <div style="display:flex;gap:10px;padding-top:8px;">
            <button type="submit" class="btn btn-primary">
                Créer la compétition
            </button>
            <a href="{{ path('app_competition_calendar') }}" class="btn btn-secondary">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
