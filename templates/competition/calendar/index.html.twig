{% extends 'base.html.twig' %}
{% block title %}Compétitions{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Compétitions</span>
{% endblock %}

{% block body %}
<style>
@media(min-width:768px){
    .cal-pill-wrap:hover .cal-tooltip { opacity: 1 !important; }
}
</style>
<div id="cal-root" style="display:flex;flex-direction:column;gap:20px;"
     x-data="{
        dayModal: false,
        dayDate: '',
        dayComps: [],
        openDay(dateStr, comps) {
            this.dayDate = dateStr;
            this.dayComps = comps;
            this.dayModal = true;
        },
     }">

    {# ── Header ── #}
    <div style="display:flex;flex-direction:column;gap:12px;" class="sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="section-title" style="text-transform:capitalize">{{ monthName }}</h1>
            {% set total = 0 %}{% for d, c in byDay %}{% set total = total + c|length %}{% endfor %}
            <p class="section-subtitle">{{ total }} compétition{% if total > 1 %}s{% endif %} programmée{% if total > 1 %}s{% endif %}</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
            <a href="{{ path('app_competition_calendar', {month: prevMonth, year: prevYear}) }}" class="btn btn-secondary btn-sm">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Précédent
            </a>
            {% if month != currentMonth or year != currentYear %}
                <a href="{{ path('app_competition_calendar') }}" class="btn btn-secondary btn-sm">Aujourd'hui</a>
            {% endif %}
            <a href="{{ path('app_competition_calendar', {month: nextMonth, year: nextYear}) }}" class="btn btn-secondary btn-sm">
                Suivant
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            {% if canEdit %}
            <a href="{{ path('app_competition_new') }}" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nouvelle compétition
            </a>
            {% endif %}
        </div>
    </div>

    {# ── Légende ── #}
    {% if competitionTypes is not empty %}
    <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
        {% for ct in competitionTypes %}
            <span style="display:flex;align-items:center;gap:6px;background:var(--bg-2);border:1px solid var(--border);padding:4px 10px;border-radius:8px;font-size:12px;color:var(--text-2);">
                <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:{{ ct.color }}"></span>
                {{ ct.name }}
            </span>
        {% endfor %}
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_competition_type_index') }}" style="display:flex;align-items:center;gap:4px;font-size:12px;color:var(--text-3);text-decoration:none;margin-left:4px;" onmouseover="this.style.color='var(--warning)'" onmouseout="this.style.color='var(--text-3)'">
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Gérer
        </a>
        {% endif %}
    </div>
    {% else %}
    <div style="font-size:12px;color:var(--text-3);">
        Aucun type configuré —
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_competition_type_index') }}" style="color:var(--warning);text-decoration:none;">Créer des types</a>
        {% endif %}
    </div>
    {% endif %}

    {# ── Grille calendrier ── #}
    <div class="card" style="overflow:hidden;user-select:none;">

        {# En-têtes jours #}
        <div class="grid grid-cols-7" style="border-bottom:1px solid var(--border);">
            {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                <div style="padding:10px 4px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:{{ day in ['Sam', 'Dim'] ? 'var(--text-3)' : 'var(--text-2)' }};">{{ day }}</div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-7 auto-rows-fr">

            {# Cases vides en début #}
            {% for i in 1..(firstWeekday - 1) %}
                <div class="min-h-28" style="border-bottom:1px solid var(--border);border-right:1px solid var(--border);background:var(--bg);opacity:.5;"></div>
            {% endfor %}

            {# Cases jours #}
            {% set isCurrentMonthView = month == currentMonth and year == currentYear %}
            {% set todayWeekRow = isCurrentMonthView ? ((today + firstWeekday - 2) // 7) : -1 %}

            {% for day in 1..daysInMonth %}
                {% set col = ((day + firstWeekday - 2) % 7) + 1 %}
                {% set isWeekend = col >= 6 %}
                {% set isToday = day == today and isCurrentMonthView %}
                {% set dayWeekRow = (day + firstWeekday - 2) // 7 %}
                {% set isCurrentWeek = isCurrentMonthView and dayWeekRow == todayWeekRow %}
                {% set dayComps = byDay[day] ?? [] %}
                {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}

                {% set allCompData = [] %}
                {% for c in dayComps %}
                    {% set allCompData = allCompData|merge([{
                        id: c.id,
                        title: c.title,
                        typeLabel: c.typeLabel,
                        color: c.colorBg,
                        location: c.location,
                        showUrl: path('app_competition_show', {id: c.id}),
                    }]) %}
                {% endfor %}

                <div class="min-h-28 group relative"
                     style="border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:6px;transition:background .15s;
                     background:{% if isToday %}rgba(245,158,11,.06){% elseif isCurrentWeek %}var(--bg-hover){% elseif isWeekend %}var(--bg){% else %}var(--bg-2){% endif %};"
                     data-date="{{ dateStr }}">

                    {# Numéro + bouton ajout rapide #}
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:4px;">
                        <span @click="{{ allCompData|length > 0 ? 'openDay(\'' ~ '%02d'|format(day) ~ '/' ~ '%02d'|format(month) ~ '/' ~ year ~ '\', ' ~ allCompData|json_encode ~ ')' : '' }}"
                              style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:13px;font-weight:500;transition:all .15s;
                              {% if isToday %}background:#d97706;color:#fff;font-weight:700;box-shadow:0 0 0 3px rgba(245,158,11,.25);
                              {% elseif isCurrentWeek %}color:var(--text-1);
                              {% elseif isWeekend %}color:var(--text-3);
                              {% else %}color:var(--text-2);{% endif %}
                              {{ allCompData|length > 0 ? 'cursor:pointer;' : '' }}">
                            {{ day }}
                        </span>
                        {% if canEdit %}
                        <a href="{{ path('app_competition_new') }}?date={{ dateStr }}"
                           style="opacity:0;width:20px;height:20px;display:flex;align-items:center;justify-content:center;border-radius:6px;color:var(--text-3);text-decoration:none;transition:all .15s;"
                           onmouseover="this.style.color='var(--warning)';this.style.background='var(--bg-hover)'"
                           onmouseout="this.style.color='var(--text-3)';this.style.background='transparent'">
                            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                        </a>
                        {% endif %}
                    </div>

                    {# Pastilles compétitions #}
                    <div data-competitions>
                        {% for c in dayComps|slice(0, 3) %}
                            <div class="cal-pill-wrap"
                                 style="position:relative;margin-bottom:2px;{% if canEdit %}cursor:grab;{% endif %}"
                                 {% if canEdit %}draggable="true" data-competition-id="{{ c.id }}"{% endif %}>
                                <a href="{{ path('app_competition_show', {id: c.id}) }}"
                                   draggable="false"
                                   style="display:flex;align-items:center;gap:4px;padding:2px 6px;border-radius:4px;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-decoration:none;transition:filter .15s;background:{{ c.colorBg }}22;border-left:2px solid {{ c.colorBg }};"
                                   onmouseover="this.style.filter='brightness(1.3)'"
                                   onmouseout="this.style.filter='brightness(1)'">
                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500;color:var(--text-1);line-height:1.4;">{{ c.title }}</span>
                                </a>

                                {# Tooltip au survol #}
                                <div class="cal-tooltip"
                                     style="position:absolute;bottom:100%;{% if col >= 5 %}right:0;{% else %}left:0;{% endif %}margin-bottom:6px;z-index:50;width:208px;pointer-events:none;opacity:0;transition:opacity .15s;background:var(--bg-card-solid);border:1px solid var(--border-strong);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.35);overflow:hidden;">
                                    <div style="height:3px;flex-shrink:0;background:{{ c.colorBg }};"></div>
                                    <div style="padding:12px;">
                                        {% if c.typeLabel != '—' %}
                                            <span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;margin-bottom:6px;background:{{ c.colorBg }}25;color:{{ c.colorBg }};border:1px solid {{ c.colorBg }}40;">
                                                {{ c.typeLabel }}
                                            </span>
                                        {% endif %}
                                        <p style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;line-height:1.3;">{{ c.title }}</p>
                                        {% if c.location %}
                                            <p style="font-size:11px;color:var(--text-2);margin:6px 0 0;display:flex;align-items:center;gap:4px;">
                                                <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                                {{ c.location }}
                                            </p>
                                        {% endif %}
                                        {% if registeredIds is not empty %}
                                        <div style="margin-top:8px;display:flex;align-items:center;gap:6px;">
                                            {% if c.id in registeredIds %}
                                                <span style="width:7px;height:7px;border-radius:50%;background:#34d399;flex-shrink:0;"></span>
                                                <span style="font-size:11px;color:#34d399;font-weight:500;">Inscrit</span>
                                            {% else %}
                                                <span style="width:7px;height:7px;border-radius:50%;background:#f87171;flex-shrink:0;"></span>
                                                <span style="font-size:11px;color:#f87171;font-weight:500;">Non inscrit</span>
                                            {% endif %}
                                        </div>
                                        {% endif %}
                                        <p style="font-size:11px;color:#fbbf24;margin:8px 0 0;font-weight:500;">Cliquer pour voir la fiche →</p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% if dayComps|length > 3 %}
                        <p style="font-size:11px;color:var(--text-3);padding:0 4px;cursor:pointer;transition:color .15s;"
                           onmouseover="this.style.color='var(--text-2)'"
                           onmouseout="this.style.color='var(--text-3)'"
                           @click.stop="openDay('{{ '%02d'|format(day) }}/{{ '%02d'|format(month) }}/{{ year }}', {{ allCompData|json_encode }})">
                            +{{ dayComps|length - 3 }} autres
                        </p>
                    {% endif %}
                </div>
            {% endfor %}

            {# Cases vides en fin #}
            {% set lastCol = ((daysInMonth + firstWeekday - 2) % 7) + 1 %}
            {% if lastCol < 7 %}
                {% for i in (lastCol + 1)..7 %}
                    <div style="min-height:7rem;border-bottom:1px solid var(--border);border-right:1px solid var(--border);background:var(--bg);opacity:.5;"></div>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# ── Navigation bas de page ── #}
    <div style="display:flex;align-items:center;justify-content:space-between;">
        <a href="{{ path('app_competition_calendar', {month: prevMonth, year: prevYear}) }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Précédent
        </a>
        <a href="{{ path('app_competition_calendar', {month: nextMonth, year: nextYear}) }}" class="btn btn-secondary btn-sm">
            Suivant
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>

    {# ═══════════════════════════════════════
       Modal VUE JOUR
       ═══════════════════════════════════════ #}
    <div x-show="dayModal"
         x-transition:enter="ease-out duration-150" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-100" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="modal-backdrop"
         @click.self="dayModal = false"
         style="display:none">

        <div class="modal" style="max-width:440px;overflow:hidden;">
            <div class="modal-header">
                <h3 class="modal-title" x-text="'Compétitions du ' + dayDate"></h3>
                <button @click="dayModal = false" class="btn btn-ghost btn-sm" style="padding:6px;">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div style="padding:16px;display:flex;flex-direction:column;gap:8px;max-height:320px;overflow-y:auto;">
                <template x-for="c in dayComps" :key="c.id">
                    <a :href="c.showUrl" class="list-item" style="text-decoration:none;">
                        <div style="width:3px;height:36px;border-radius:2px;flex-shrink:0;" :style="'background:' + c.color"></div>
                        <div style="flex:1;min-width:0;">
                            <p style="font-weight:500;font-size:13px;color:var(--text-1);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" x-text="c.title"></p>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:2px;">
                                <span style="font-size:11px;" :style="'color:' + c.color" x-text="c.typeLabel"></span>
                                <span x-show="c.location" style="font-size:11px;color:var(--text-3);" x-text="c.location"></span>
                            </div>
                        </div>
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </template>
            </div>
            {% if canEdit %}
            <div style="padding:16px;border-top:1px solid var(--border);">
                <a :href="'/competitions/new?date=' + dayDate.split('/').reverse().join('-')"
                   class="btn btn-primary" style="width:100%;justify-content:center;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Ajouter une compétition ce jour
                </a>
            </div>
            {% endif %}
        </div>
    </div>

</div>

{% if canEdit %}
<script>
(function () {
    var dragging = null;
    var lastCell = null;

    function clearHL() {
        if (lastCell) { lastCell.style.outline = lastCell.style.outlineOffset = ''; lastCell = null; }
    }

    document.addEventListener('dragstart', function(e) {
        var pill = e.target.closest('[data-competition-id]');
        if (!pill) return;
        dragging = {id: pill.dataset.competitionId, el: pill};
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', dragging.id);
        setTimeout(function() { if (dragging) dragging.el.style.opacity = '0.4'; }, 0);
    });

    document.addEventListener('dragend', function() {
        if (dragging) dragging.el.style.opacity = '';
        dragging = null;
        clearHL();
    });

    document.addEventListener('dragover', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        if (lastCell !== cell) {
            clearHL();
            cell.style.outline = '2px solid rgba(245,158,11,0.6)';
            cell.style.outlineOffset = '-2px';
            lastCell = cell;
        }
    });

    document.addEventListener('drop', function(e) {
        if (!dragging) return;
        var cell = e.target.closest('[data-date]');
        if (!cell) return;
        e.preventDefault();
        var id = dragging.id, el = dragging.el;
        dragging = null; clearHL();
        el.style.opacity = '';
        var cont = cell.querySelector('[data-competitions]');
        if (cont) cont.appendChild(el);
        fetch('/competitions/' + id + '/reschedule', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({date: cell.dataset.date})
        }).then(function(r) { if (!r.ok) location.reload(); }).catch(location.reload);
    });
}());

// ── Tooltips calendrier : position:fixed pour échapper à overflow:hidden ──
(function() {
    function initTooltips() {
        document.querySelectorAll('.cal-pill-wrap').forEach(function(wrap) {
            if (wrap._tipInit) return;
            wrap._tipInit = true;
            var tip = wrap.querySelector('.cal-tooltip');
            if (!tip) return;

            wrap.addEventListener('mouseenter', function() {
                var r    = wrap.getBoundingClientRect();
                var tipW = 208;
                var tipH = tip.offsetHeight || 180;

                tip.style.position = 'fixed';
                tip.style.width    = tipW + 'px';
                tip.style.margin   = '0';

                // Horizontal
                if (r.right + tipW > window.innerWidth - 8) {
                    tip.style.right = (window.innerWidth - r.right) + 'px';
                    tip.style.left  = 'auto';
                } else {
                    tip.style.left  = r.left + 'px';
                    tip.style.right = 'auto';
                }

                // Vertical : au-dessus si la place le permet, sinon en-dessous
                if (r.top > tipH + 12) {
                    tip.style.bottom = (window.innerHeight - r.top + 6) + 'px';
                    tip.style.top    = 'auto';
                } else {
                    tip.style.top    = (r.bottom + 6) + 'px';
                    tip.style.bottom = 'auto';
                }
            });
        });
    }
    initTooltips();
}());
</script>
{% endif %}
{% endblock %}
