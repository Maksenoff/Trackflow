{% extends 'base.html.twig' %}
{% block title %}Modifier — {{ competition.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar', {month: competition.date|date('n'), year: competition.date|date('Y')}) }}" >Compétitions</a>
    <span class="sep">/</span>
    <a href="{{ path('app_competition_show', {id: competition.id}) }}" >{{ competition.title }}</a>
    <span class="sep">/</span>
    <span class="current">Modifier</span>
{% endblock %}

{% block body %}
<div style="max-width:640px;margin:0 auto;">
    <div style="margin-bottom:24px;">
        <h1 class="section-title">Modifier la compétition</h1>
    </div>
    <div class="card card-body">
        {{ form_start(form, {attr: {class: 'space-y-5', enctype: 'multipart/form-data', 'data-turbo': 'false'}}) }}
        {{ form_row(form.title) }}
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
            <div>{{ form_row(form.date) }}</div>
            <div>{{ form_row(form.competitionType) }}</div>
        </div>
        {{ form_row(form.location) }}
        {{ form_row(form.websiteUrl) }}

        {# Document upload with current file indicator #}
        <div>
            {% if competition.documentFilename %}
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;background:var(--bg-hover);border-radius:8px;padding:8px 12px;">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:var(--warning);flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span style="font-size:13px;color:var(--text-2);">Circulaire actuelle</span>
                    <a href="{{ path('app_competition_document', {id: competition.id}) }}"
                       style="font-size:12px;color:var(--warning);text-decoration:none;margin-left:auto;">Télécharger</a>
                </div>
            {% endif %}
            {{ form_row(form.documentFile) }}
        </div>

        {{ form_row(form.description) }}
        <div style="display:flex;gap:10px;padding-top:8px;">
            <button type="submit" class="btn btn-primary">
                Enregistrer
            </button>
            <a href="{{ path('app_competition_show', {id: competition.id}) }}" class="btn btn-secondary">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
