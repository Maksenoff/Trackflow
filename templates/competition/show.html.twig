{% extends 'base.html.twig' %}
{% block title %}{{ competition.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar', {month: competition.date|date('n'), year: competition.date|date('Y')}) }}" class="hover:text-white transition-colors">Compétitions</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">{{ competition.title }}</span>
{% endblock %}

{% block body %}

{% set disciplineLabelsJson = {} %}
{% for code, label in disciplineLabels %}
    {% set disciplineLabelsJson = disciplineLabelsJson|merge({(code): label}) %}
{% endfor %}
{% set myRegInit = myRegistration ? {id: myRegistration.id, disciplines: myRegistration.disciplines} : null %}

<div class="space-y-5"
     x-data="competitionPage({
         registerUrl:      '{{ path('app_competition_register',      {id: competition.id}) }}',
         unregisterUrl:    '{{ path('app_competition_unregister',    {id: competition.id}) }}',
         unregAnyBase:     '{{ path('app_competition_unregister_any',{id: competition.id, registrationId: 0}) }}',
         registerToken:    '{{ csrf_token('register-competition-' ~ competition.id) }}',
         unregToken:       '{{ csrf_token('unregister-competition-' ~ competition.id) }}',
         myReg:            {{ myRegInit|json_encode }},
         registrations:    {{ registrationsData|json_encode }},
         disciplineLabels: {{ disciplineLabelsJson|json_encode }},
         canRegister:      {{ canRegister ? 'true' : 'false' }},
     })">

{# ── Header ─────────────────────────────────────────────────────────── #}
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="h-1.5" style="background: {{ competition.colorBg }}"></div>
    <div class="p-6">
        <div class="flex items-start justify-between gap-4">

            {# Gauche : titre, badges, méta #}
            <div class="flex-1">
                <div class="flex items-center flex-wrap gap-2 mb-2">
                    {% if competition.competitionType %}
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full"
                              style="background:{{ competition.colorBg }}22; color:{{ competition.colorBg }}; border:1px solid {{ competition.colorBg }}44">
                            {{ competition.typeLabel }}
                        </span>
                    {% endif %}
                    {% if competition.isPast() %}
                        <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">Passée</span>
                    {% else %}
                        <span class="text-xs text-emerald-400 bg-emerald-900/30 border border-emerald-800/50 px-2 py-0.5 rounded-full">À venir</span>
                    {% endif %}
                </div>
                <h1 class="text-2xl font-bold text-white mb-2">{{ competition.title }}</h1>
                <div class="flex flex-wrap items-center gap-5 text-sm text-gray-400">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        {{ competition.date|date_fr('l d F Y')|capitalize }}
                    </span>
                    {% if competition.location %}
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {{ competition.location }}
                    </span>
                    {% endif %}
                </div>
            </div>

            {# Droite : actions #}
            {% if canEdit %}
            <div class="flex gap-2 shrink-0">
                <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                   class="flex items-center gap-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Modifier
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <form action="{{ path('app_competition_delete', {id: competition.id}) }}" method="post" data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-competition' ~ competition.id) }}">
                    <button type="submit" onclick="return confirm('Supprimer cette compétition ?')"
                            class="flex items-center gap-1.5 bg-gray-800 hover:bg-red-900/40 hover:text-red-400 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Supprimer
                    </button>
                </form>
                {% endif %}
            </div>
            {% endif %}
        </div>

        {# Stats rapides #}
        <div class="grid grid-cols-3 gap-4 mt-5 pt-5 border-t border-gray-800">
            <div>
                <p class="text-2xl font-bold text-white" x-text="registrations.length">{{ registrationsData|length }}</p>
                <p class="text-sm text-gray-400">Inscrit{{ registrationsData|length > 1 ? 's' : '' }}</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">
                    {{ competition.documentFilename ? '1' : '—' }}
                </p>
                <p class="text-sm text-gray-400">Circulaire</p>
            </div>
            <div>
                <p class="text-2xl font-bold" style="color:{{ competition.colorBg }}">
                    {{ competition.isPast() ? 'Terminée' : 'À venir' }}
                </p>
                <p class="text-sm text-gray-400">Statut</p>
            </div>
        </div>
    </div>
</div>

{# ── Barre d'onglets ─────────────────────────────────────────────────── #}
<div class="flex gap-1 bg-gray-900 border border-gray-800 rounded-xl p-1">
    <button @click="activeTab = 'infos'"
            :class="activeTab === 'infos' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
            class="flex-1 flex items-center justify-center gap-2 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Infos pratiques
    </button>
    <button @click="activeTab = 'inscriptions'"
            :class="activeTab === 'inscriptions' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
            class="flex-1 flex items-center justify-center gap-2 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Inscriptions
        <span class="text-xs font-semibold px-1.5 py-0.5 rounded-full transition-colors"
              :class="activeTab === 'inscriptions' ? 'bg-gray-600 text-gray-200' : 'bg-gray-800 text-gray-500'"
              x-text="registrations.length"></span>
    </button>
</div>

{# ── Onglet Infos ────────────────────────────────────────────────────── #}
<div x-show="activeTab === 'infos'" x-transition class="space-y-5">

    {# Liens #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-5">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Ressources</h2>

        <div class="flex items-center gap-4">
            <div class="w-9 h-9 rounded-lg bg-gray-800 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-xs text-gray-500 mb-0.5">Site officiel</p>
                {% if competition.websiteUrl %}
                    <a href="{{ competition.websiteUrl }}" target="_blank" rel="noopener noreferrer"
                       class="text-sm text-amber-400 hover:text-amber-300 break-all transition-colors">{{ competition.websiteUrl }}</a>
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}" class="text-sm text-gray-600 hover:text-gray-400 transition-colors">Ajouter un lien →</a>
                {% else %}
                    <span class="text-sm text-gray-600">Non renseigné</span>
                {% endif %}
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="w-9 h-9 rounded-lg bg-gray-800 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div class="flex-1">
                <p class="text-xs text-gray-500 mb-0.5">Circulaire</p>
                {% if competition.documentFilename %}
                    <a href="{{ path('app_competition_document', {id: competition.id}) }}"
                       class="inline-flex items-center gap-2 text-sm text-amber-400 hover:text-amber-300 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                        Télécharger la circulaire
                    </a>
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}" class="text-sm text-gray-600 hover:text-gray-400 transition-colors">Ajouter une circulaire →</a>
                {% else %}
                    <span class="text-sm text-gray-600">Non disponible</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# Notes #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Notes
            </h2>
            {% if canEdit %}
            <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
               class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Modifier</a>
            {% endif %}
        </div>
        <div class="p-6">
            {% if competition.description %}
                <pre class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap font-sans">{{ competition.description }}</pre>
            {% else %}
                <div class="text-center py-6">
                    <svg class="w-8 h-8 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p class="text-gray-500 text-sm">Aucune note pour l'instant.</p>
                    {% if canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       class="inline-block mt-2 text-xs text-amber-400 hover:text-amber-300 transition-colors">Ajouter des notes →</a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

</div>

{# ── Onglet Inscriptions ─────────────────────────────────────────────── #}
<div x-show="activeTab === 'inscriptions'" x-transition class="space-y-4">

    {# Toast #}
    <div x-show="toast"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-end="opacity-0"
         :class="toastError ? 'bg-red-900/40 border-red-800/50 text-red-300' : 'bg-emerald-900/40 border-emerald-800/50 text-emerald-300'"
         class="px-4 py-3 rounded-xl border text-sm font-medium"
         x-text="toast" style="display:none"></div>

    {# Mon inscription #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800">
            <h2 class="text-sm font-semibold text-white">Mon inscription</h2>
        </div>
        <div class="p-6">

            {# Inscrit #}
            <template x-if="myReg">
                <div class="space-y-4">
                    <div class="flex items-start gap-4 p-4 rounded-xl"
                         style="background:{{ competition.colorBg }}0d; border:1px solid {{ competition.colorBg }}28">
                        <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:{{ competition.colorBg }}22">
                            <svg class="w-4 h-4" style="color:{{ competition.colorBg }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white mb-2">Tu es inscrit</p>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="d in myReg.disciplines" :key="d">
                                    <span class="inline-flex items-center gap-1.5 text-sm font-medium px-2.5 py-1 rounded-lg"
                                          style="background:{{ competition.colorBg }}18; color:{{ competition.colorBg }}; border:1px solid {{ competition.colorBg }}35"
                                          x-text="disciplineLabels[d] || d"></span>
                                </template>
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button @click="openModal()"
                                class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Modifier les disciplines
                        </button>
                        <button @click="unregister()" :disabled="loading"
                                class="flex items-center gap-2 text-red-400 bg-red-900/20 hover:bg-red-900/35 border border-red-800/40 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors disabled:opacity-40">
                            <svg x-show="loading" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                            Annuler l'inscription
                        </button>
                    </div>
                </div>
            </template>

            {# Non inscrit, peut s'inscrire #}
            <template x-if="!myReg && canRegister">
                <div class="text-center py-4">
                    <p class="text-sm text-gray-400 mb-4">Tu n'es pas encore inscrit à cette compétition.</p>
                    <button @click="openModal()"
                            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold text-white transition-colors"
                            style="background:{{ competition.colorBg }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        S'inscrire
                    </button>
                </div>
            </template>

            {# Compétition passée ou pas de profil #}
            <template x-if="!myReg && !canRegister">
                <div class="text-center py-4">
                    <p class="text-sm text-gray-500">
                        {{ competition.isPast() ? 'Cette compétition est terminée.' : 'Associez un profil athlète pour vous inscrire.' }}
                    </p>
                </div>
            </template>
        </div>
    </div>

    {# Liste des inscrits #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white">Liste des inscrits</h2>
            <span class="text-xs font-medium text-gray-400 bg-gray-800 px-2.5 py-1 rounded-full"
                  x-text="registrations.length + ' inscrit' + (registrations.length > 1 ? 's' : '')">
                {{ registrationsData|length }} inscrit{{ registrationsData|length > 1 ? 's' : '' }}
            </span>
        </div>

        <template x-if="registrations.length === 0">
            <div class="px-6 py-12 text-center">
                <svg class="w-10 h-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <p class="text-gray-500 text-sm">Aucune inscription pour l'instant.</p>
            </div>
        </template>

        <div class="divide-y divide-gray-800/60">
            <template x-for="reg in registrations" :key="reg.id">
                <div class="px-6 py-4 flex items-center gap-4 transition-colors"
                     :class="reg.isOwn ? 'bg-gray-800/20' : 'hover:bg-gray-800/10'">

                    {# Avatar #}
                    <template x-if="reg.athletePhoto">
                        <img :src="'/uploads/athletes/' + reg.athletePhoto"
                             class="w-10 h-10 rounded-full object-cover shrink-0">
                    </template>
                    <template x-if="!reg.athletePhoto">
                        <div class="w-10 h-10 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-sm font-bold text-gray-400 shrink-0"
                             x-text="reg.athleteName.split(' ').map(p => p[0] || '').join('').slice(0,2).toUpperCase()"></div>
                    </template>

                    {# Nom + disciplines #}
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1.5">
                            <span class="text-sm font-semibold text-white truncate" x-text="reg.athleteName"></span>
                            <template x-if="reg.isOwn">
                                <span class="text-xs px-1.5 py-0.5 rounded-md font-semibold shrink-0"
                                      style="background:{{ competition.colorBg }}20; color:{{ competition.colorBg }}">Toi</span>
                            </template>
                        </div>
                        <div class="flex flex-wrap gap-1.5">
                            <template x-for="d in reg.disciplines" :key="d">
                                <span class="text-xs px-2 py-0.5 rounded-md font-medium bg-gray-800 text-gray-300 border border-gray-700/50"
                                      x-text="disciplineLabels[d] || d"></span>
                            </template>
                        </div>
                    </div>

                    {# Bouton retirer #}
                    <template x-if="reg.canRemove">
                        <button @click="unregisterAny(reg.id, reg.unregToken)"
                                :disabled="loading"
                                title="Retirer l'inscription"
                                class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-gray-400 border border-gray-700 hover:text-red-400 hover:border-red-800/60 hover:bg-red-900/20 transition-colors disabled:opacity-40 shrink-0">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            Retirer
                        </button>
                    </template>
                </div>
            </template>
        </div>
    </div>

</div>

{# ── Modal disciplines ───────────────────────────────────────────────── #}
<div x-show="modalOpen"
     x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150" x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black/65 backdrop-blur-sm"
     @click.self="modalOpen = false" style="display:none">

    <div x-transition:enter="transition ease-out duration-200" x-transition:enter-start="translate-y-4 opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
         class="bg-gray-900 border border-gray-700/80 rounded-t-2xl sm:rounded-2xl w-full sm:max-w-lg flex flex-col"
         style="max-height:88vh" @click.stop>

        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 shrink-0">
            <div>
                <h3 class="text-base font-bold text-white">Choisir les disciplines</h3>
                <p class="text-xs text-gray-500 mt-0.5">{{ competition.title }}</p>
            </div>
            <button @click="modalOpen = false"
                    class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-500 hover:text-white hover:bg-gray-800 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="overflow-y-auto flex-1 px-6 py-5 space-y-5">
            {% for groupName, codes in disciplineGroups %}
            <div>
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2.5">{{ groupName }}</p>
                <div class="flex flex-wrap gap-2">
                    {% for code in codes %}
                    {% set label = disciplineLabels[code] ?? code %}
                    <button type="button"
                            @click="toggleDisc('{{ code }}')"
                            class="px-3 py-1.5 rounded-lg text-sm font-medium transition-all border"
                            :class="selected.includes('{{ code }}') ? '' : 'text-gray-400 border-gray-700 hover:border-gray-500 hover:text-gray-200'"
                            :style="selected.includes('{{ code }}') ? 'background:{{ competition.colorBg }}25; border-color:{{ competition.colorBg }}; color:{{ competition.colorBg }}' : ''">
                        {{ label|capitalize }}
                    </button>
                    {% endfor %}
                </div>
                {% if groupName == 'Autre' %}
                <div x-show="selected.includes('autre')" x-transition class="mt-2">
                    <textarea x-model="autreText" placeholder="Précise la discipline…" rows="2"
                              class="w-full bg-gray-800 border border-gray-700 focus:border-indigo-500 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-500 outline-none resize-none transition-colors"></textarea>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <div class="px-6 py-4 border-t border-gray-800 flex items-center justify-between gap-4 shrink-0">
            <span class="text-sm text-gray-400">
                <span x-text="selected.length" class="font-semibold text-white"></span>
                <span x-text="selected.length > 1 ? ' disciplines' : ' discipline'"></span>
            </span>
            <button @click="submitRegister()"
                    :disabled="selected.length === 0 || loading"
                    class="flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold text-white disabled:opacity-40 disabled:cursor-not-allowed transition-all"
                    style="background:{{ competition.colorBg }}">
                <svg x-show="loading" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                <span x-text="myReg ? 'Mettre à jour' : 'Confirmer l\'inscription'"></span>
            </button>
        </div>
    </div>
</div>

</div>{# /x-data #}

<script>
function competitionPage(cfg) {
    return {
        activeTab:        'infos',
        myReg:            cfg.myReg,
        registrations:    cfg.registrations,
        disciplineLabels: cfg.disciplineLabels,
        canRegister:      cfg.canRegister,

        modalOpen: false,
        selected:  [],
        autreText: '',

        loading:     false,
        toast:       '',
        toastError:  false,
        _toastTimer: null,

        openModal() {
            this.selected  = this.myReg ? [...this.myReg.disciplines] : [];
            this.autreText = '';
            this.modalOpen = true;
        },

        toggleDisc(code) {
            const i = this.selected.indexOf(code);
            i >= 0 ? this.selected.splice(i, 1) : this.selected.push(code);
        },

        get disciplinesForSubmit() {
            return this.selected.map(d => d === 'autre' ? (this.autreText.trim() || 'autre') : d);
        },

        showToast(msg, isError = false) {
            this.toast      = msg;
            this.toastError = isError;
            clearTimeout(this._toastTimer);
            this._toastTimer = setTimeout(() => this.toast = '', 3500);
        },

        apply(data) {
            this.myReg         = data.myRegistration;
            this.registrations = data.registrations;
        },

        async post(url, fields) {
            this.loading = true;
            try {
                const fd = new FormData();
                Object.entries(fields).forEach(([k, v]) => {
                    if (Array.isArray(v)) v.forEach(item => fd.append(k + '[]', item));
                    else fd.append(k, v);
                });
                const res = await fetch(url, {
                    method:  'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body:    fd,
                });
                return await res.json();
            } catch {
                return { ok: false, error: 'Erreur réseau' };
            } finally {
                this.loading = false;
            }
        },

        async submitRegister() {
            const data = await this.post(cfg.registerUrl, {
                _token:      cfg.registerToken,
                disciplines: this.disciplinesForSubmit,
            });
            if (data.ok) {
                this.apply(data);
                this.modalOpen = false;
                this.showToast('Inscription enregistrée ✓');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },

        async unregister() {
            if (!confirm('Annuler ton inscription ?')) return;
            const data = await this.post(cfg.unregisterUrl, { _token: cfg.unregToken });
            if (data.ok) {
                this.apply(data);
                this.showToast('Inscription annulée.');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },

        async unregisterAny(regId, token) {
            if (!confirm('Retirer cet athlète ?')) return;
            const url  = cfg.unregAnyBase.replace(/\/0$/, '/' + regId);
            const data = await this.post(url, { _token: token });
            if (data.ok) {
                this.apply(data);
                this.showToast('Inscription retirée.');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },
    };
}
</script>
{% endblock %}
