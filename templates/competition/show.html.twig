{% extends 'base.html.twig' %}
{% block title %}{{ competition.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar', {month: competition.date|date('n'), year: competition.date|date('Y')}) }}">Compétitions</a>
    <span class="sep">/</span>
    <span class="current">{{ competition.title }}</span>
{% endblock %}

{% block body %}

{% set disciplineLabelsJson = {} %}
{% for code, label in disciplineLabels %}
    {% set disciplineLabelsJson = disciplineLabelsJson|merge({(code): label}) %}
{% endfor %}
{% set myRegInit = myRegistration ? {id: myRegistration.id, disciplines: myRegistration.disciplines} : null %}

<div style="display:flex;flex-direction:column;gap:20px;"
     x-data="competitionPage({
         registerUrl:      '{{ path('app_competition_register',      {id: competition.id}) }}',
         unregisterUrl:    '{{ path('app_competition_unregister',    {id: competition.id}) }}',
         unregAnyBase:     '{{ path('app_competition_unregister_any',{id: competition.id, registrationId: 0}) }}',
         registerToken:    '{{ csrf_token('register-competition-' ~ competition.id) }}',
         unregToken:       '{{ csrf_token('unregister-competition-' ~ competition.id) }}',
         myReg:            {{ myRegInit|json_encode }},
         registrations:    {{ registrationsData|json_encode }},
         disciplineLabels: {{ disciplineLabelsJson|json_encode }},
         canRegister:      {{ canRegister ? 'true' : 'false' }},
     })">

{# ── Header ─────────────────────────────────────────────────────────── #}
<div class="card" style="overflow:hidden;">
    <div style="height:3px;background:{{ competition.colorBg }};"></div>
    <div class="card-body">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:16px;">

            {# Gauche : titre, badges, méta #}
            <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                    {% if competition.competitionType %}
                        <span style="font-size:11px;font-weight:600;padding:4px 10px;border-radius:99px;background:{{ competition.colorBg }}22;color:{{ competition.colorBg }};border:1px solid {{ competition.colorBg }}44;">
                            {{ competition.typeLabel }}
                        </span>
                    {% endif %}
                    {% if competition.isPast() %}
                        <span class="badge">Passée</span>
                    {% else %}
                        <span class="badge badge-green">À venir</span>
                    {% endif %}
                </div>
                <h1 style="font-size:22px;font-weight:700;color:var(--text-1);margin:0 0 10px;">{{ competition.title }}</h1>
                <div style="display:flex;flex-wrap:wrap;align-items:center;gap:16px;font-size:13px;color:var(--text-2);">
                    <span style="display:flex;align-items:center;gap:6px;">
                        <svg width="14" height="14" fill="none" stroke="var(--text-3)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        {{ competition.date|date_fr('l d F Y')|capitalize }}
                    </span>
                    {% if competition.location %}
                    <span style="display:flex;align-items:center;gap:6px;">
                        <svg width="14" height="14" fill="none" stroke="var(--text-3)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {{ competition.location }}
                    </span>
                    {% endif %}
                </div>
            </div>

            {# Droite : actions #}
            {% if canEdit %}
            <div style="display:flex;gap:8px;flex-shrink:0;">
                <a href="{{ path('app_competition_edit', {id: competition.id}) }}" class="btn btn-secondary btn-sm">
                    <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Modifier
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <form action="{{ path('app_competition_delete', {id: competition.id}) }}" method="post" data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-competition' ~ competition.id) }}">
                    <button type="submit" onclick="return confirm('Supprimer cette compétition ?')" class="btn btn-danger btn-sm">
                        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Supprimer
                    </button>
                </form>
                {% endif %}
            </div>
            {% endif %}
        </div>

        {# Stats rapides #}
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:20px;padding-top:20px;border-top:1px solid var(--border);">
            <div>
                <p class="section-title" x-text="registrations.length">{{ registrationsData|length }}</p>
                <p style="font-size:13px;color:var(--text-2);margin:4px 0 0;">Inscrit{{ registrationsData|length > 1 ? 's' : '' }}</p>
            </div>
            <div>
                <p class="section-title">{{ competition.documentFilename ? '1' : '—' }}</p>
                <p style="font-size:13px;color:var(--text-2);margin:4px 0 0;">Circulaire</p>
            </div>
            <div>
                <p style="font-size:20px;font-weight:700;margin:0;color:{{ competition.colorBg }};">
                    {{ competition.isPast() ? 'Terminée' : 'À venir' }}
                </p>
                <p style="font-size:13px;color:var(--text-2);margin:4px 0 0;">Statut</p>
            </div>
        </div>
    </div>
</div>

{# ── Barre d'onglets ─────────────────────────────────────────────────── #}
<div class="tf-tabs">
    <button @click="activeTab = 'infos'"
            class="tf-tab"
            :class="activeTab === 'infos' ? 'active' : ''">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Infos pratiques
    </button>
    <button @click="activeTab = 'inscriptions'"
            class="tf-tab"
            :class="activeTab === 'inscriptions' ? 'active' : ''">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Inscriptions
        <span style="font-size:11px;font-weight:600;padding:2px 6px;border-radius:99px;transition:background .15s,color .15s;"
              :style="activeTab === 'inscriptions' ? 'background:rgba(255,255,255,.15);color:var(--text-1)' : 'background:var(--bg-2);color:var(--text-3)'"
              x-text="registrations.length"></span>
    </button>
</div>

{# ── Onglet Infos ────────────────────────────────────────────────────── #}
<div x-show="activeTab === 'infos'" x-transition style="display:flex;flex-direction:column;gap:20px;">

    {# Liens #}
    <div class="card card-body" style="display:flex;flex-direction:column;gap:20px;">
        <h2 style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0;">Ressources</h2>

        <div style="display:flex;align-items:center;gap:16px;">
            <div style="width:36px;height:36px;border-radius:10px;background:var(--bg-2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="14" height="14" fill="none" stroke="var(--text-2)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </div>
            <div style="flex:1;min-width:0;">
                <p style="font-size:11px;color:var(--text-3);margin:0 0 3px;">Site officiel</p>
                {% if competition.websiteUrl %}
                    <a href="{{ competition.websiteUrl }}" target="_blank" rel="noopener noreferrer"
                       style="font-size:13px;color:#fbbf24;text-decoration:none;word-break:break-all;transition:opacity .15s;"
                       onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">{{ competition.websiteUrl }}</a>
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       style="font-size:13px;color:var(--text-3);text-decoration:none;transition:color .15s;"
                       onmouseover="this.style.color='var(--text-2)'" onmouseout="this.style.color='var(--text-3)'">Ajouter un lien →</a>
                {% else %}
                    <span style="font-size:13px;color:var(--text-3);">Non renseigné</span>
                {% endif %}
            </div>
        </div>

        <div style="display:flex;align-items:center;gap:16px;">
            <div style="width:36px;height:36px;border-radius:10px;background:var(--bg-2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="14" height="14" fill="none" stroke="var(--text-2)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div style="flex:1;">
                <p style="font-size:11px;color:var(--text-3);margin:0 0 3px;">Circulaire</p>
                {% if competition.documentFilename %}
                    <a href="{{ path('app_competition_document', {id: competition.id}) }}"
                       style="display:inline-flex;align-items:center;gap:8px;font-size:13px;color:#fbbf24;text-decoration:none;transition:opacity .15s;"
                       onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                        Télécharger la circulaire
                    </a>
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       style="font-size:13px;color:var(--text-3);text-decoration:none;transition:color .15s;"
                       onmouseover="this.style.color='var(--text-2)'" onmouseout="this.style.color='var(--text-3)'">Ajouter une circulaire →</a>
                {% else %}
                    <span style="font-size:13px;color:var(--text-3);">Non disponible</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# Notes #}
    <div class="card" style="overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;display:flex;align-items:center;gap:8px;">
                <svg width="14" height="14" fill="none" stroke="var(--text-3)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Notes
            </h2>
            {% if canEdit %}
            <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
               style="font-size:12px;color:var(--text-3);text-decoration:none;transition:color .15s;"
               onmouseover="this.style.color='var(--text-2)'" onmouseout="this.style.color='var(--text-3)'">Modifier</a>
            {% endif %}
        </div>
        <div style="padding:20px;">
            {% if competition.description %}
                <pre style="color:var(--text-2);font-size:13px;line-height:1.7;white-space:pre-wrap;font-family:inherit;margin:0;">{{ competition.description }}</pre>
            {% else %}
                <div class="empty-state" style="padding:24px 20px;">
                    <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p>Aucune note pour l'instant.</p>
                    {% if canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       style="font-size:12px;color:#fbbf24;text-decoration:none;margin-top:6px;display:inline-block;">Ajouter des notes →</a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

</div>

{# ── Onglet Inscriptions ─────────────────────────────────────────────── #}
<div x-show="activeTab === 'inscriptions'" x-transition style="display:flex;flex-direction:column;gap:16px;">

    {# Toast #}
    <div x-show="toast"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-end="opacity-0"
         :style="toastError ? 'background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171' : 'background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.25);color:#34d399'"
         style="padding:12px 16px;border-radius:12px;font-size:13px;font-weight:500;display:none;"
         x-text="toast"></div>

    {# Mon inscription #}
    <div class="card" style="overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;">Mon inscription</h2>
        </div>
        <div style="padding:20px;">

            {# Inscrit #}
            <template x-if="myReg">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div style="display:flex;align-items:flex-start;gap:16px;padding:16px;border-radius:12px;background:{{ competition.colorBg }}0d;border:1px solid {{ competition.colorBg }}28;">
                        <div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:{{ competition.colorBg }}22;">
                            <svg width="14" height="14" fill="none" stroke="{{ competition.colorBg }}" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div style="flex:1;">
                            <p style="font-size:13px;font-weight:600;color:var(--text-1);margin:0 0 8px;">Tu es inscrit</p>
                            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                                <template x-for="d in myReg.disciplines" :key="d">
                                    <span style="display:inline-flex;align-items:center;font-size:13px;font-weight:500;padding:4px 10px;border-radius:8px;background:{{ competition.colorBg }}18;color:{{ competition.colorBg }};border:1px solid {{ competition.colorBg }}35;"
                                          x-text="disciplineLabels[d] || d"></span>
                                </template>
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;">
                        <button @click="openModal()" class="btn btn-secondary">
                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Modifier les disciplines
                        </button>
                        <button @click="unregister()" :disabled="loading" class="btn btn-danger">
                            <svg x-show="loading" width="14" height="14" fill="none" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity:.25"/><path fill="currentColor" d="M4 12a8 8 0 018-8v8z" style="opacity:.75"/></svg>
                            Annuler l'inscription
                        </button>
                    </div>
                </div>
            </template>

            {# Non inscrit, peut s'inscrire #}
            <template x-if="!myReg && canRegister">
                <div style="text-align:center;padding:16px 0;">
                    <p style="font-size:13px;color:var(--text-2);margin:0 0 16px;">Tu n'es pas encore inscrit à cette compétition.</p>
                    <button @click="openModal()"
                            style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px;border-radius:12px;font-size:13px;font-weight:600;color:#fff;border:none;cursor:pointer;transition:opacity .15s;background:{{ competition.colorBg }};"
                            onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        S'inscrire
                    </button>
                </div>
            </template>

            {# Compétition passée ou pas de profil #}
            <template x-if="!myReg && !canRegister">
                <div style="text-align:center;padding:16px 0;">
                    <p style="font-size:13px;color:var(--text-3);">
                        {{ competition.isPast() ? 'Cette compétition est terminée.' : 'Associez un profil athlète pour vous inscrire.' }}
                    </p>
                </div>
            </template>
        </div>
    </div>

    {# Liste des inscrits #}
    <div class="card" style="overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;">Liste des inscrits</h2>
            <span class="badge"
                  x-text="registrations.length + ' inscrit' + (registrations.length > 1 ? 's' : '')">
                {{ registrationsData|length }} inscrit{{ registrationsData|length > 1 ? 's' : '' }}
            </span>
        </div>

        <template x-if="registrations.length === 0">
            <div class="empty-state" style="padding:40px;">
                <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <p>Aucune inscription pour l'instant.</p>
            </div>
        </template>

        <div>
            <template x-for="reg in registrations" :key="reg.id">
                <div style="padding:16px 20px;display:flex;align-items:center;gap:16px;border-bottom:1px solid var(--border);transition:background .15s;"
                     :style="reg.isOwn ? 'background:rgba(var(--accent-rgb),.05)' : ''"
                     onmouseover="if(!this._own)this.style.background='var(--bg-hover)'"
                     onmouseout="if(!this._own)this.style.background=''">

                    {# Avatar #}
                    <template x-if="reg.athletePhoto">
                        <img :src="'/uploads/athletes/' + reg.athletePhoto"
                             style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0;">
                    </template>
                    <template x-if="!reg.athletePhoto">
                        <div class="avatar"
                             style="background:var(--bg-2);border:1px solid var(--border);color:var(--text-2);font-size:12px;font-weight:700;flex-shrink:0;"
                             x-text="reg.athleteName.split(' ').map(p => p[0] || '').join('').slice(0,2).toUpperCase()"></div>
                    </template>

                    {# Nom + disciplines #}
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                            <span style="font-size:13px;font-weight:600;color:var(--text-1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" x-text="reg.athleteName"></span>
                            <template x-if="reg.isOwn">
                                <span style="font-size:11px;padding:2px 6px;border-radius:6px;font-weight:600;flex-shrink:0;background:{{ competition.colorBg }}20;color:{{ competition.colorBg }};">Toi</span>
                            </template>
                        </div>
                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                            <template x-for="d in reg.disciplines" :key="d">
                                <span style="font-size:11px;padding:2px 8px;border-radius:6px;font-weight:500;background:var(--bg-2);color:var(--text-2);border:1px solid var(--border);"
                                      x-text="disciplineLabels[d] || d"></span>
                            </template>
                        </div>
                    </div>

                    {# Bouton retirer #}
                    <template x-if="reg.canRemove">
                        <button @click="unregisterAny(reg.id, reg.unregToken)"
                                :disabled="loading"
                                title="Retirer l'inscription"
                                class="btn btn-sm"
                                style="color:var(--text-3);border:1px solid var(--border);flex-shrink:0;transition:all .15s;"
                                onmouseover="this.style.color='#f87171';this.style.borderColor='rgba(239,68,68,.4)';this.style.background='rgba(239,68,68,.1)'"
                                onmouseout="this.style.color='var(--text-3)';this.style.borderColor='var(--border)';this.style.background=''">
                            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            Retirer
                        </button>
                    </template>
                </div>
            </template>
        </div>
    </div>

</div>

{# ── Modal disciplines ───────────────────────────────────────────────── #}
<div x-show="modalOpen"
     x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150" x-transition:leave-end="opacity-0"
     class="modal-backdrop"
     @click.self="modalOpen = false" style="display:none;">

    <div class="modal" style="max-width:540px;display:flex;flex-direction:column;max-height:88vh;" @click.stop>

        <div class="modal-header" style="flex-shrink:0;">
            <div>
                <h3 class="modal-title">Choisir les disciplines</h3>
                <p style="font-size:12px;color:var(--text-3);margin:3px 0 0;">{{ competition.title }}</p>
            </div>
            <button @click="modalOpen = false" class="btn btn-ghost btn-sm" style="padding:6px;">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div style="overflow-y:auto;flex:1;padding:20px;display:flex;flex-direction:column;gap:20px;">
            {% for groupName, codes in disciplineGroups %}
            <div>
                <p style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 10px;">{{ groupName }}</p>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    {% for code in codes %}
                    {% set label = disciplineLabels[code] ?? code %}
                    <button type="button"
                            @click="toggleDisc('{{ code }}')"
                            style="padding:6px 14px;border-radius:8px;font-size:13px;font-weight:500;transition:all .15s;cursor:pointer;"
                            :style="selected.includes('{{ code }}')
                                ? 'background:{{ competition.colorBg }}25;border:1px solid {{ competition.colorBg }};color:{{ competition.colorBg }}'
                                : 'background:var(--bg-2);border:1px solid var(--border);color:var(--text-2)'">
                        {{ label|capitalize }}
                    </button>
                    {% endfor %}
                </div>
                {% if groupName == 'Autre' %}
                <div x-show="selected.includes('autre')" x-transition style="margin-top:10px;display:none;">
                    <textarea x-model="autreText" placeholder="Précise la discipline…" rows="2"
                              class="form-input" style="resize:none;"></textarea>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <div style="padding:16px 20px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-shrink:0;">
            <span style="font-size:13px;color:var(--text-2);">
                <span style="font-weight:600;color:var(--text-1);" x-text="selected.length"></span>
                <span x-text="selected.length > 1 ? ' disciplines' : ' discipline'"></span>
            </span>
            <button @click="submitRegister()"
                    :disabled="selected.length === 0 || loading"
                    style="display:flex;align-items:center;gap:8px;padding:10px 24px;border-radius:12px;font-size:13px;font-weight:700;color:#fff;border:none;cursor:pointer;transition:opacity .15s;background:{{ competition.colorBg }};"
                    :style="(selected.length === 0 || loading) ? 'opacity:.4;cursor:not-allowed' : ''"
                    onmouseover="if(this.style.opacity !== '0.4')this.style.filter='brightness(.9)'"
                    onmouseout="this.style.filter=''">
                <svg x-show="loading" width="14" height="14" fill="none" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity:.25"/><path fill="currentColor" d="M4 12a8 8 0 018-8v8z" style="opacity:.75"/></svg>
                <span x-text="myReg ? 'Mettre à jour' : 'Confirmer l\'inscription'"></span>
            </button>
        </div>
    </div>
</div>

</div>{# /x-data #}

<script>
function competitionPage(cfg) {
    return {
        activeTab:        'infos',
        myReg:            cfg.myReg,
        registrations:    cfg.registrations,
        disciplineLabels: cfg.disciplineLabels,
        canRegister:      cfg.canRegister,

        modalOpen: false,
        selected:  [],
        autreText: '',

        loading:     false,
        toast:       '',
        toastError:  false,
        _toastTimer: null,

        openModal() {
            this.selected  = this.myReg ? [...this.myReg.disciplines] : [];
            this.autreText = '';
            this.modalOpen = true;
        },

        toggleDisc(code) {
            const i = this.selected.indexOf(code);
            i >= 0 ? this.selected.splice(i, 1) : this.selected.push(code);
        },

        get disciplinesForSubmit() {
            return this.selected.map(d => d === 'autre' ? (this.autreText.trim() || 'autre') : d);
        },

        showToast(msg, isError = false) {
            this.toast      = msg;
            this.toastError = isError;
            clearTimeout(this._toastTimer);
            this._toastTimer = setTimeout(() => this.toast = '', 3500);
        },

        apply(data) {
            this.myReg         = data.myRegistration;
            this.registrations = data.registrations;
        },

        async post(url, fields) {
            this.loading = true;
            try {
                const fd = new FormData();
                Object.entries(fields).forEach(([k, v]) => {
                    if (Array.isArray(v)) v.forEach(item => fd.append(k + '[]', item));
                    else fd.append(k, v);
                });
                const res = await fetch(url, {
                    method:  'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body:    fd,
                });
                return await res.json();
            } catch {
                return { ok: false, error: 'Erreur réseau' };
            } finally {
                this.loading = false;
            }
        },

        async submitRegister() {
            const data = await this.post(cfg.registerUrl, {
                _token:      cfg.registerToken,
                disciplines: this.disciplinesForSubmit,
            });
            if (data.ok) {
                this.apply(data);
                this.modalOpen = false;
                this.showToast('Inscription enregistrée ✓');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },

        async unregister() {
            if (!confirm('Annuler ton inscription ?')) return;
            const data = await this.post(cfg.unregisterUrl, { _token: cfg.unregToken });
            if (data.ok) {
                this.apply(data);
                this.showToast('Inscription annulée.');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },

        async unregisterAny(regId, token) {
            if (!confirm('Retirer cet athlète ?')) return;
            const url  = cfg.unregAnyBase.replace(/\/0$/, '/' + regId);
            const data = await this.post(url, { _token: token });
            if (data.ok) {
                this.apply(data);
                this.showToast('Inscription retirée.');
            } else {
                this.showToast(data.error || 'Une erreur est survenue.', true);
            }
        },
    };
}
</script>
{% endblock %}
