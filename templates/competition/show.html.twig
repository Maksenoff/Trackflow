{% extends 'base.html.twig' %}
{% block title %}{{ competition.title }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar', {month: competition.date|date('n'), year: competition.date|date('Y')}) }}" class="hover:text-white transition-colors">Compétitions</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">{{ competition.title }}</span>
{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto space-y-6">

    {# Header card #}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <div class="h-2" style="background: {{ competition.colorBg }}"></div>
        <div class="p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        {% if competition.competitionType %}
                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full"
                                  style="background: {{ competition.colorBg }}22; color: {{ competition.colorBg }}; border: 1px solid {{ competition.colorBg }}44">
                                {{ competition.typeLabel }}
                            </span>
                        {% endif %}
                        {% if competition.isPast %}
                            <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">Passée</span>
                        {% else %}
                            <span class="text-xs text-emerald-400 bg-emerald-900/30 border border-emerald-800/50 px-2 py-0.5 rounded-full">À venir</span>
                        {% endif %}
                    </div>
                    <h1 class="text-2xl font-bold text-white">{{ competition.title }}</h1>
                    <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-gray-400">
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {{ competition.date|date('l d F Y')|capitalize }}
                        </span>
                        {% if competition.location %}
                            <span class="flex items-center gap-1.5">
                                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {{ competition.location }}
                            </span>
                        {% endif %}
                    </div>
                </div>
                {% if canEdit %}
                <div class="flex gap-2 shrink-0">
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       class="flex items-center gap-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Modifier
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <form action="{{ path('app_competition_delete', {id: competition.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-competition' ~ competition.id) }}">
                        <button type="submit" onclick="return confirm('Supprimer cette compétition ?')"
                                class="flex items-center gap-1.5 bg-gray-800 hover:bg-red-900/40 hover:text-red-400 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            Supprimer
                        </button>
                    </form>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Infos pratiques #}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 space-y-4">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Infos pratiques</h2>

        {# Site officiel #}
        <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            <div class="flex-1">
                <p class="text-xs text-gray-500 mb-0.5">Site officiel</p>
                {% if competition.websiteUrl %}
                    <a href="{{ competition.websiteUrl }}" target="_blank" rel="noopener noreferrer"
                       class="text-sm text-amber-400 hover:text-amber-300 break-all">
                        {{ competition.websiteUrl }}
                    </a>
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       class="text-sm text-gray-600 hover:text-gray-400 transition-colors">Ajouter un lien →</a>
                {% else %}
                    <span class="text-sm text-gray-600">Non renseigné</span>
                {% endif %}
            </div>
        </div>

        {# Circulaire #}
        <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <div class="flex-1">
                <p class="text-xs text-gray-500 mb-0.5">Circulaire</p>
                {% if competition.documentFilename %}
                    <a href="{{ path('app_competition_document', {id: competition.id}) }}"
                       class="inline-flex items-center gap-2 text-sm text-amber-400 hover:text-amber-300 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                        Télécharger la circulaire
                    </a>
                    {% if canEdit %}
                        <span class="text-xs text-gray-600 ml-2">(remplacer via <a href="{{ path('app_competition_edit', {id: competition.id}) }}" class="hover:text-gray-400">Modifier</a>)</span>
                    {% endif %}
                {% elseif canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       class="text-sm text-gray-600 hover:text-gray-400 transition-colors">Ajouter une circulaire →</a>
                {% else %}
                    <span class="text-sm text-gray-600">Non disponible</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# Notes #}
    {% if competition.description or canEdit %}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Notes
            </h2>
        </div>
        <div class="p-6">
            {% if competition.description %}
                <pre class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap font-sans">{{ competition.description }}</pre>
            {% else %}
                <div class="text-center py-6">
                    <p class="text-gray-500 text-sm">Aucune note.</p>
                    {% if canEdit %}
                    <a href="{{ path('app_competition_edit', {id: competition.id}) }}"
                       class="inline-block mt-2 text-xs text-amber-400 hover:text-amber-300 transition-colors">
                        Ajouter des notes →
                    </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# ── Inscription ─────────────────────────────────────────────────── #}
    {% if canRegister %}
    {% set knownCodes = disciplineLabels|keys %}
    {% set selectedInit = [] %}
    {% set autreInit = '' %}
    {% for d in (myRegistration ? myRegistration.disciplines : []) %}
        {% if d in knownCodes %}{% set selectedInit = selectedInit|merge([d]) %}
        {% else %}{% set autreInit = d %}{% set selectedInit = selectedInit|merge(['autre']) %}
        {% endif %}
    {% endfor %}

    <div x-data="{
        open: false,
        selected: {{ selectedInit|json_encode }},
        autreText: {{ autreInit|json_encode }},
        toggle(d) { const i = this.selected.indexOf(d); i >= 0 ? this.selected.splice(i,1) : this.selected.push(d); },
        isSelected(d) { return this.selected.includes(d); },
        get disciplinesForSubmit() { return this.selected.map(d => d==='autre' ? (this.autreText.trim()||'autre') : d); }
    }">

        {# Bannière statut inscription #}
        {% if myRegistration %}
        <div class="rounded-xl px-5 py-5 flex items-center justify-between" style="margin-top:2rem; background-color:rgba(6,78,59,0.2); border:1px solid rgba(6,78,59,0.5); padding-top:1.5rem; padding-bottom:1.5rem">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-emerald-900/50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-emerald-300">Tu es inscrit{{ app.user.linkedAthlete and app.user.linkedAthlete.gender == 'F' ? 'e' : '' }}</p>
                    <p class="text-xs text-emerald-500 mt-0.5">
                        {% for disc in myRegistration.disciplines %}{{ (disciplineLabels[disc] ?? disc)|capitalize }}{% if not loop.last %}, {% endif %}{% endfor %}
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button @click="open = true"
                        class="px-3 py-1.5 rounded-lg text-xs font-medium text-gray-300 bg-gray-800 hover:bg-gray-700 transition-colors">
                    Modifier
                </button>
                <form action="{{ path('app_competition_unregister', {id: competition.id}) }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('unregister-competition-' ~ competition.id) }}">
                    <button type="submit" onclick="return confirm('Annuler ton inscription ?')"
                            class="px-3 py-1.5 rounded-lg text-xs font-medium text-red-400 bg-red-900/20 hover:bg-red-900/40 border border-red-800/40 transition-colors">
                        Annuler
                    </button>
                </form>
            </div>
        </div>
        {% else %}
        <button @click="open = true"
                class="w-full flex items-center justify-center gap-2 py-3 rounded-xl font-semibold text-sm transition-colors"
                style="background-color: {{ competition.colorBg }}18; color: {{ competition.colorBg }}; border: 1px solid {{ competition.colorBg }}44">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            S'inscrire à cette compétition
        </button>
        {% endif %}

        {# ── Modal ── #}
        <div x-show="open"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black/60 backdrop-blur-sm"
             @click.self="open = false">

            <div x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="translate-y-4 opacity-0"
                 x-transition:enter-end="translate-y-0 opacity-100"
                 class="bg-gray-900 border border-gray-700/80 rounded-t-2xl sm:rounded-2xl w-full sm:max-w-lg flex flex-col"
                 style="max-height: 90vh"
                 @click.stop>

                {# Header modal #}
                <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
                    <div>
                        <h3 class="text-base font-bold text-white">Choisis tes disciplines</h3>
                        <p class="text-xs text-gray-500 mt-0.5">{{ competition.title }}</p>
                    </div>
                    <button @click="open = false"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-500 hover:text-white hover:bg-gray-800 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>

                {# Corps scrollable #}
                <div class="overflow-y-auto flex-1 px-6 py-4 space-y-5">
                    {% for groupName, codes in disciplineGroups %}
                    <div>
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">{{ groupName }}</p>
                        <div class="flex flex-wrap gap-2">
                            {% for code in codes %}
                            {% set label = disciplineLabels[code] ?? code %}
                            <button type="button"
                                    @click="toggle('{{ code }}')"
                                    class="px-3 py-1.5 rounded-lg text-sm font-medium transition-all border"
                                    :class="isSelected('{{ code }}') ? 'text-white border-transparent' : 'text-gray-400 border-gray-700 hover:border-gray-500 hover:text-gray-200'"
                                    :style="isSelected('{{ code }}') ? 'background-color:{{ competition.colorBg }}33; border-color:{{ competition.colorBg }}; color:{{ competition.colorBg }}' : ''">
                                {{ label|capitalize }}
                            </button>
                            {% endfor %}
                        </div>
                        {% if groupName == 'Autre' %}
                        <div x-show="isSelected('autre')" x-transition class="mt-2">
                            <textarea x-model="autreText"
                                      placeholder="Précise la discipline..."
                                      rows="2"
                                      class="w-full bg-gray-800 border border-gray-700 focus:border-indigo-500 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-500 outline-none resize-none transition-colors"></textarea>
                        </div>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>

                {# Footer modal #}
                <form action="{{ path('app_competition_register', {id: competition.id}) }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('register-competition-' ~ competition.id) }}">
                    <template x-for="d in disciplinesForSubmit" :key="d">
                        <input type="hidden" name="disciplines[]" :value="d">
                    </template>
                    <div class="px-6 py-4 border-t border-gray-800 flex items-center justify-between gap-4">
                        <span class="text-sm text-gray-400">
                            <span x-text="selected.length" class="font-semibold text-white"></span>
                            discipline<span x-show="selected.length > 1">s</span> sélectionnée<span x-show="selected.length > 1">s</span>
                        </span>
                        <button type="submit"
                                :disabled="selected.length === 0"
                                class="px-6 py-2.5 rounded-xl text-sm font-bold text-white disabled:opacity-40 disabled:cursor-not-allowed transition-all"
                                style="background-color: {{ competition.colorBg }}">
                            Confirmer l'inscription
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    {# ── Liste des inscrits ───────────────────────────────────────────── #}
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white">
                Inscrits
                <span class="ml-2 text-xs font-normal text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">{{ registrations|length }}</span>
            </h2>
        </div>
        {% if registrations is empty %}
            <div class="px-6 py-10 text-center">
                <p class="text-gray-500 text-sm">Aucune inscription pour l'instant.</p>
            </div>
        {% else %}
            <div class="divide-y divide-gray-800/60">
                {% for reg in registrations %}
                {% set isOwn = myRegistration and myRegistration.id == reg.id %}
                <div class="px-6 py-4 flex items-center gap-4 {{ isOwn ? 'bg-gray-800/30' : '' }}">

                    {# Avatar #}
                    {% if reg.athlete.photo %}
                        <img src="/uploads/athletes/{{ reg.athlete.photo }}"
                             class="w-9 h-9 rounded-full object-cover shrink-0">
                    {% else %}
                        <div class="w-9 h-9 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400 shrink-0">
                            {{ reg.athlete.firstName|slice(0,1) }}{{ reg.athlete.lastName|slice(0,1) }}
                        </div>
                    {% endif %}

                    {# Nom + badge "Toi" #}
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-semibold text-white">{{ reg.athlete.fullName }}</span>
                            {% if isOwn %}
                                <span class="text-xs px-1.5 py-0.5 rounded font-medium"
                                      style="background-color: {{ competition.colorBg }}22; color: {{ competition.colorBg }}">Toi</span>
                            {% endif %}
                        </div>
                        <div class="flex flex-wrap gap-1.5 mt-1.5">
                            {% for disc in reg.disciplines %}
                                <span class="text-xs px-2 py-0.5 rounded-md font-medium bg-gray-800 text-gray-300 border border-gray-700">
                                    {{ (disciplineLabels[disc] ?? disc)|capitalize }}
                                </span>
                            {% endfor %}
                        </div>
                    </div>

                    {# Actions #}
                    {% if isOwn or is_granted('ROLE_COACH') %}
                    <form action="{{ path('app_competition_unregister_any', {id: competition.id, registrationId: reg.id}) }}" method="post" class="shrink-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('unregister-any-' ~ reg.id) }}">
                        <button type="submit"
                                onclick="return confirm('Annuler l\'inscription de {{ reg.athlete.firstName }} ?')"
                                class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-gray-400 border border-gray-700 hover:text-red-400 hover:border-red-800/60 hover:bg-red-900/20 transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            Retirer
                        </button>
                    </form>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
