{# ══════════════════════════════════════
   SCRIPTS GLOBAUX
══════════════════════════════════════ #}
<script>
const TF = {
    /* ── Theme ── */
    toggleTheme() {
        const html = document.documentElement;
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('tf-theme', next);
    },
    initTheme() {
        const saved = localStorage.getItem('tf-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', saved);
    },

    /* ── Tiroir profil mobile ── */
    toggleProfileDrawer() {
        const drawer  = document.getElementById('tf-profile-drawer');
        const overlay = document.getElementById('tf-profile-overlay');
        const isOpen  = drawer.classList.contains('open');
        drawer.classList.toggle('open', !isOpen);
        overlay.classList.toggle('show', !isOpen);
    },
    closeProfileDrawer() {
        document.getElementById('tf-profile-drawer')?.classList.remove('open');
        document.getElementById('tf-profile-overlay')?.classList.remove('show');
    },

    /* ── Sidebar mobile ── */
    toggleSidebar() {
        const sidebar = document.getElementById('tf-sidebar');
        const overlay = document.getElementById('tf-overlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('show');
    },
    closeSidebar() {
        document.getElementById('tf-sidebar').classList.remove('open');
        document.getElementById('tf-overlay').classList.remove('show');
    },

    /* ── Page transitions ── */
    initTransitions() {
        // Première entrée : compléter la barre si elle existe
        const barInit = document.getElementById('tf-transition');
        if (barInit) requestAnimationFrame(() => barInit.classList.add('complete'));

        // Avant chaque navigation Turbo : lancer la barre + fade-out
        // On re-requête les éléments à chaque fois (la page source peut être
        // une page standalone sans #tf-transition, ex. la page login)
        document.addEventListener('turbo:before-visit', () => {
            const bar     = document.getElementById('tf-transition');
            const content = document.getElementById('tf-content');
            if (!bar) return;
            bar.style.transition = 'none';
            bar.className        = '';
            bar.style.transform  = 'scaleX(0)';
            bar.style.opacity    = '1';
            void bar.offsetWidth;
            bar.style.transition = '';
            bar.classList.add('loading');
            if (content) content.classList.add('exiting');
        });

        // Après chaque navigation Turbo : compléter la barre + fade-in
        document.addEventListener('turbo:load', () => {
            const bar     = document.getElementById('tf-transition');
            const content = document.getElementById('tf-content');
            if (bar) bar.classList.add('complete');
            if (content) content.classList.remove('exiting');
        });
    },

    /* ── Stagger animations ── */
    initStagger() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.05 });

        document.querySelectorAll('[data-stagger]').forEach(el => observer.observe(el));
    },

    /* ── Count-up animation ── */
    initCountUp() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                const el = entry.target;
                const end = parseFloat(el.dataset.count);
                const dec = (el.dataset.count.split('.')[1] || '').length;
                const duration = 1000;
                const start = performance.now();
                const step = (now) => {
                    const progress = Math.min((now - start) / duration, 1);
                    const ease = 1 - Math.pow(1 - progress, 3);
                    el.textContent = (end * ease).toFixed(dec);
                    if (progress < 1) requestAnimationFrame(step);
                };
                requestAnimationFrame(step);
                observer.unobserve(el);
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-count]').forEach(el => observer.observe(el));
    },

    /* ── Progress bars ── */
    initProgressBars() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                const fill = entry.target.querySelector('.progress-fill');
                if (fill) {
                    const target = fill.dataset.width || '0';
                    setTimeout(() => { fill.style.width = target + '%'; }, 100);
                }
                observer.unobserve(entry.target);
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.progress-bar').forEach(el => observer.observe(el));
    },

    /* ── Mobile sidebar nav links close ── */
    initNavLinks() {
        document.querySelectorAll('#tf-sidebar .tf-nav-link').forEach(link => {
            link.addEventListener('click', () => TF.closeSidebar());
        });
        document.getElementById('tf-overlay')?.addEventListener('click', () => TF.closeSidebar());
    },

    /* ── Swipe to dismiss ──────────────────────────────────────────────
       Ajoute le glissement tactile sur un élément panneau.
       direction : 'down' (tiroir bas→haut), 'left' (sidebar gauche)
       closeFn   : fonction appelée quand le seuil est atteint
    ──────────────────────────────────────────────────────────────────── */
    swipeDismiss(el, direction, closeFn) {
        let t0x, t0y, dragging = false;
        const isVertical = direction === 'down';

        el.addEventListener('touchstart', e => {
            // Ne pas démarrer si l'élément n'est pas visible/ouvert
            if (!el.classList.contains('open')) return;
            t0x = e.touches[0].clientX;
            t0y = e.touches[0].clientY;
            dragging = false;
            el.style.transition = 'none';
        }, { passive: true });

        el.addEventListener('touchmove', e => {
            if (!el.classList.contains('open')) return;
            const dx = e.touches[0].clientX - t0x;
            const dy = e.touches[0].clientY - t0y;
            const primary   = isVertical ? dy : dx;
            const secondary = isVertical ? dx : dy;

            // Confirmer la direction dominante
            if (!dragging && Math.abs(primary) > 8) {
                dragging = Math.abs(primary) > Math.abs(secondary);
            }
            if (!dragging) return;

            // N'appliquer que dans le sens du dismiss (bas ou gauche)
            const delta = isVertical ? Math.max(0, dy) : Math.min(0, dx);
            if (delta === 0) return;
            el.style.transform = isVertical
                ? `translateY(${delta}px)`
                : `translateX(${delta}px)`;
        }, { passive: true });

        el.addEventListener('touchend', e => {
            if (!dragging) { el.style.transition = ''; return; }
            const dx = e.changedTouches[0].clientX - t0x;
            const dy = e.changedTouches[0].clientY - t0y;
            const delta = isVertical ? dy : -dx; // positif = vers dismiss

            // Restaurer la transition CSS avant toute modification
            el.style.transition = '';
            el.style.transform  = '';

            if (delta > 80) {
                closeFn();
            }
            dragging = false;
        }, { passive: true });
    },

    initSwipeGestures() {
        // Tiroir profil : glisser vers le bas pour fermer
        const drawer = document.getElementById('tf-profile-drawer');
        if (drawer) this.swipeDismiss(drawer, 'down', () => this.closeProfileDrawer());

        // Sidebar mobile : glisser vers la gauche pour fermer
        const sidebar = document.getElementById('tf-sidebar');
        if (sidebar) this.swipeDismiss(sidebar, 'left', () => this.closeSidebar());
    },
};

// Setup unique (listeners enregistrés une seule fois)
document.addEventListener('DOMContentLoaded', () => {
    TF.initTheme();
    TF.initTransitions();
    TF.initSwipeGestures();
});

// Init par page — premier chargement ET chaque navigation Turbo
document.addEventListener('turbo:load', () => {
    TF.initStagger();
    TF.initCountUp();
    TF.initProgressBars();
    TF.initNavLinks();
});
</script>

{# ══════════════════════════════════════
   BOUTON FEEDBACK FLOTTANT
══════════════════════════════════════ #}
{% if is_granted('IS_AUTHENTICATED_FULLY') %}
<button id="tf-feedback-btn"
        onclick="TFFeedback.open()"
        title="Signaler un bug ou une suggestion"
        aria-label="Signaler un bug ou une suggestion"
        style="
            position:fixed;
            bottom:80px;
            right:18px;
            z-index:900;
            width:44px;
            height:44px;
            border-radius:50%;
            background:var(--accent);
            color:#fff;
            border:none;
            cursor:pointer;
            display:flex;
            align-items:center;
            justify-content:center;
            box-shadow:0 4px 16px rgba(0,0,0,.25);
            transition:transform .15s,box-shadow .15s;
        "
        onmouseenter="this.style.transform='scale(1.1)';this.style.boxShadow='0 6px 20px rgba(0,0,0,.35)'"
        onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 16px rgba(0,0,0,.25)'">
    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 8v4m0 4h.01M21 12c0 4.97-4.03 9-9 9a8.96 8.96 0 01-5.657-2.007L3 21l2.007-3.343A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z"/>
    </svg>
</button>

{# Overlay #}
<div id="tf-feedback-overlay"
     onclick="TFFeedback.close()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;"></div>

{# Modal #}
<div id="tf-feedback-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="tf-feedback-title"
     style="
         display:none;
         position:fixed;
         top:50%;
         left:50%;
         transform:translate(-50%,-50%) scale(.95);
         z-index:1001;
         width:min(480px,calc(100vw - 32px));
         background:var(--bg-card);
         border:1px solid var(--border);
         border-radius:var(--radius-lg,16px);
         padding:24px;
         box-shadow:0 20px 60px rgba(0,0,0,.3);
         transition:transform .2s,opacity .2s;
         opacity:0;
     ">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
        <h3 id="tf-feedback-title" style="margin:0;font-size:16px;font-weight:700;color:var(--text-1);">
            Signaler un problème ou une idée
        </h3>
        <button onclick="TFFeedback.close()"
                style="background:none;border:none;cursor:pointer;color:var(--text-3);padding:4px;border-radius:6px;line-height:0;"
                aria-label="Fermer">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <form id="tf-feedback-form" onsubmit="TFFeedback.submit(event)">
        {# Type #}
        <div style="display:flex;gap:8px;margin-bottom:16px;">
            <label style="flex:1;cursor:pointer;">
                <input type="radio" name="fb_type" value="bug" checked style="display:none;" id="fb-type-bug">
                <div class="tf-feedback-tab" data-for="fb-type-bug"
                     style="text-align:center;padding:10px;border-radius:10px;border:2px solid var(--accent);background:var(--accent);color:#fff;font-size:13px;font-weight:600;transition:all .15s;">
                    🐛 Bug
                </div>
            </label>
            <label style="flex:1;cursor:pointer;">
                <input type="radio" name="fb_type" value="suggestion" style="display:none;" id="fb-type-suggestion">
                <div class="tf-feedback-tab" data-for="fb-type-suggestion"
                     style="text-align:center;padding:10px;border-radius:10px;border:2px solid var(--border);color:var(--text-2);font-size:13px;font-weight:600;transition:all .15s;">
                    💡 Suggestion
                </div>
            </label>
        </div>

        {# Description #}
        <textarea name="fb_description"
                  id="tf-feedback-desc"
                  placeholder="Décris le problème ou l'idée… (page concernée, étapes pour reproduire, etc.)"
                  rows="5"
                  required
                  style="
                      width:100%;
                      box-sizing:border-box;
                      padding:12px;
                      border-radius:10px;
                      border:1.5px solid var(--border);
                      background:var(--bg);
                      color:var(--text-1);
                      font-size:14px;
                      resize:vertical;
                      font-family:inherit;
                      outline:none;
                      transition:border-color .15s;
                  "
                  onfocus="this.style.borderColor='var(--accent)'"
                  onblur="this.style.borderColor='var(--border)'"></textarea>

        <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:14px;">
            <button type="button" onclick="TFFeedback.close()"
                    style="padding:9px 18px;border-radius:8px;border:1.5px solid var(--border);background:none;color:var(--text-2);font-size:13px;cursor:pointer;font-weight:500;">
                Annuler
            </button>
            <button type="submit" id="tf-feedback-submit"
                    style="padding:9px 18px;border-radius:8px;border:none;background:var(--accent);color:#fff;font-size:13px;cursor:pointer;font-weight:600;display:flex;align-items:center;gap:6px;">
                <span id="tf-feedback-submit-text">Envoyer</span>
                <svg id="tf-feedback-spinner" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="display:none;animation:tf-spin 1s linear infinite;">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                </svg>
            </button>
        </div>
    </form>

    {# Message succès #}
    <div id="tf-feedback-success" style="display:none;text-align:center;padding:20px 0 8px;">
        <div style="font-size:36px;margin-bottom:10px;">✅</div>
        <p style="font-size:15px;font-weight:600;color:var(--text-1);margin:0 0 6px;">Merci !</p>
        <p style="font-size:13px;color:var(--text-3);margin:0;">Ton retour a bien été envoyé.</p>
    </div>
</div>

<style>
@keyframes tf-spin { to { transform: rotate(360deg); } }
</style>

<script>
const TFFeedback = {
    open() {
        const overlay = document.getElementById('tf-feedback-overlay');
        const modal   = document.getElementById('tf-feedback-modal');
        const form    = document.getElementById('tf-feedback-form');
        const success = document.getElementById('tf-feedback-success');

        form.style.display    = '';
        success.style.display = 'none';
        document.getElementById('tf-feedback-desc').value = '';
        // reset radio tabs
        document.querySelectorAll('.tf-feedback-tab').forEach(tab => {
            const forId = tab.dataset.for;
            const input = document.getElementById(forId);
            this._styleTab(tab, input && input.checked);
        });

        overlay.style.display = '';
        modal.style.display   = '';
        requestAnimationFrame(() => {
            modal.style.opacity   = '1';
            modal.style.transform = 'translate(-50%,-50%) scale(1)';
        });
        document.getElementById('tf-feedback-desc').focus();
        document.addEventListener('keydown', this._escHandler);
    },

    close() {
        const overlay = document.getElementById('tf-feedback-overlay');
        const modal   = document.getElementById('tf-feedback-modal');
        modal.style.opacity   = '0';
        modal.style.transform = 'translate(-50%,-50%) scale(.95)';
        setTimeout(() => {
            overlay.style.display = 'none';
            modal.style.display   = 'none';
        }, 180);
        document.removeEventListener('keydown', this._escHandler);
    },

    _escHandler(e) {
        if (e.key === 'Escape') TFFeedback.close();
    },

    _styleTab(el, active) {
        if (active) {
            el.style.background   = 'var(--accent)';
            el.style.borderColor  = 'var(--accent)';
            el.style.color        = '#fff';
        } else {
            el.style.background   = 'none';
            el.style.borderColor  = 'var(--border)';
            el.style.color        = 'var(--text-2)';
        }
    },

    async submit(e) {
        e.preventDefault();
        const form    = e.target;
        const btn     = document.getElementById('tf-feedback-submit');
        const spinner = document.getElementById('tf-feedback-spinner');
        const text    = document.getElementById('tf-feedback-submit-text');
        const desc    = document.getElementById('tf-feedback-desc').value.trim();
        const type    = form.fb_type.value;

        btn.disabled    = true;
        spinner.style.display = '';
        text.textContent = 'Envoi…';

        const body = new URLSearchParams({
            type,
            description: desc,
            page: window.location.pathname,
        });

        try {
            const res = await fetch('{{ path("app_feedback_report") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body,
            });
            const data = await res.json();

            if (data.success) {
                document.getElementById('tf-feedback-form').style.display    = 'none';
                document.getElementById('tf-feedback-success').style.display = '';
                setTimeout(() => TFFeedback.close(), 2200);
            } else {
                alert(data.message || 'Erreur lors de l\'envoi.');
            }
        } catch {
            alert('Erreur réseau, réessaie.');
        } finally {
            btn.disabled    = false;
            spinner.style.display = 'none';
            text.textContent = 'Envoyer';
        }
    },
};

// Gestion des onglets Bug / Suggestion
document.addEventListener('turbo:load', () => {
    document.querySelectorAll('input[name="fb_type"]').forEach(input => {
        input.addEventListener('change', () => {
            document.querySelectorAll('.tf-feedback-tab').forEach(tab => {
                const forId = tab.dataset.for;
                const rel = document.getElementById(forId);
                TFFeedback._styleTab(tab, rel && rel.checked);
            });
        });
    });
});
</script>
{% endif %}

</body>
</html>
