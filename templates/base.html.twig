<!DOCTYPE html>
<html lang="fr" data-theme="dark" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}TrackFlow{% endblock %} — TrackFlow</title>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    <style>
    /* ═══════════════════════════════════════════════════
       TRACKFLOW DESIGN SYSTEM — v2.0
    ═══════════════════════════════════════════════════ */

    /* ── CSS Variables — Dark (default) ── */
    :root, [data-theme="dark"] {
        --bg:            #06060f;
        --bg-2:          #0c0c1d;
        --bg-card:       rgba(255,255,255,0.03);
        --bg-card-solid: #0e0e20;
        --bg-hover:      rgba(255,255,255,0.06);
        --border:        rgba(255,255,255,0.07);
        --border-strong: rgba(255,255,255,0.12);
        --text-1:        #f0f4ff;
        --text-2:        #8892aa;
        --text-3:        #4a5568;
        --accent:        #6366f1;
        --accent-2:      #22d3ee;
        --accent-hover:  #818cf8;
        --accent-glow:   rgba(99,102,241,0.3);
        --accent-subtle: rgba(99,102,241,0.1);
        --success:       #10b981;
        --success-bg:    rgba(16,185,129,0.1);
        --warning:       #f59e0b;
        --warning-bg:    rgba(245,158,11,0.1);
        --danger:        #ef4444;
        --danger-bg:     rgba(239,68,68,0.1);
        --sidebar-w:     260px;
        --radius:        14px;
        --radius-sm:     8px;
        --radius-pill:   999px;
        --shadow-card:   0 4px 24px rgba(0,0,0,0.4);
        --shadow-glow:   0 0 40px rgba(99,102,241,0.2);
        --transition:    0.2s cubic-bezier(0.4,0,0.2,1);
    }

    /* ── CSS Variables — Light ── */
    [data-theme="light"] {
        --bg:            #f0f4ff;
        --bg-2:          #e8edff;
        --bg-card:       rgba(255,255,255,0.9);
        --bg-card-solid: #ffffff;
        --bg-hover:      rgba(99,102,241,0.05);
        --border:        rgba(0,0,0,0.07);
        --border-strong: rgba(0,0,0,0.13);
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --accent:        #4f46e5;
        --accent-2:      #0891b2;
        --accent-hover:  #4338ca;
        --accent-glow:   rgba(79,70,229,0.2);
        --accent-subtle: rgba(79,70,229,0.08);
        --success:       #059669;
        --success-bg:    rgba(5,150,105,0.08);
        --warning:       #d97706;
        --warning-bg:    rgba(217,119,6,0.08);
        --danger:        #dc2626;
        --danger-bg:     rgba(220,38,38,0.08);
        --shadow-card:   0 2px 16px rgba(0,0,0,0.08);
        --shadow-glow:   0 0 30px rgba(79,70,229,0.1);
    }

    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; }
    html { height: 100%; scroll-behavior: smooth; }
    body {
        height: 100%;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text-1);
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
        overflow-x: hidden;
        transition: background var(--transition), color var(--transition);
    }

    /* ── Page transition ── */
    #tf-transition {
        position: fixed;
        inset: 0;
        background: var(--accent);
        z-index: 9999;
        pointer-events: none;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    #tf-transition.enter  { transform: scaleX(1); transform-origin: left; }
    #tf-transition.leave  { transform: scaleX(0); transform-origin: right; }

    /* ── Sidebar ── */
    #tf-sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: var(--sidebar-w);
        z-index: 40;
        display: flex;
        flex-direction: column;
        background: var(--bg-2);
        border-right: 1px solid var(--border);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        transition: transform var(--transition), background var(--transition);
    }
    .tf-sidebar-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 24px 20px;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        flex-shrink: 0;
    }
    .tf-sidebar-logo-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px var(--accent-glow);
        flex-shrink: 0;
    }
    .tf-sidebar-logo-text {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: var(--text-1);
        background: linear-gradient(135deg, var(--text-1), var(--accent-hover));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .tf-sidebar-nav { flex: 1; padding: 16px 12px; overflow-y: auto; }
    .tf-sidebar-section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--text-3);
        padding: 8px 10px 6px;
        margin-top: 8px;
    }
    .tf-nav-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: var(--radius-sm);
        font-size: 13.5px;
        font-weight: 500;
        color: var(--text-2);
        text-decoration: none;
        transition: all var(--transition);
        position: relative;
        margin-bottom: 2px;
    }
    .tf-nav-link:hover { color: var(--text-1); background: var(--bg-hover); }
    .tf-nav-link.active {
        color: var(--accent-hover);
        background: var(--accent-subtle);
    }
    .tf-nav-link.active::before {
        content: '';
        position: absolute;
        left: 0; top: 6px; bottom: 6px;
        width: 3px;
        border-radius: 0 3px 3px 0;
        background: var(--accent);
        box-shadow: 0 0 8px var(--accent-glow);
    }
    .tf-nav-link svg { width: 18px; height: 18px; flex-shrink: 0; transition: transform var(--transition); }
    .tf-nav-link:hover svg { transform: translateX(2px); }
    .tf-sidebar-footer {
        padding: 12px;
        border-top: 1px solid var(--border);
        flex-shrink: 0;
    }

    /* ── Sidebar overlay mobile ── */
    #tf-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        z-index: 39;
    }
    @media (max-width: 1023px) {
        #tf-sidebar { transform: translateX(-100%); }
        #tf-sidebar.open { transform: translateX(0); box-shadow: 20px 0 60px rgba(0,0,0,0.4); }
        #tf-overlay.show { display: block; }
    }
    @media (min-width: 1024px) {
        #tf-overlay { display: none !important; }
    }

    /* ── Main layout ── */
    #tf-main {
        margin-left: var(--sidebar-w);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        transition: margin var(--transition);
    }
    @media (max-width: 1023px) {
        #tf-main { margin-left: 0; padding-bottom: 72px; }
    }

    /* ── Top Header ── */
    #tf-header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: rgba(var(--bg-2-rgb, 12,12,29), 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        padding: 0 28px;
        height: 60px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: background var(--transition);
    }
    [data-theme="light"] #tf-header {
        background: rgba(240,244,255,0.85);
    }
    .tf-breadcrumb { flex: 1; font-size: 13px; color: var(--text-2); min-width: 0; }
    .tf-breadcrumb a { color: var(--text-2); text-decoration: none; transition: color var(--transition); }
    .tf-breadcrumb a:hover { color: var(--text-1); }
    .tf-breadcrumb span.sep { color: var(--text-3); margin: 0 6px; }
    .tf-breadcrumb .current { color: var(--text-1); font-weight: 600; }

    /* ── Hamburger ── */
    #tf-hamburger {
        width: 36px; height: 36px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-2);
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        transition: all var(--transition);
        flex-shrink: 0;
    }
    #tf-hamburger:hover { background: var(--bg-hover); color: var(--text-1); }
    @media (max-width: 1023px) { #tf-hamburger { display: flex; } }

    /* ── Theme toggle ── */
    .tf-theme-btn {
        width: 36px; height: 36px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-2);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition);
        flex-shrink: 0;
    }
    .tf-theme-btn:hover { background: var(--bg-hover); color: var(--text-1); }
    .tf-theme-btn .icon-dark { display: block; }
    .tf-theme-btn .icon-light { display: none; }
    [data-theme="light"] .tf-theme-btn .icon-dark { display: none; }
    [data-theme="light"] .tf-theme-btn .icon-light { display: block; }

    /* ── User menu ── */
    .tf-user-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        cursor: pointer;
        transition: all var(--transition);
    }
    .tf-user-btn:hover { background: var(--bg-hover); border-color: var(--border-strong); }
    .tf-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: white;
        flex-shrink: 0;
        overflow: hidden;
    }
    .tf-user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }
    .tf-user-role { font-size: 11px; color: var(--text-3); }
    @media (max-width: 639px) { .tf-user-name, .tf-user-role { display: none; } }
    .tf-dropdown {
        position: absolute;
        right: 0; top: calc(100% + 8px);
        width: 220px;
        background: var(--bg-card-solid);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        transform-origin: top right;
        transition: all 0.15s cubic-bezier(0.4,0,0.2,1);
    }
    .tf-dropdown.hidden { opacity: 0; transform: scale(0.92); pointer-events: none; }
    .tf-dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 16px;
        font-size: 13px; color: var(--text-2);
        text-decoration: none;
        transition: all var(--transition);
        cursor: pointer; background: none; border: none; width: 100%; text-align: left;
    }
    .tf-dropdown-item:hover { background: var(--bg-hover); color: var(--text-1); }
    .tf-dropdown-item.danger { color: var(--danger); }
    .tf-dropdown-item.danger:hover { background: var(--danger-bg); }
    .tf-dropdown-sep { height: 1px; background: var(--border); }
    .tf-dropdown-header { padding: 12px 16px; border-bottom: 1px solid var(--border); }
    .tf-dropdown-header p { font-size: 11px; color: var(--text-3); }

    /* ── Flash messages ── */
    .tf-flash {
        padding: 12px 20px;
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 500;
        border: 1px solid;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: slideDown 0.3s ease;
    }
    .tf-flash.success { background: var(--success-bg); color: var(--success); border-color: rgba(16,185,129,0.2); }
    .tf-flash.error   { background: var(--danger-bg); color: var(--danger); border-color: rgba(239,68,68,0.2); }
    .tf-flash.info    { background: var(--accent-subtle); color: var(--accent-hover); border-color: rgba(99,102,241,0.2); }

    /* ── Page content ── */
    #tf-content {
        flex: 1;
        padding: 28px 32px;
        animation: pageFadeIn 0.4s cubic-bezier(0.4,0,0.2,1);
    }
    @media (max-width: 1023px) { #tf-content { padding: 20px 16px; } }
    @media (max-width: 639px)  { #tf-content { padding: 16px 12px; } }

    /* ── Bottom Nav (mobile) ── */
    #tf-bottom-nav {
        display: none;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        height: 64px;
        background: var(--bg-card-solid);
        border-top: 1px solid var(--border);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 50;
        padding: 0 8px;
        align-items: center;
        justify-content: space-around;
        gap: 4px;
    }
    @media (max-width: 1023px) { #tf-bottom-nav { display: flex; } }
    .tf-bn-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        flex: 1;
        padding: 8px 4px;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--text-3);
        font-size: 10px;
        font-weight: 500;
        transition: all var(--transition);
        position: relative;
    }
    .tf-bn-item svg { width: 22px; height: 22px; transition: transform var(--transition); }
    .tf-bn-item.active { color: var(--accent); }
    .tf-bn-item.active svg { transform: translateY(-2px); }
    .tf-bn-item.active::after {
        content: '';
        position: absolute;
        bottom: 2px;
        width: 20px; height: 3px;
        border-radius: var(--radius-pill);
        background: var(--accent);
    }
    .tf-bn-item:hover:not(.active) { color: var(--text-1); background: var(--bg-hover); }

    /* ═══════════════════════════════════════════════════
       COMPOSANTS RÉUTILISABLES
    ═══════════════════════════════════════════════════ */

    /* ── Cards ── */
    .card {
        background: var(--bg-card-solid);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition: border-color var(--transition), box-shadow var(--transition);
    }
    .card-glass {
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }
    .card-hover:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-card);
    }
    .card-accent-hover:hover {
        border-color: rgba(99,102,241,0.4);
        box-shadow: 0 0 0 3px var(--accent-subtle);
    }
    .card-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
    .card-body { padding: 24px; }
    .card-title { font-size: 15px; font-weight: 700; color: var(--text-1); }

    /* ── Buttons ── */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: var(--radius-sm);
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: all var(--transition);
        position: relative;
        overflow: hidden;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .btn::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0);
        transition: background 0.15s;
    }
    .btn:hover::after { background: rgba(255,255,255,0.06); }
    .btn:active { transform: scale(0.97); }
    .btn svg { width: 15px; height: 15px; flex-shrink: 0; }

    .btn-primary {
        background: linear-gradient(135deg, var(--accent), #8b5cf6);
        color: white;
        box-shadow: 0 4px 12px var(--accent-glow);
    }
    .btn-primary:hover { box-shadow: 0 6px 20px var(--accent-glow); transform: translateY(-1px); color: white; }
    .btn-secondary {
        background: var(--bg-hover);
        color: var(--text-2);
        border: 1px solid var(--border);
    }
    .btn-secondary:hover { background: var(--bg-card); color: var(--text-1); border-color: var(--border-strong); }
    .btn-ghost {
        background: transparent;
        color: var(--text-2);
    }
    .btn-ghost:hover { background: var(--bg-hover); color: var(--text-1); }
    .btn-danger {
        background: var(--danger-bg);
        color: var(--danger);
        border: 1px solid rgba(239,68,68,0.2);
    }
    .btn-danger:hover { background: var(--danger); color: white; box-shadow: 0 4px 12px rgba(239,68,68,0.3); }
    .btn-success {
        background: var(--success-bg);
        color: var(--success);
        border: 1px solid rgba(16,185,129,0.2);
    }
    .btn-success:hover { background: var(--success); color: white; }
    .btn-sm { padding: 6px 12px; font-size: 12px; border-radius: 6px; }
    .btn-sm svg { width: 13px; height: 13px; }
    .btn-lg { padding: 12px 28px; font-size: 15px; border-radius: 10px; }
    .btn-icon { padding: 8px; border-radius: var(--radius-sm); }
    .btn-icon svg { width: 16px; height: 16px; }

    /* ── Stat cards ── */
    .stat-card {
        background: var(--bg-card-solid);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        position: relative;
        overflow: hidden;
        transition: all var(--transition);
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
    }
    .stat-card.indigo::before { background: linear-gradient(90deg, var(--accent), transparent); }
    .stat-card.cyan::before   { background: linear-gradient(90deg, var(--accent-2), transparent); }
    .stat-card.green::before  { background: linear-gradient(90deg, var(--success), transparent); }
    .stat-card.amber::before  { background: linear-gradient(90deg, var(--warning), transparent); }
    .stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-card); border-color: var(--border-strong); }
    .stat-icon {
        width: 40px; height: 40px;
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon.indigo { background: var(--accent-subtle); color: var(--accent-hover); }
    .stat-icon.cyan   { background: rgba(34,211,238,0.1); color: #22d3ee; }
    .stat-icon.green  { background: var(--success-bg); color: var(--success); }
    .stat-icon.amber  { background: var(--warning-bg); color: var(--warning); }
    .stat-icon svg { width: 20px; height: 20px; }
    .stat-value {
        font-size: 32px;
        font-weight: 800;
        color: var(--text-1);
        letter-spacing: -1px;
        line-height: 1;
        margin-top: 12px;
    }
    .stat-label { font-size: 12.5px; color: var(--text-2); margin-top: 4px; }
    .stat-delta { font-size: 11px; margin-top: 6px; font-weight: 600; }
    .stat-delta.up   { color: var(--success); }
    .stat-delta.down { color: var(--danger); }

    /* ── Badges ── */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        font-size: 11.5px;
        font-weight: 600;
    }
    .badge-indigo { background: var(--accent-subtle); color: var(--accent-hover); }
    .badge-success { background: var(--success-bg); color: var(--success); }
    .badge-warning { background: var(--warning-bg); color: var(--warning); }
    .badge-danger  { background: var(--danger-bg); color: var(--danger); }
    .badge-neutral { background: var(--bg-hover); color: var(--text-2); }

    /* ── Form elements ── */
    .form-group { margin-bottom: 18px; }
    .form-label { display: block; font-size: 12.5px; font-weight: 600; color: var(--text-2); margin-bottom: 6px; letter-spacing: 0.2px; }
    .form-input {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        font-size: 14px;
        color: var(--text-1);
        transition: all var(--transition);
        outline: none;
    }
    .form-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-subtle);
    }
    .form-input::placeholder { color: var(--text-3); }
    select.form-input { cursor: pointer; }
    textarea.form-input { resize: vertical; min-height: 100px; }

    /* ── Section headings ── */
    .section-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--text-1);
        letter-spacing: -0.5px;
    }
    .section-subtitle { font-size: 13.5px; color: var(--text-2); margin-top: 4px; }

    /* ── Page header ── */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    /* ── Dividers ── */
    .divider { height: 1px; background: var(--border); margin: 20px 0; }

    /* ── Avatar ── */
    .avatar {
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: white;
        flex-shrink: 0;
        overflow: hidden;
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .avatar-sm { width: 36px; height: 36px; font-size: 13px; }
    .avatar-md { width: 48px; height: 48px; font-size: 16px; }
    .avatar-lg { width: 72px; height: 72px; font-size: 24px; }
    .avatar-xl { width: 96px; height: 96px; font-size: 32px; }
    .avatar-sq { border-radius: var(--radius-sm); }

    /* ── List items ── */
    .list-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        transition: background var(--transition);
        text-decoration: none;
        color: inherit;
    }
    .list-item:last-child { border-bottom: none; }
    .list-item:hover { background: var(--bg-hover); }
    .list-item-title { font-size: 14px; font-weight: 600; color: var(--text-1); }
    .list-item-sub   { font-size: 12px; color: var(--text-2); margin-top: 2px; }

    /* ── Empty state ── */
    .empty-state {
        padding: 64px 32px;
        text-align: center;
        color: var(--text-2);
    }
    .empty-state svg { width: 56px; height: 56px; color: var(--text-3); margin: 0 auto 16px; }
    .empty-state h3  { font-size: 16px; font-weight: 700; color: var(--text-1); margin-bottom: 6px; }
    .empty-state p   { font-size: 13px; color: var(--text-2); }

    /* ── Modals ── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(6px);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        animation: fadeIn 0.15s ease;
    }
    .modal {
        background: var(--bg-card-solid);
        border: 1px solid var(--border-strong);
        border-radius: 18px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        animation: scaleIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
    }
    .modal-header { padding: 20px 24px; border-bottom: 1px solid var(--border); }
    .modal-body   { padding: 20px 24px; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: flex-end; }

    /* ── Tabs ── */
    .tf-tabs {
        display: flex;
        gap: 2px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 4px;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .tf-tabs::-webkit-scrollbar { display: none; }
    .tf-tab {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-2);
        cursor: pointer;
        transition: all var(--transition);
        border: none;
        background: none;
        white-space: nowrap;
    }
    .tf-tab:hover { color: var(--text-1); background: var(--bg-hover); }
    .tf-tab.active { background: var(--bg-card-solid); color: var(--text-1); font-weight: 600; box-shadow: 0 1px 4px rgba(0,0,0,0.15); }
    .tf-tab svg { width: 15px; height: 15px; }

    /* ── Skeleton loader ── */
    .skeleton {
        background: linear-gradient(90deg, var(--bg-hover) 25%, var(--bg-card) 50%, var(--bg-hover) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 6px;
    }

    /* ── Progress bar ── */
    .progress-bar {
        height: 6px;
        background: var(--bg-hover);
        border-radius: var(--radius-pill);
        overflow: hidden;
    }
    .progress-fill {
        height: 100%;
        border-radius: var(--radius-pill);
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        transition: width 1s cubic-bezier(0.4,0,0.2,1);
    }

    /* ── Responsive grid helpers ── */
    .grid-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .grid-main { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }

    @media (max-width: 1279px) {
        .grid-main { grid-template-columns: 1fr; }
        .grid-3    { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 767px) {
        .grid-stats { grid-template-columns: repeat(2, 1fr); }
        .grid-2     { grid-template-columns: 1fr; }
        .grid-3     { grid-template-columns: 1fr; }
    }
    @media (max-width: 479px) {
        .grid-stats { grid-template-columns: 1fr; }
    }

    /* ═══════════════════════════════════════════════════
       ANIMATIONS
    ═══════════════════════════════════════════════════ */
    @keyframes pageFadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scaleIn {
        from { opacity: 0; transform: scale(0.9); }
        to   { opacity: 1; transform: scale(1); }
    }
    @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @keyframes shimmer {
        0%   { background-position: -200% 0; }
        100% { background-position:  200% 0; }
    }
    @keyframes countUp {
        from { opacity: 0; transform: translateY(10px) scale(0.8); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes pulse-ring {
        0%   { box-shadow: 0 0 0 0 var(--accent-glow); }
        70%  { box-shadow: 0 0 0 8px transparent; }
        100% { box-shadow: 0 0 0 0 transparent; }
    }
    @keyframes tf-spin { to { transform: rotate(360deg); } }
    .animate-count { animation: countUp 0.5s cubic-bezier(0.34,1.56,0.64,1) both; }
    .animate-pulse-ring { animation: pulse-ring 2s infinite; }

    /* ── Stagger animations ── */
    [data-stagger] > * {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    [data-stagger].visible > * { opacity: 1; transform: translateY(0); }
    [data-stagger] > *:nth-child(1) { transition-delay: 0ms; }
    [data-stagger] > *:nth-child(2) { transition-delay: 60ms; }
    [data-stagger] > *:nth-child(3) { transition-delay: 120ms; }
    [data-stagger] > *:nth-child(4) { transition-delay: 180ms; }
    [data-stagger] > *:nth-child(5) { transition-delay: 240ms; }
    [data-stagger] > *:nth-child(6) { transition-delay: 300ms; }
    [data-stagger] > *:nth-child(7) { transition-delay: 360ms; }
    [data-stagger] > *:nth-child(8) { transition-delay: 420ms; }

    /* ── Scrollbar custom ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-3); }

    /* ── Utility ── */
    .space-y-4 > * + * { margin-top: 16px; }
    .space-y-6 > * + * { margin-top: 24px; }
    .space-y-8 > * + * { margin-top: 32px; }
    .flex-col-gap { display: flex; flex-direction: column; gap: 16px; }
    .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
    </style>
</head>
<body>

{# ── Page transition overlay ── #}
<div id="tf-transition"></div>

{# ── Mobile sidebar overlay ── #}
<div id="tf-overlay"></div>

{# ══════════════════════════════════════
   SIDEBAR
══════════════════════════════════════ #}
<aside id="tf-sidebar">

    {# Logo #}
    <a href="{{ path('app_dashboard') }}" class="tf-sidebar-logo" data-no-transition>
        <div class="tf-sidebar-logo-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
        </div>
        <span class="tf-sidebar-logo-text">TrackFlow</span>
    </a>

    {# Navigation principale #}
    <nav class="tf-sidebar-nav">
        <a href="{{ path('app_dashboard') }}"
           class="tf-nav-link {% if app.current_route == 'app_dashboard' or app.current_route == 'app_dashboard_athlete' or app.current_route == 'app_dashboard_coach' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Tableau de bord
        </a>

        <a href="{{ path('app_athlete_index') }}"
           class="tf-nav-link {% if app.current_route starts with 'app_athlete' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Athlètes
        </a>

        <a href="{{ path('app_calendar') }}"
           class="tf-nav-link {% if app.current_route == 'app_calendar' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Calendrier
        </a>

        <a href="{{ path('app_competition_calendar') }}"
           class="tf-nav-link {% if app.current_route starts with 'app_competition' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
            Compétitions
        </a>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="tf-sidebar-section-label">Administration</div>

        <a href="{{ path('app_training_type_index') }}"
           class="tf-nav-link {% if app.current_route == 'app_training_type_index' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            Types de séances
        </a>

        <a href="{{ path('app_competition_type_index') }}"
           class="tf-nav-link {% if app.current_route starts with 'app_competition_type' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
            Types de compétitions
        </a>

        <a href="{{ path('app_user_index') }}"
           class="tf-nav-link {% if app.current_route starts with 'app_user' or app.current_route starts with 'app_admin' %}active{% endif %}">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Utilisateurs
        </a>
        {% endif %}
    </nav>

    {# Footer sidebar — version #}
    <div class="tf-sidebar-footer">
        <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 6px var(--success);"></div>
            <span style="font-size:11px;color:var(--text-3);">TrackFlow v2.0</span>
        </div>
    </div>
</aside>

{# ══════════════════════════════════════
   MAIN CONTENT
══════════════════════════════════════ #}
<div id="tf-main">

    {# ── Top Header ── #}
    <header id="tf-header">
        <button id="tf-hamburger" onclick="TF.toggleSidebar()" aria-label="Menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>

        <nav class="tf-breadcrumb">
            {% block breadcrumb %}{% endblock %}
        </nav>

        {# Theme toggle #}
        <button class="tf-theme-btn" onclick="TF.toggleTheme()" aria-label="Changer le thème">
            <svg class="icon-dark" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
            <svg class="icon-light" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
        </button>

        {# User dropdown #}
        <div style="position:relative;" x-data="{ open: false }" @click.outside="open = false">
            <button class="tf-user-btn" @click="open = !open">
                <div class="tf-avatar" style="width:30px;height:30px;font-size:11px;">
                    {{ app.user.firstName|slice(0,1)|upper }}{{ app.user.lastName|slice(0,1)|upper }}
                </div>
                <div class="r-user-info" style="text-align:left;">
                    <div class="tf-user-name">{{ app.user.firstName }}</div>
                    <div class="tf-user-role">{{ is_granted('ROLE_ADMIN') ? 'Coach' : 'Athlète' }}</div>
                </div>
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"
                     :class="open ? 'rotate-180' : ''" style="transition: transform 0.2s; color: var(--text-3);"
                     class="r-user-info">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>

            <div class="tf-dropdown" :class="open ? '' : 'hidden'" style="display:block;">
                <div class="tf-dropdown-header">
                    <p>{{ app.user.email }}</p>
                </div>

                {% if app.user.linkedAthlete %}
                    <a href="{{ path('app_athlete_show', {id: app.user.linkedAthlete.id}) }}" class="tf-dropdown-item" @click="open=false">
                        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        Mon profil
                    </a>
                {% else %}
                    <a href="{{ path('app_register_link_profile') }}" class="tf-dropdown-item" @click="open=false">
                        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                        Créer mon profil
                    </a>
                {% endif %}

                <div class="tf-dropdown-sep"></div>
                <a href="{{ path('app_logout') }}" class="tf-dropdown-item danger">
                    <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Se déconnecter
                </a>
            </div>
        </div>
    </header>

    {# ── Flash messages ── #}
    <div style="padding: 0 28px; margin-top: 12px;" id="tf-flash-zone">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div x-data="{ show: true }"
                 x-show="show"
                 x-init="setTimeout(() => show = false, 4500)"
                 x-transition:leave="transition ease-in duration-300"
                 x-transition:leave-start="opacity-100 translate-y-0"
                 x-transition:leave-end="opacity-0 -translate-y-2"
                 class="tf-flash {% if type == 'success' %}success{% elseif type == 'error' %}error{% else %}info{% endif %}"
                 style="margin-bottom: 8px;">
                {% if type == 'success' %}
                    <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {% elseif type == 'error' %}
                    <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                {% else %}
                    <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {% endif %}
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    </div>

    {# ── Page content ── #}
    <main id="tf-content">
        {% block body %}{% endblock %}
    </main>
</div>

{# ══════════════════════════════════════
   BOTTOM NAV (mobile)
══════════════════════════════════════ #}
<nav id="tf-bottom-nav">
    <a href="{{ path('app_dashboard') }}"
       class="tf-bn-item {% if app.current_route == 'app_dashboard' or app.current_route == 'app_dashboard_athlete' or app.current_route == 'app_dashboard_coach' %}active{% endif %}">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Accueil
    </a>
    <a href="{{ path('app_athlete_index') }}"
       class="tf-bn-item {% if app.current_route starts with 'app_athlete' %}active{% endif %}">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Athlètes
    </a>
    <a href="{{ path('app_calendar') }}"
       class="tf-bn-item {% if app.current_route == 'app_calendar' %}active{% endif %}">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Calendrier
    </a>
    <a href="{{ path('app_competition_calendar') }}"
       class="tf-bn-item {% if app.current_route starts with 'app_competition' %}active{% endif %}">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
        Compétitions
    </a>
    <a href="{{ app.user.linkedAthlete ? path('app_athlete_show', {id: app.user.linkedAthlete.id}) : '#' }}"
       class="tf-bn-item">
        <div class="tf-avatar" style="width:24px;height:24px;font-size:9px;border-radius:50%;">
            {{ app.user.firstName|slice(0,1)|upper }}
        </div>
        Profil
    </a>
</nav>

{# ══════════════════════════════════════
   SCRIPTS GLOBAUX
══════════════════════════════════════ #}
<script>
const TF = {
    /* ── Theme ── */
    toggleTheme() {
        const html = document.documentElement;
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('tf-theme', next);
    },
    initTheme() {
        const saved = localStorage.getItem('tf-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', saved);
    },

    /* ── Sidebar mobile ── */
    toggleSidebar() {
        const sidebar = document.getElementById('tf-sidebar');
        const overlay = document.getElementById('tf-overlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('show');
    },
    closeSidebar() {
        document.getElementById('tf-sidebar').classList.remove('open');
        document.getElementById('tf-overlay').classList.remove('show');
    },

    /* ── Page transitions ── */
    initTransitions() {
        const bar = document.getElementById('tf-transition');

        // Animate in on page load
        bar.classList.add('enter');
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                bar.classList.remove('enter');
                bar.classList.add('leave');
            });
        });

        // Intercept internal link clicks
        document.addEventListener('click', (e) => {
            const link = e.target.closest('a[href]');
            if (!link) return;
            const href = link.getAttribute('href');
            if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
            if (link.hasAttribute('data-no-transition')) return;
            if (link.target === '_blank') return;
            try {
                const url = new URL(href, window.location.origin);
                if (url.origin !== window.location.origin) return;
            } catch { return; }

            e.preventDefault();
            bar.style.transition = 'none';
            bar.className = '';
            bar.classList.add('enter');
            void bar.offsetWidth;
            bar.style.transition = '';

            setTimeout(() => { window.location.href = href; }, 280);
        });
    },

    /* ── Stagger animations ── */
    initStagger() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.05 });

        document.querySelectorAll('[data-stagger]').forEach(el => observer.observe(el));
    },

    /* ── Count-up animation ── */
    initCountUp() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                const el = entry.target;
                const end = parseFloat(el.dataset.count);
                const dec = (el.dataset.count.split('.')[1] || '').length;
                const duration = 1000;
                const start = performance.now();
                const step = (now) => {
                    const progress = Math.min((now - start) / duration, 1);
                    const ease = 1 - Math.pow(1 - progress, 3);
                    el.textContent = (end * ease).toFixed(dec);
                    if (progress < 1) requestAnimationFrame(step);
                };
                requestAnimationFrame(step);
                observer.unobserve(el);
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-count]').forEach(el => observer.observe(el));
    },

    /* ── Progress bars ── */
    initProgressBars() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                const fill = entry.target.querySelector('.progress-fill');
                if (fill) {
                    const target = fill.dataset.width || '0';
                    setTimeout(() => { fill.style.width = target + '%'; }, 100);
                }
                observer.unobserve(entry.target);
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.progress-bar').forEach(el => observer.observe(el));
    },

    /* ── Mobile sidebar nav links close ── */
    initNavLinks() {
        document.querySelectorAll('#tf-sidebar .tf-nav-link').forEach(link => {
            link.addEventListener('click', () => TF.closeSidebar());
        });
        document.getElementById('tf-overlay')?.addEventListener('click', () => TF.closeSidebar());
    }
};

// Init
document.addEventListener('DOMContentLoaded', () => {
    TF.initTheme();
    TF.initTransitions();
    TF.initStagger();
    TF.initCountUp();
    TF.initProgressBars();
    TF.initNavLinks();
});
</script>

</body>
</html>
