{% extends 'base.html.twig' %}
{% block title %}Types de compétitions{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_competition_calendar') }}">Calendrier compétitions</a>
    <span class="sep">/</span>
    <span class="current">Types de compétitions</span>
{% endblock %}

{% block body %}
<div style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:24px;">

    <div>
        <h1 class="section-title">Types de compétitions</h1>
        <p class="section-subtitle">Gérez les pastilles de type utilisées dans le calendrier des compétitions.</p>
    </div>

    {# Liste des types existants #}
    <div class="card" style="overflow:hidden">
        {% if types is empty %}
            <div class="empty-state" style="padding:40px">
                <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 012-2z"/></svg>
                <p>Aucun type créé. Commencez par en ajouter un ci-dessous.</p>
            </div>
        {% else %}
            {% for type in types %}
                <div class="list-item"
                     x-data="{
                        editing: false,
                        async deleteType() {
                            const msg = '{{ ('Supprimer le type "' ~ type.name ~ '" ?')|e('js') }}{% if type.competitions|length > 0 %} Les {{ type.competitions|length }} compétitions associées n\'auront plus de type.{% endif %}';
                            if (!confirm(msg)) return;
                            const res = await fetch('{{ path('app_competition_type_delete', {id: type.id}) }}', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                                body: '_token={{ csrf_token('delete-ct' ~ type.id)|url_encode }}'
                            });
                            if (res.ok) {
                                $el.style.opacity = '0';
                                $el.style.transition = 'opacity .2s';
                                setTimeout(() => $el.remove(), 200);
                            }
                        }
                     }">

                    {# Display mode #}
                    <div style="display:flex;align-items:center;gap:12px;flex:1;" x-show="!editing">
                        <span style="width:18px;height:18px;border-radius:50%;flex-shrink:0;border:2px solid rgba(255,255,255,.15);background:{{ type.color }}"></span>
                        <span style="font-weight:500;color:var(--text-1);font-size:14px;">{{ type.name }}</span>
                        <span style="font-size:11px;color:var(--text-3);font-family:monospace;">{{ type.color }}</span>
                        {% if type.competitions|length > 0 %}
                            <span style="font-size:12px;color:var(--text-3);">{{ type.competitions|length }} compétition{% if type.competitions|length > 1 %}s{% endif %}</span>
                        {% endif %}
                    </div>

                    {# Inline edit form #}
                    <form action="{{ path('app_competition_type_edit', {id: type.id}) }}" method="post"
                          style="display:flex;align-items:center;gap:8px;flex:1;margin-right:16px;" x-show="editing">
                        <input type="text" name="competition_type[name]" value="{{ type.name }}"
                               class="form-input" style="flex:1;padding:6px 10px;font-size:13px;">
                        <input type="color" name="competition_type[color]" value="{{ type.color }}"
                               style="width:36px;height:32px;border-radius:8px;cursor:pointer;background:transparent;border:1px solid var(--border);padding:2px;">
                        <input type="hidden" name="competition_type[_token]" value="{{ csrf_token('competition_type') }}">
                        <button type="submit" class="btn btn-primary btn-sm">OK</button>
                        <button type="button" @click="editing = false" class="btn btn-ghost btn-sm">Annuler</button>
                    </form>

                    <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
                        <button @click="editing = !editing" x-show="!editing"
                                style="background:none;border:none;padding:6px;border-radius:8px;cursor:pointer;color:var(--text-3);transition:color .15s,background .15s;"
                                onmouseover="this.style.color='var(--accent)';this.style.background='rgba(var(--accent-rgb),.1)'"
                                onmouseout="this.style.color='var(--text-3)';this.style.background='none'">
                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </button>
                        <button type="button" @click="deleteType()"
                                style="background:none;border:none;padding:6px;border-radius:8px;cursor:pointer;color:var(--text-3);transition:color .15s,background .15s;"
                                onmouseover="this.style.color='var(--danger)';this.style.background='rgba(239,68,68,.1)'"
                                onmouseout="this.style.color='var(--text-3)';this.style.background='none'">
                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    {# Créer un nouveau type #}
    <div class="card card-body">
        <h2 style="font-size:14px;font-weight:600;color:var(--text-1);margin:0 0 16px;text-transform:uppercase;letter-spacing:.05em;">Nouveau type</h2>
        {{ form_start(form, {attr: {style: 'display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;'}}) }}
        <div style="flex:1;min-width:160px;">
            {{ form_row(form.name) }}
        </div>
        <div style="padding-bottom:2px;">
            <p class="form-label">Couleur</p>
            {{ form_widget(form.color, {attr: {style: 'width:44px;height:38px;border-radius:8px;cursor:pointer;background:transparent;border:1px solid var(--border);padding:2px;'}}) }}
            {% do form.color.setRendered() %}
        </div>
        <div style="padding-bottom:2px;">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter
            </button>
        </div>
        {{ form_end(form) }}
    </div>

    <a href="{{ path('app_competition_calendar') }}" class="btn btn-ghost btn-sm" style="align-self:flex-start;">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Retour au calendrier des compétitions
    </a>

</div>
{% endblock %}
