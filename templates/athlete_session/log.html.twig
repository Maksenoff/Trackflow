{% extends 'base.html.twig' %}
{% block title %}Enregistrer ma séance{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}">{{ athlete.fullName }}</a>
    <span class="sep">/</span>
    <span class="current">Mon ressenti</span>
{% endblock %}

{% block body %}
<div style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:20px;">

    {# Session info card #}
    <div class="card" style="overflow:hidden;">
        <div style="height:3px;background:{{ session.colorBg }};"></div>
        <div class="card-body">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;">
                <div>
                    <h2 style="font-size:17px;font-weight:700;color:var(--text-1);margin:0 0 10px;">{{ session.title }}</h2>
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;
                                     background:{{ session.colorBg }}22;color:{{ session.colorBg }};">
                            {{ session.typeLabel }}
                        </span>
                        <span style="font-size:13px;color:var(--text-2);">{{ session.date|date('d/m/Y') }}</span>
                        {% if session.durationMinutes %}
                            <span style="font-size:13px;color:var(--text-2);">{{ session.durationMinutes }} min</span>
                        {% endif %}
                    </div>
                    {% if session.description %}
                        <p style="font-size:13px;color:var(--text-2);margin:12px 0 0;line-height:1.6;">{{ session.description }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# Feedback form #}
    <div class="card card-body">
        <h3 style="font-weight:600;color:var(--text-1);margin:0 0 20px;font-size:15px;">Ton ressenti pour {{ athlete.firstName }}</h3>

        {{ form_start(form, {attr: {style: 'display:flex;flex-direction:column;gap:20px;'}}) }}

        {# Difficulty slider #}
        <div x-data="{ val: 5 }">
            <p class="form-label">
                Difficulté ressentie — <span style="color:var(--accent);font-weight:700;" x-text="val + '/10'"></span>
            </p>
            <div style="display:flex;align-items:center;gap:16px;margin-top:10px;">
                <input type="range" min="0" max="10" step="1" x-model="val"
                       name="{{ form.difficulty.vars.full_name }}"
                       id="{{ form.difficulty.vars.id }}"
                       style="flex:1;height:6px;border-radius:99px;cursor:pointer;accent-color:var(--accent);">
                <div style="display:flex;gap:3px;flex-shrink:0;">
                    <template x-for="i in 11" :key="i-1">
                        <div style="width:20px;height:20px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;transition:background .15s,color .15s;"
                             :style="(i-1) <= val ? 'background:var(--accent);color:#fff;' : 'background:var(--bg-2);color:var(--text-3);'"
                             x-text="i-1"></div>
                    </template>
                </div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-3);margin-top:6px;">
                <span>Très facile</span>
                <span>Modéré</span>
                <span>Maximal</span>
            </div>
            {% do form.difficulty.setRendered() %}
        </div>

        {{ form_row(form.comment) }}

        <div style="display:flex;gap:12px;padding-top:4px;">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Enregistrer mon ressenti
            </button>
            <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="btn btn-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
