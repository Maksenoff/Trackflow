                    {# File picker row #}
                    <div id="video-dropzone"
                         class="flex items-center gap-3 bg-gray-800/60 border border-dashed border-gray-600 hover:border-indigo-500 hover:bg-indigo-500/5 rounded-lg px-3 py-2.5 cursor-pointer transition-all group"
                         onclick="document.getElementById('video-file-input').click()">
                        <svg class="w-4 h-4 text-gray-500 group-hover:text-indigo-400 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <span id="video-file-label" class="text-xs text-gray-400 group-hover:text-gray-200 transition-colors flex-1">Choisir un fichier — MP4, MOV, AVI… max 500 Mo</span>
                        <input type="file" name="video" id="video-file-input" accept="video/*" required class="hidden">
                    </div>

                    {# Preview selected file #}
                    <div id="video-file-preview" class="hidden items-center gap-2.5 bg-indigo-600/10 border border-indigo-600/30 rounded-lg px-3 py-2">
                        <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <div class="flex-1 min-w-0">
                            <p id="vdz-filename" class="text-xs font-medium text-white truncate"></p>
                            <p id="vdz-filesize" class="text-xs text-indigo-300/70"></p>
                        </div>
                        <button type="button" onclick="videoClearFile()" class="text-gray-500 hover:text-red-400 transition-colors shrink-0">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>

                    {# Title + category #}
                    <div class="grid grid-cols-2 gap-2">
                        <input type="text" name="title" required placeholder="Titre de la vidéo *"
                               class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500">
                        <select name="discipline"
                                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-indigo-500">
                            <option value="">— Catégorie —</option>
                            {% for label, value in constant('App\\Entity\\Performance::DISCIPLINES') %}
                                <option value="{{ value }}">{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Submit #}
                    <div class="flex justify-end">
                        <button type="submit" id="video-submit-btn"
                                class="flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-xs font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                            </svg>
                            Envoyer
                        </button>
                    </div>

                    {# Progress #}
                    <div id="video-progress-wrap" class="hidden">
                        <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
                            <span>Envoi en cours…</span>
                            <span id="video-progress-pct"></span>
                        </div>
                        <div class="w-full bg-gray-800 rounded-full h-1 overflow-hidden">
                            <div id="video-progress-bar" class="h-1 rounded-full bg-indigo-500" style="width:0%;transition:width 0.2s ease"></div>
                        </div>
                    </div>

                    <div id="video-upload-error" class="hidden text-xs text-red-400 bg-red-900/20 border border-red-800/40 rounded-lg px-3 py-2"></div>

                </form>
            </div>
        </div>

        {# Videos list #}
        <div id="videos-container">
            <div id="videos-loading" class="text-center py-10 text-gray-500 text-sm">Chargement…</div>
        </div>

    </div>

</div>

<script>
(function () {
    var athleteId = {{ athlete.id }};
    var uploadUrl = '{{ path('app_athlete_video_upload', {athleteId: athlete.id}) }}';
    var listUrl   = '{{ path('app_athlete_videos', {athleteId: athlete.id}) }}';

    var loaded = false;

    window.videoApp = {
        load: function () {
            if (loaded) return;
            loaded = true;
            fetch(listUrl, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
                .then(r => r.json())
                .then(data => renderVideos(data.videos))
                .catch(() => { document.getElementById('videos-loading').textContent = 'Erreur de chargement.'; });
        }
    };

    function renderVideos(videos) {
        var container = document.getElementById('videos-container');
        container.innerHTML = '';
        if (!videos.length) {
            container.innerHTML = '<div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500 text-sm">Aucune vidéo pour l\'instant.</div>';
            return;
        }

        // Group by discipline preserving insertion order
        var groups = {}, order = [];
        videos.forEach(function (v) {
            var key = v.discipline || '';
            if (!groups[key]) { groups[key] = []; order.push(key); }
            groups[key].push(v);
        });

        var wrap = document.createElement('div');
        wrap.className = 'space-y-3';

        order.forEach(function (disc, idx) {
            var label   = disc || 'Sans catégorie';
            var catVids = groups[disc];
            var isOpen  = idx === 0;

            var acc = document.createElement('div');
            acc.className = 'bg-gray-900 border border-gray-800 rounded-xl overflow-hidden';

            // ── Header ──
            var header = document.createElement('button');
            header.type = 'button';
            header.style.cssText = 'width:100%;display:flex;align-items:center;justify-content:space-between;padding:20px 24px;background:none;border:none;cursor:pointer;transition:background 0.15s';
            header.onmouseenter = function(){ this.style.background='rgba(255,255,255,0.04)'; };
            header.onmouseleave = function(){ this.style.background='none'; };
            header.innerHTML =
                '<div style="display:flex;align-items:center;gap:12px">'
                + '<span style="font-weight:600;color:white;font-size:15px">' + escHtml(label) + '</span>'
                + '<span style="font-size:11px;background:#1f2937;color:#9ca3af;padding:3px 10px;border-radius:999px">' + catVids.length + '</span>'
                + '</div>'
                + '<svg class="cat-arrow" style="width:18px;height:18px;color:#6b7280;transition:transform 0.2s;transform:rotate(' + (isOpen ? '180' : '0') + 'deg);flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">'
                + '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';

            // ── Body ──
            var body = document.createElement('div');
            body.className = 'border-t border-gray-800';
            if (!isOpen) body.style.display = 'none';

            // Search bar
            var searchWrap = document.createElement('div');
            searchWrap.style.cssText = 'padding:14px 24px;border-bottom:1px solid rgba(255,255,255,0.06)';
            var searchInput = document.createElement('input');
            searchInput.type = 'text';
            searchInput.placeholder = 'Rechercher dans ' + label + '…';
            searchInput.style.cssText = 'width:100%;background:#1f2937;border:1px solid #374151;border-radius:8px;padding:10px 14px;font-size:13px;color:white;outline:none;box-sizing:border-box';
            searchInput.onfocus   = function(){ this.style.borderColor='#6366f1'; };
            searchInput.onblur    = function(){ this.style.borderColor='#374151'; };
            searchWrap.appendChild(searchInput);

            // Video grid
            var grid = document.createElement('div');
            grid.className = 'p-4 grid grid-cols-3 gap-2 sm:grid-cols-4';

            catVids.forEach(function (v) { grid.appendChild(createVideoCard(v)); });

            searchInput.addEventListener('input', function () {
                var q = this.value.toLowerCase().trim();
                grid.querySelectorAll('.video-card').forEach(function (c) {
                    c.style.display = (!q || c.dataset.title.toLowerCase().includes(q)) ? '' : 'none';
                });
            });

            header.addEventListener('click', function () {
                isOpen = !isOpen;
                body.style.display = isOpen ? '' : 'none';
                header.querySelector('.cat-arrow').style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
            });

            body.appendChild(searchWrap);
            body.appendChild(grid);
            acc.appendChild(header);
            acc.appendChild(body);
            wrap.appendChild(acc);
        });

        container.appendChild(wrap);
    }

    function fmtTime(s) {
        if (isNaN(s)) return '0:00';
        var m = Math.floor(s / 60), sec = Math.floor(s % 60);
        return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function createVideoCard(v) {
        var card = document.createElement('div');
        card.className = 'video-card bg-gray-800/50 border border-gray-700/60 rounded-xl overflow-hidden';
        card.id = 'vcard-' + v.id;
        card.dataset.title = v.title;

        // ── Video wrapper ──
        var wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;background:#000;border-radius:12px;overflow:hidden;aspect-ratio:16/9;';

        var video = document.createElement('video');
        video.src = v.url;
        video.preload = 'metadata';
        video.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;cursor:pointer;';

        // ── Controls overlay ──
        var ctrl = document.createElement('div');
        ctrl.style.cssText = 'position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;opacity:0;transition:opacity 0.2s;';

        // Gradient bottom
        var grad = document.createElement('div');
        grad.style.cssText = 'position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,rgba(0,0,0,0.2) 45%,transparent 100%);pointer-events:none;';
        ctrl.appendChild(grad);

        // Controls panel
        var panel = document.createElement('div');
        panel.style.cssText = 'position:relative;padding:0 14px 14px;z-index:1;';

        // ── Progress bar ──
        var progressWrap = document.createElement('div');
        progressWrap.style.cssText = 'position:relative;width:100%;height:3px;background:rgba(255,255,255,0.2);border-radius:9999px;margin-bottom:12px;cursor:pointer;transition:height 0.15s;';

        var progressFill = document.createElement('div');
        progressFill.style.cssText = 'position:absolute;top:0;left:0;height:100%;width:0%;background:linear-gradient(to right,#818cf8,#6366f1);border-radius:9999px;pointer-events:none;transition:width 0.08s linear;';

        var progressThumb = document.createElement('div');
        progressThumb.style.cssText = 'position:absolute;top:50%;right:-6px;transform:translateY(-50%);width:12px;height:12px;background:#fff;border-radius:50%;pointer-events:none;opacity:0;transition:opacity 0.15s;box-shadow:0 0 0 3px rgba(99,102,241,0.4);';

        progressFill.appendChild(progressThumb);
        progressWrap.appendChild(progressFill);

        progressWrap.addEventListener('mouseenter', function() { this.style.height='5px'; progressThumb.style.opacity='1'; });
        progressWrap.addEventListener('mouseleave', function() { this.style.height='3px'; progressThumb.style.opacity='0'; });

        var isSeeking = false;
        function seekFromEvent(e) {
            var rect = progressWrap.getBoundingClientRect();
            var pct = Math.max(0, Math.min((e.clientX - rect.left) / rect.width, 1));
            if (video.duration > 0) video.currentTime = pct * video.duration;
            progressFill.style.width = (pct * 100) + '%';
        }
        progressWrap.addEventListener('mousedown', function(e) { e.stopPropagation(); isSeeking = true; seekFromEvent(e); });
        document.addEventListener('mousemove', function(e) { if (isSeeking) seekFromEvent(e); });
        document.addEventListener('mouseup',   function()  { isSeeking = false; });

        // ── Controls row ──
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:6px;';

        function mkBtn(html) {
            var b = document.createElement('button');
            b.type = 'button';
            b.style.cssText = 'color:rgba(255,255,255,0.85);background:none;border:none;padding:5px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;border-radius:6px;transition:background 0.15s,color 0.15s;';
            b.innerHTML = html;
            b.addEventListener('mouseenter', function() { this.style.background='rgba(255,255,255,0.12)'; this.style.color='#fff'; });
            b.addEventListener('mouseleave', function() { this.style.background='none'; this.style.color='rgba(255,255,255,0.85)'; });
            return b;
        }

        // Play/pause
        var playBtn = mkBtn('<svg class="play-icon" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg><svg class="pause-icon" width="20" height="20" fill="currentColor" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>');

        // Rewind -5s
        var rwBtn = mkBtn('<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 12a9.5 9.5 0 1 1 1.07 4.37"/><path d="M2.5 7v5h5"/><text x="12.2" y="14" text-anchor="middle" font-size="5.5" fill="currentColor" stroke="none" font-family="sans-serif" font-weight="700">5</text></svg>');
        // Forward +5s
        var fwBtn = mkBtn('<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 12a9.5 9.5 0 1 0-1.07 4.37"/><path d="M21.5 7v5h-5"/><text x="11.8" y="14" text-anchor="middle" font-size="5.5" fill="currentColor" stroke="none" font-family="sans-serif" font-weight="700">5</text></svg>');

        // Time
        var timeEl = document.createElement('span');
        timeEl.style.cssText = 'font-size:11.5px;color:rgba(255,255,255,0.75);font-variant-numeric:tabular-nums;white-space:nowrap;flex-shrink:0;letter-spacing:0.02em;margin-left:2px;';
        timeEl.textContent = '0:00';

        var spacer = document.createElement('span');
        spacer.style.flex = '1';

        // Speed — pills horizontales dans le player
        var speeds = [0.05, 0.1, 0.25, 0.5, 0.75, 1, 1.25, 1.5, 2];
        var currentSpeed = 1;

        var speedWrap = document.createElement('div');
        speedWrap.style.cssText = 'flex-shrink:0;position:relative;';

        // Barre de pills — remplace la row, pleine largeur, scroll sur petits lecteurs
        var speedPills = document.createElement('div');
        speedPills.style.cssText = 'display:none;flex-direction:row;align-items:center;gap:4px;overflow-x:auto;scrollbar-width:none;padding:2px 0;';

        speeds.forEach(function(s) {
            var pill = document.createElement('button');
            pill.type = 'button';
            pill.dataset.speed = s;
            var isActive = s === 1;
            pill.style.cssText = 'font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px;cursor:pointer;transition:all 0.12s;white-space:nowrap;border:1px solid ' + (isActive ? 'rgba(99,102,241,0.6)' : 'transparent') + ';background:' + (isActive ? 'rgba(99,102,241,0.25)' : 'rgba(255,255,255,0.06)') + ';color:' + (isActive ? '#a5b4fc' : 'rgba(255,255,255,0.65)') + ';';
            pill.textContent = s + '×';
            pill.addEventListener('mouseenter', function() {
                if (parseFloat(this.dataset.speed) !== currentSpeed) {
                    this.style.background = 'rgba(255,255,255,0.12)';
                    this.style.color = '#fff';
                }
            });
            pill.addEventListener('mouseleave', function() {
                var spd = parseFloat(this.dataset.speed);
                this.style.background = spd === currentSpeed ? 'rgba(99,102,241,0.25)' : 'rgba(255,255,255,0.06)';
                this.style.color      = spd === currentSpeed ? '#a5b4fc' : 'rgba(255,255,255,0.65)';
                this.style.borderColor = spd === currentSpeed ? 'rgba(99,102,241,0.6)' : 'transparent';
            });
            pill.addEventListener('click', function(e) {
                e.stopPropagation();
                currentSpeed = parseFloat(this.dataset.speed);
                video.playbackRate = currentSpeed;
                speedBtn.textContent = currentSpeed + '×';
                var isNorm = currentSpeed === 1;
                speedBtn.style.color       = isNorm ? 'rgba(255,255,255,0.85)' : '#a5b4fc';
                speedBtn.style.borderColor = isNorm ? 'rgba(255,255,255,0.15)' : 'rgba(165,180,252,0.35)';
                speedBtn.style.background  = isNorm ? 'rgba(255,255,255,0.1)'  : 'rgba(99,102,241,0.2)';
                speedPills.querySelectorAll('button').forEach(function(p) {
                    var spd = parseFloat(p.dataset.speed);
                    p.style.background  = spd === currentSpeed ? 'rgba(99,102,241,0.25)' : 'rgba(255,255,255,0.06)';
                    p.style.color       = spd === currentSpeed ? '#a5b4fc' : 'rgba(255,255,255,0.65)';
                    p.style.borderColor = spd === currentSpeed ? 'rgba(99,102,241,0.6)' : 'transparent';
                });
                speedPills.style.display = 'none';
                row.style.display = 'flex';
            });
            speedPills.appendChild(pill);
        });

        var speedBtn = document.createElement('button');
        speedBtn.type = 'button';
        speedBtn.style.cssText = 'font-size:11px;font-weight:700;color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:6px;padding:4px 9px;cursor:pointer;white-space:nowrap;transition:all 0.15s;letter-spacing:0.03em;min-width:36px;text-align:center;';
        speedBtn.textContent = '1×';
        speedBtn.addEventListener('mouseenter', function() { if(currentSpeed===1) this.style.background='rgba(255,255,255,0.18)'; });
        speedBtn.addEventListener('mouseleave', function() { if(currentSpeed===1) this.style.background='rgba(255,255,255,0.1)'; });
        speedBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            var open = speedPills.style.display === 'flex';
            speedPills.style.display = open ? 'none' : 'flex';
            row.style.display        = open ? 'flex' : 'none';
        });

        document.addEventListener('click', function() {
            speedPills.style.display = 'none';
            row.style.display = 'flex';
        });

        speedWrap.appendChild(speedBtn);

        // ── Volume (icon + precise slider) ──
        var volGroup = document.createElement('div');
        volGroup.style.cssText = 'display:flex;align-items:center;gap:5px;flex-shrink:0;';

        var volBtn = mkBtn(
            '<svg class="vol-on" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>' +
            '<svg class="vol-off" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="display:none"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>'
        );

        // Volume slider container
        var volSliderWrap = document.createElement('div');
        volSliderWrap.style.cssText = 'position:relative;width:80px;height:20px;display:flex;align-items:center;cursor:pointer;flex-shrink:0;';

        var volTrack = document.createElement('div');
        volTrack.style.cssText = 'position:absolute;left:0;right:0;height:3px;background:rgba(255,255,255,0.18);border-radius:9999px;transition:height 0.15s;';

        var volFill = document.createElement('div');
        volFill.style.cssText = 'position:absolute;left:0;height:100%;width:100%;background:linear-gradient(to right,#a5b4fc,#818cf8);border-radius:9999px;pointer-events:none;';

        var volThumb = document.createElement('div');
        volThumb.style.cssText = 'position:absolute;top:50%;transform:translateY(-50%);width:11px;height:11px;background:#fff;border-radius:50%;pointer-events:none;left:calc(100% - 5.5px);opacity:0;transition:opacity 0.15s;box-shadow:0 1px 4px rgba(0,0,0,0.5);';

        volTrack.appendChild(volFill);
        volTrack.appendChild(volThumb);
        volSliderWrap.appendChild(volTrack);

        volSliderWrap.addEventListener('mouseenter', function() { volTrack.style.height='5px'; volThumb.style.opacity='1'; });
        volSliderWrap.addEventListener('mouseleave', function() { volTrack.style.height='3px'; volThumb.style.opacity='0'; });

        // Volume tooltip
        var volTooltip = document.createElement('span');
        volTooltip.style.cssText = 'position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:10px;font-weight:600;color:#fff;background:rgba(0,0,0,0.7);padding:2px 5px;border-radius:4px;pointer-events:none;opacity:0;transition:opacity 0.15s;white-space:nowrap;';
        volTooltip.textContent = '100%';
        volSliderWrap.appendChild(volTooltip);
        volSliderWrap.addEventListener('mouseenter', function() { volTooltip.style.opacity='1'; });
        volSliderWrap.addEventListener('mouseleave', function() { volTooltip.style.opacity='0'; });

        var isVolDragging = false;
        function setVolumeFromEvent(e) {
            var rect = volSliderWrap.getBoundingClientRect();
            var pct = Math.max(0, Math.min((e.clientX - rect.left) / rect.width, 1));
            video.volume = pct;
            video.muted = pct === 0;
            updateVol();
        }
        volSliderWrap.addEventListener('mousedown', function(e) { e.stopPropagation(); isVolDragging = true; setVolumeFromEvent(e); });
        document.addEventListener('mousemove', function(e) { if (isVolDragging) setVolumeFromEvent(e); });
        document.addEventListener('mouseup',   function()  { isVolDragging = false; });

        function updateVol() {
            var muted = video.muted || video.volume === 0;
            var pct = muted ? 0 : video.volume;
            volFill.style.width = (pct * 100) + '%';
            volThumb.style.left = 'calc(' + (pct * 100) + '% - 5.5px)';
            volTooltip.textContent = Math.round(pct * 100) + '%';
            volBtn.querySelector('.vol-on').style.display  = muted ? 'none' : '';
            volBtn.querySelector('.vol-off').style.display = muted ? '' : 'none';
        }

        volBtn.addEventListener('click', function(e) { e.stopPropagation(); video.muted = !video.muted; updateVol(); });

        volGroup.appendChild(volBtn);
        volGroup.appendChild(volSliderWrap);

        // Fullscreen
        var fsBtn = mkBtn(
