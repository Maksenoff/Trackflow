{% extends 'base.html.twig' %}

{% block title %}{{ athlete.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <a href="{{ path('app_athlete_index') }}" class="hover:text-white transition-colors">Athlètes</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">{{ athlete.fullName }}</span>
{% endblock %}

{% block body %}
<div class="space-y-6" x-data="{ activeTab: 'performances' }">

    {# Athlete header #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex items-start justify-between">
            <div class="flex items-center gap-5">
                <div class="w-20 h-20 rounded-xl bg-indigo-600/20 flex items-center justify-center text-indigo-300 font-bold text-2xl overflow-hidden shrink-0">
                    {% if athlete.photo %}
                        <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}" class="w-full h-full object-cover">
                    {% else %}
                        {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                    {% endif %}
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">{{ athlete.fullName }}</h1>
                    <p class="text-indigo-400 font-medium mt-0.5">{{ athlete.discipline }}</p>
                    <div class="flex items-center gap-4 mt-2 text-sm text-gray-400">
                        {% if athlete.age %}
                            <span>{{ athlete.age }} ans</span>
                        {% endif %}
                        {% if athlete.gender %}
                            <span>{{ athlete.gender == 'M' ? 'Homme' : (athlete.gender == 'F' ? 'Femme' : 'Autre') }}</span>
                        {% endif %}
                        <span>Suivi depuis {{ athlete.createdAt|date('F Y') }}</span>
                    </div>
                </div>
            </div>
            <div class="flex gap-2">
                <a href="{{ path('app_athlete_edit', {id: athlete.id}) }}"
                   class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Modifier
                </a>
                <form action="{{ path('app_athlete_delete', {id: athlete.id}) }}" method="post"
                      x-data onsubmit="return confirm('Supprimer cet athlète et toutes ses données ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ athlete.id) }}">
                    <button type="submit" class="flex items-center gap-2 bg-gray-800 hover:bg-red-900/50 hover:text-red-400 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Supprimer
                    </button>
                </form>
            </div>
        </div>

        {% if athlete.notes %}
            <div class="mt-4 pt-4 border-t border-gray-800 text-sm text-gray-400">
                {{ athlete.notes }}
            </div>
        {% endif %}

        {% if athlete.ffaProfileUrl %}
        <div class="mt-4 pt-4 border-t border-gray-800 flex items-center gap-3 text-sm">
            <span class="text-gray-500">Profil athle.fr :</span>
            <a href="{{ athlete.ffaProfileUrl }}" target="_blank" class="text-indigo-400 hover:text-indigo-300 truncate max-w-xs transition-colors">bases.athle.fr</a>
            <span id="ffa-sync-badge" class="flex items-center gap-1.5 text-gray-500">
                <svg id="ffa-spin" class="w-3.5 h-3.5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
                <span id="ffa-sync-text">Synchronisation…</span>
            </span>
        </div>
        {% endif %}

        {# Quick stats #}
        <div class="grid grid-cols-4 gap-4 mt-5 pt-5 border-t border-gray-800">
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.athleteSessions|length }}</p>
                <p class="text-sm text-gray-400">Séances</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.performances|length }}</p>
                <p class="text-sm text-gray-400">Performances</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.goals|filter(g => g.status == 'achieved')|length }}</p>
                <p class="text-sm text-gray-400">Objectifs atteints</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.goals|filter(g => g.status == 'in_progress')|length }}</p>
                <p class="text-sm text-gray-400">En cours</p>
            </div>
        </div>
    </div>

    {# Tabs #}
    <div class="flex gap-1 bg-gray-900 border border-gray-800 rounded-xl p-1">
        <button @click="activeTab = 'performances'"
                :class="activeTab === 'performances' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Performances
        </button>
        <button @click="activeTab = 'sessions'"
                :class="activeTab === 'sessions' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Séances
        </button>
        <button @click="activeTab = 'goals'"
                :class="activeTab === 'goals' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Objectifs
        </button>
        <button @click="activeTab = 'videos'; $nextTick(() => videoApp.load())"
                :class="activeTab === 'videos' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Vidéos
        </button>
    </div>

    {# Performances tab #}
    <div x-show="activeTab === 'performances'" x-transition
         x-data="perfTab({{ performancesJson|json_encode }})"
         x-init="init()">

        {# Header #}
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <h2 class="text-lg font-semibold text-white">Performances</h2>
                <span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded-full" x-text="filtered.length + ' résultat' + (filtered.length > 1 ? 's' : '')"></span>
            </div>
            <div class="flex items-center gap-2">
                {% if athlete.ffaProfileUrl %}
                <button id="manual-sync-btn"
                        onclick="triggerSync()"
                        class="flex items-center gap-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    <svg id="sync-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    <span id="sync-label">Sync athle.fr</span>
                </button>
                {% endif %}
                <a href="{{ path('app_performance_new', {athleteId: athlete.id}) }}"
                   class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Ajouter
                </a>
            </div>
        </div>

        <template x-if="allPerfs.length === 0">
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">
                Aucune performance enregistrée.
            </div>
        </template>

        <template x-if="allPerfs.length > 0">
            <div class="space-y-4">

                {# Season tabs #}
                <div class="flex flex-wrap gap-2">
                    <button @click="activeSeason = ''; activePage = 0"
                            :class="activeSeason === '' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'"
                            class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
                        Toutes
                        <span class="ml-1 text-xs opacity-70" x-text="'(' + allPerfs.length + ')'"></span>
                    </button>
                    <template x-for="[s, count] in seasons" :key="s">
                        <button @click="activeSeason = s; activePage = 0; activeDisc = ''; activeCat = ''"
                                :class="activeSeason === s ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'"
                                class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
                            <span x-text="s.replace('-20', '-')"></span>
                            <span class="ml-1 text-xs opacity-70" x-text="'(' + count + ')'"></span>
                        </button>
                    </template>
                </div>

                {# Discipline + category filters #}
                <div class="flex flex-wrap gap-2 items-center">
                    <span class="text-xs text-gray-500 mr-1">Discipline :</span>
                    <button @click="activeDisc = ''; activePage = 0"
                            :class="activeDisc === '' ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                            class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors">Toutes</button>
                    <template x-for="d in disciplines" :key="d">
                        <button @click="activeDisc = (activeDisc === d ? '' : d); activePage = 0"
                                :class="activeDisc === d ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                                class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors"
                                x-text="d"></button>
                    </template>

                    <template x-if="categories.length > 1">
                        <div class="flex flex-wrap gap-2 items-center ml-3">
                            <span class="text-xs text-gray-500 mr-1">Catégorie :</span>
                            <button @click="activeCat = ''; activePage = 0"
                                    :class="activeCat === '' ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                                    class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors">Toutes</button>
                            <template x-for="c in categories" :key="c">
                                <button @click="activeCat = (activeCat === c ? '' : c); activePage = 0"
                                        :class="activeCat === c ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                                        class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors"
                                        x-text="c"></button>
                            </template>
                        </div>
                    </template>
                </div>

                {# Results table #}
                <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wide">
                                <th class="text-left px-4 py-3 font-medium">Date</th>
                                <th class="text-left px-4 py-3 font-medium">Discipline</th>
                                <th class="text-left px-4 py-3 font-medium">Performance</th>
                                <th class="text-left px-4 py-3 font-medium hidden sm:table-cell">Saison</th>
                                <th class="text-left px-4 py-3 font-medium hidden md:table-cell">Catégorie</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800/60">
                            <template x-for="p in paginated" :key="p.id">
                                <tr class="hover:bg-gray-800/30 transition-colors group">
                                    <td class="px-4 py-3 text-gray-400 whitespace-nowrap" x-text="p.dateFormatted"></td>
                                    <td class="px-4 py-3">
                                        <span class="text-gray-300 font-medium" x-text="p.discipline"></span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2">
                                            <template x-if="p.isPersonalBest">
                                                <span title="Record personnel">⭐</span>
                                            </template>
                                            <span :class="p.isPersonalBest ? 'text-yellow-300 font-bold' : 'text-white font-medium'"
                                                  x-text="p.formattedValue"></span>
                                            <template x-if="p.isCompetition && !p.isPersonalBest">
                                                <span class="text-xs bg-blue-900/40 text-blue-400 px-1.5 py-0.5 rounded font-medium">Compét</span>
                                            </template>
                                        </div>
                                        <p x-show="p.notes" x-text="p.notes" class="text-xs text-gray-500 mt-0.5"></p>
                                    </td>
                                    <td class="px-4 py-3 hidden sm:table-cell">
                                        <span class="text-xs text-gray-500" x-text="p.season.replace('-20', '-')"></span>
                                    </td>
                                    <td class="px-4 py-3 hidden md:table-cell">
                                        <span x-show="p.category" x-text="p.category"
                                              class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded-full"></span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <a :href="p.editUrl" class="text-gray-500 hover:text-indigo-400 p-1 rounded transition-colors">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                            </a>
                                            <button @click="deletePerf(p)"
                                                    class="text-gray-500 hover:text-red-400 p-1 rounded transition-colors">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                            <tr x-show="filtered.length === 0">
                                <td colspan="6" class="px-4 py-10 text-center text-gray-500">Aucun résultat pour ces filtres.</td>
                            </tr>
                        </tbody>
                    </table>

                    {# Pagination #}
                    <div x-show="totalPages > 1" class="flex items-center justify-between px-4 py-3 border-t border-gray-800">
                        <span class="text-xs text-gray-500"
                              x-text="(activePage * pageSize + 1) + '–' + Math.min((activePage + 1) * pageSize, filtered.length) + ' sur ' + filtered.length"></span>
                        <div class="flex gap-1">
                            <button @click="activePage--" :disabled="activePage === 0"
                                    class="px-2.5 py-1 rounded text-xs bg-gray-800 text-gray-400 disabled:opacity-30 hover:text-white transition-colors">←</button>
                            <template x-for="i in totalPages" :key="i">
                                <button @click="activePage = i - 1"
                                        :class="activePage === i - 1 ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'"
                                        class="px-2.5 py-1 rounded text-xs transition-colors"
                                        x-text="i"></button>
                            </template>
                            <button @click="activePage++" :disabled="activePage >= totalPages - 1"
                                    class="px-2.5 py-1 rounded text-xs bg-gray-800 text-gray-400 disabled:opacity-30 hover:text-white transition-colors">→</button>
                        </div>
                    </div>
                </div>

                {# Charts per discipline (collapsible) #}
                {% if performancesByDiscipline is not empty %}
                <div x-data="{ chartsOpen: false }">
                    <button @click="chartsOpen = !chartsOpen"
                            class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
                        <svg :class="chartsOpen ? 'rotate-90' : ''" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        Graphiques de progression
                    </button>
                    <div x-show="chartsOpen" x-transition class="mt-3 space-y-4">
                        {% for discipline, perfs in performancesByDiscipline %}
                            {% if perfs|length > 1 %}
                            <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
                                <p class="text-sm font-medium text-gray-300 mb-3">{{ discipline }}</p>
                                <canvas id="chart-{{ loop.index }}" height="70"
                                        data-labels="{{ chartData[discipline].labels|json_encode }}"
                                        data-values="{{ chartData[discipline].values|json_encode }}"
                                        data-unit="{{ chartData[discipline].unit }}"
                                        data-higher-is-better="{{ chartData[discipline].higherIsBetter ? 'true' : 'false' }}"
                                        class="performance-chart">
                                </canvas>
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

            </div>
        </template>
    </div>

    {# Sessions tab #}
    <div x-show="activeTab === 'sessions'" x-transition>
        <div class="space-y-6">

            {# Séances à enregistrer #}
            {% if unloggedSessions is not empty %}
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <h2 class="text-base font-semibold text-white">Séances passées à enregistrer</h2>
                        <span class="text-xs bg-indigo-600/20 text-indigo-400 border border-indigo-600/30 px-2 py-0.5 rounded-full">
                            {{ unloggedSessions|length }}
                        </span>
                    </div>
                    <div class="space-y-2">
                        {% for session in unloggedSessions %}
                            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-indigo-600/40 transition-colors">
                                <div class="h-0.5" style="background: {{ session.colorBg }}"></div>
                                <div class="flex items-center justify-between px-4 py-3">
                                    <div class="flex items-center gap-4">
                                        <div class="text-center w-10 shrink-0">
                                            <p class="text-base font-bold text-white leading-none">{{ session.date|date('d') }}</p>
                                            <p class="text-xs text-gray-500 uppercase">{{ session.date|date('M') }}</p>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-white">{{ session.title }}</p>
                                            <div class="flex items-center gap-2 mt-0.5">
                                                <span class="text-xs px-1.5 py-0.5 rounded font-medium"
                                                      style="background: {{ session.colorBg }}22; color: {{ session.colorBg }}">
                                                    {{ session.typeLabel }}
                                                </span>
                                                {% if session.durationMinutes %}
                                                    <span class="text-xs text-gray-500">{{ session.durationMinutes }} min</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    <a href="{{ path('app_athlete_session_log', {athleteId: athlete.id, sessionId: session.id}) }}"
                                       class="flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors shrink-0">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                        Enregistrer mon ressenti
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Séances déjà enregistrées #}
            <div>
                <h2 class="text-base font-semibold text-white mb-3">Historique des séances</h2>
                {% if loggedSessions is empty %}
                    <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500 text-sm">
                        Aucune séance enregistrée pour l'instant.
                    </div>
                {% else %}
                    <div class="space-y-2">
                        {% for as in loggedSessions %}
                            {% set s = as.session %}
                            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                                <div class="h-0.5" style="background: {{ s.colorBg }}"></div>
                                <div class="px-4 py-3">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="flex items-start gap-4 flex-1 min-w-0">
                                            <div class="text-center w-10 shrink-0 pt-0.5">
                                                <p class="text-base font-bold text-white leading-none">{{ s.date|date('d') }}</p>
                                                <p class="text-xs text-gray-500 uppercase">{{ s.date|date('M') }}</p>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-sm font-medium text-white">{{ s.title }}</p>
                                                <div class="flex items-center gap-2 mt-0.5 flex-wrap">
                                                    <span class="text-xs px-1.5 py-0.5 rounded font-medium"
                                                          style="background: {{ s.colorBg }}22; color: {{ s.colorBg }}">
                                                        {{ s.typeLabel }}
                                                    </span>
                                                    {% if as.difficulty is not null %}
                                                        <span class="flex items-center gap-1 text-xs text-gray-400">
                                                            Difficulté :
                                                            <span class="font-bold
                                                                {% if as.difficulty <= 3 %}text-emerald-400
                                                                {% elseif as.difficulty <= 6 %}text-yellow-400
                                                                {% else %}text-red-400{% endif %}">
                                                                {{ as.difficulty }}/10
                                                            </span>
                                                        </span>
                                                    {% endif %}
                                                </div>
                                                {% if as.comment %}
                                                    <p class="text-xs text-gray-400 mt-1.5 italic leading-relaxed">"{{ as.comment }}"</p>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <div class="flex gap-1 shrink-0">
                                            <a href="{{ path('app_athlete_session_edit', {athleteId: athlete.id, id: as.id}) }}"
                                               class="text-gray-500 hover:text-indigo-400 p-1.5 rounded hover:bg-gray-800 transition-colors">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                            </a>
                                            <form action="{{ path('app_athlete_session_delete', {athleteId: athlete.id, id: as.id}) }}" method="post" class="inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-as' ~ as.id) }}">
                                                <button type="submit" onclick="return confirm('Supprimer ce ressenti ?')"
                                                        class="text-gray-500 hover:text-red-400 p-1.5 rounded hover:bg-gray-800 transition-colors">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Goals tab #}
    <div x-show="activeTab === 'goals'" x-transition>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-white">Objectifs</h2>
            <a href="{{ path('app_goal_new', {athleteId: athlete.id}) }}"
               class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter
            </a>
        </div>

        {% if athlete.goals is empty %}
            <div id="goals-empty" class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">
                Aucun objectif défini.
            </div>
        {% else %}
            <div id="goals-list" class="space-y-3">
                {% for goal in athlete.goals %}
                    <div id="goal-{{ goal.id }}"
                         class="bg-gray-900 border rounded-xl px-5 py-4 transition-all
                        {% if goal.isAchieved %}border-emerald-800/50
                        {% elseif goal.isOverdue %}border-red-800/50
                        {% else %}border-gray-800{% endif %}">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-start gap-3">
                                <button type="button"
                                        onclick="goalToggle({{ goal.id }}, '{{ path('app_goal_toggle', {athleteId: athlete.id, id: goal.id}) }}', '{{ csrf_token('toggle-goal' ~ goal.id) }}')"
                                        class="mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-colors shrink-0
                                        {% if goal.isAchieved %}border-emerald-500 bg-emerald-500{% else %}border-gray-600 hover:border-emerald-500{% endif %}">
                                    {% if goal.isAchieved %}
                                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    {% endif %}
                                </button>
                                <div>
                                    <p class="font-medium {% if goal.isAchieved %}text-emerald-400 line-through{% else %}text-white{% endif %}">
                                        {{ goal.title }}
                                    </p>
                                    <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
                                        {% if goal.discipline %}
                                            <span>{{ goal.discipline }}</span>
                                        {% endif %}
                                        {% if goal.targetValue %}
                                            <span>Cible : {{ goal.targetValue }} {{ goal.unit }}</span>
                                        {% endif %}
                                        {% if goal.deadline %}
                                            <span class="{% if goal.isOverdue and not goal.isAchieved %}text-red-400{% endif %}">
                                                Échéance : {{ goal.deadline|date('d/m/Y') }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    {% if goal.notes %}
                                        <p class="text-xs text-gray-500 mt-1">{{ goal.notes }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <span class="goal-status-badge text-xs px-2 py-0.5 rounded-full font-medium
                                    {% if goal.isAchieved %}bg-emerald-900/50 text-emerald-400
                                    {% elseif goal.isOverdue %}bg-red-900/50 text-red-400
                                    {% else %}bg-blue-900/50 text-blue-400{% endif %}">
                                    {% if goal.isAchieved %}Atteint
                                    {% elseif goal.isOverdue %}En retard
                                    {% else %}En cours{% endif %}
                                </span>
                                <a href="{{ path('app_goal_edit', {athleteId: athlete.id, id: goal.id}) }}"
                                   class="text-gray-500 hover:text-indigo-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <button type="button"
                                        onclick="goalDelete({{ goal.id }}, '{{ path('app_goal_delete', {athleteId: athlete.id, id: goal.id}) }}', '{{ csrf_token('delete-goal' ~ goal.id) }}')"
                                        class="text-gray-500 hover:text-red-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

<script>
function goalToggle(id, url, token) {
    fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: '_token=' + encodeURIComponent(token)
    })
    .then(r => r.json())
    .then(data => {
        var el = document.getElementById('goal-' + id);
        if (!el) return;
        var btn = el.querySelector('button[onclick^="goalToggle"]');
        var title = el.querySelector('p.font-medium');
        var badge = el.querySelector('.goal-status-badge');

        if (data.achieved) {
            el.className = el.className.replace(/border-\S+/g, '').trim() + ' border-emerald-800/50';
            btn.className = btn.className.replace(/border-\S+|bg-\S+/g, '').trim() + ' border-emerald-500 bg-emerald-500';
            btn.innerHTML = '<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
            title.className = title.className.replace('text-white', 'text-emerald-400') + ' line-through';
            badge.className = badge.className.replace(/bg-\S+|text-\S+400/g, '').trim() + ' bg-emerald-900/50 text-emerald-400';
            badge.textContent = 'Atteint';
        } else {
            el.className = el.className.replace(/border-\S+/g, '').trim() + ' border-gray-800';
            btn.className = btn.className.replace(/border-\S+|bg-\S+/g, '').trim() + ' border-gray-600 hover:border-emerald-500';
            btn.innerHTML = '';
            title.className = title.className.replace('text-emerald-400', 'text-white').replace(' line-through', '');
            badge.className = badge.className.replace(/bg-\S+|text-\S+400/g, '').trim() + ' bg-blue-900/50 text-blue-400';
            badge.textContent = 'En cours';
        }
    })
    .catch(() => location.reload());
}

function goalDelete(id, url, token) {
    if (!confirm('Supprimer cet objectif ?')) return;
    fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: '_token=' + encodeURIComponent(token)
    })
    .then(r => r.json())
    .then(() => {
        var el = document.getElementById('goal-' + id);
        if (el) el.remove();
        var list = document.getElementById('goals-list');
        if (list && list.children.length === 0) {
            list.outerHTML = '<div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">Aucun objectif défini.</div>';
        }
    })
    .catch(() => location.reload());
}
</script>

    {# Videos tab #}
    <div x-show="activeTab === 'videos'" x-transition id="videos-tab">

        {# Upload — compact collapsible #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-4" x-data="{ uploadOpen: false }">

            {# Toggle header #}
            <button type="button" @click="uploadOpen = !uploadOpen"
                    class="w-full flex items-center gap-3 px-4 py-3 hover:bg-gray-800/60 transition-colors">
                <div class="w-7 h-7 rounded-lg bg-indigo-600/20 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                    </svg>
                </div>
                <span class="text-sm font-medium text-white">Ajouter une vidéo</span>
                <svg :class="uploadOpen ? 'rotate-180' : ''" class="w-4 h-4 text-gray-500 transition-transform ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>

            {# Collapsible form #}
            <div x-show="uploadOpen" x-transition class="border-t border-gray-800">
                <form id="video-upload-form" class="p-4 space-y-3">

                    {# File picker row #}
                    <div id="video-dropzone"
                         class="flex items-center gap-3 bg-gray-800/60 border border-dashed border-gray-600 hover:border-indigo-500 hover:bg-indigo-500/5 rounded-lg px-3 py-2.5 cursor-pointer transition-all group"
                         onclick="document.getElementById('video-file-input').click()">
                        <svg class="w-4 h-4 text-gray-500 group-hover:text-indigo-400 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <span id="video-file-label" class="text-xs text-gray-400 group-hover:text-gray-200 transition-colors flex-1">Choisir un fichier — MP4, MOV, AVI… max 500 Mo</span>
                        <input type="file" name="video" id="video-file-input" accept="video/*" required class="hidden">
                    </div>

                    {# Preview selected file #}
                    <div id="video-file-preview" class="hidden items-center gap-2.5 bg-indigo-600/10 border border-indigo-600/30 rounded-lg px-3 py-2">
                        <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <div class="flex-1 min-w-0">
                            <p id="vdz-filename" class="text-xs font-medium text-white truncate"></p>
                            <p id="vdz-filesize" class="text-xs text-indigo-300/70"></p>
                        </div>
                        <button type="button" onclick="videoClearFile()" class="text-gray-500 hover:text-red-400 transition-colors shrink-0">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>

                    {# Title + category #}
                    <div class="grid grid-cols-2 gap-2">
                        <input type="text" name="title" required placeholder="Titre de la vidéo *"
                               class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500">
                        <select name="discipline"
                                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-indigo-500">
                            <option value="">— Catégorie —</option>
                            {% for label, value in constant('App\\Entity\\Performance::DISCIPLINES') %}
                                <option value="{{ value }}">{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Submit #}
                    <div class="flex justify-end">
                        <button type="submit" id="video-submit-btn"
                                class="flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-xs font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                            </svg>
                            Envoyer
                        </button>
                    </div>

                    {# Progress #}
                    <div id="video-progress-wrap" class="hidden">
                        <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
                            <span>Envoi en cours…</span>
                            <span id="video-progress-pct"></span>
                        </div>
                        <div class="w-full bg-gray-800 rounded-full h-1 overflow-hidden">
                            <div id="video-progress-bar" class="h-1 rounded-full bg-indigo-500" style="width:0%;transition:width 0.2s ease"></div>
