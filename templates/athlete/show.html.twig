        var vTooltip = document.createElement('span');
        vTooltip.style.cssText = 'position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:10px;font-weight:600;color:#fff;background:rgba(0,0,0,0.7);padding:2px 5px;border-radius:4px;pointer-events:none;opacity:0;transition:opacity 0.15s;white-space:nowrap;';
