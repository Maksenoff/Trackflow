        vidWrap.appendChild(vid);

        // Title
        var titleEl = document.createElement('p');
        titleEl.style.cssText = 'font-size:12px;font-weight:600;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0 2px;';
        titleEl.textContent = v.title;

        // Volume bar (below video)
