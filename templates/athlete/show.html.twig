        vThumb.style.cssText = 'position:absolute;top:50%;transform:translateY(-50%);width:11px;height:11px;background:#fff;border-radius:50%;pointer-events:none;left:calc(100% - 5.5px);opacity:0;transition:opacity 0.15s;box-shadow:0 1px 4px rgba(0,0,0,0.5);';

        vTrack.appendChild(vFill);
