                    <div id="video-upload-error" class="hidden text-xs text-red-400 bg-red-900/20 border border-red-800/40 rounded-lg px-3 py-2"></div>

                </form>
            </div>
        </div>

        {# Videos list #}
        <div id="videos-container">
            <div id="videos-loading" class="text-center py-10 text-gray-500 text-sm">Chargement…</div>
        </div>

    </div>

</div>

<script>
(function () {
    var athleteId = {{ athlete.id }};
    var uploadUrl = '{{ path('app_athlete_video_upload', {athleteId: athlete.id}) }}';
    var listUrl   = '{{ path('app_athlete_videos', {athleteId: athlete.id}) }}';

    var loaded = false;

    window.videoApp = {
        load: function () {
            if (loaded) return;
            loaded = true;
            fetch(listUrl, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
                .then(r => r.json())
                .then(data => renderVideos(data.videos))
                .catch(() => { document.getElementById('videos-loading').textContent = 'Erreur de chargement.'; });
        }
    };

    function renderVideos(videos) {
        var container = document.getElementById('videos-container');
        container.innerHTML = '';
        if (!videos.length) {
            container.innerHTML = '<div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500 text-sm">Aucune vidéo pour l\'instant.</div>';
            return;
        }

        // Group by discipline preserving insertion order
        var groups = {}, order = [];
        videos.forEach(function (v) {
            var key = v.discipline || '';
            if (!groups[key]) { groups[key] = []; order.push(key); }
            groups[key].push(v);
        });

        var wrap = document.createElement('div');
        wrap.className = 'space-y-3';

        order.forEach(function (disc, idx) {
            var label   = disc || 'Sans catégorie';
            var catVids = groups[disc];
            var isOpen  = idx === 0;

            var acc = document.createElement('div');
            acc.className = 'bg-gray-900 border border-gray-800 rounded-xl overflow-hidden';

            // ── Header ──
            var header = document.createElement('button');
            header.type = 'button';
            header.style.cssText = 'width:100%;display:flex;align-items:center;justify-content:space-between;padding:20px 24px;background:none;border:none;cursor:pointer;transition:background 0.15s';
            header.onmouseenter = function(){ this.style.background='rgba(255,255,255,0.04)'; };
            header.onmouseleave = function(){ this.style.background='none'; };
            header.innerHTML =
                '<div style="display:flex;align-items:center;gap:12px">'
                + '<span style="font-weight:600;color:white;font-size:15px">' + escHtml(label) + '</span>'
                + '<span style="font-size:11px;background:#1f2937;color:#9ca3af;padding:3px 10px;border-radius:999px">' + catVids.length + '</span>'
                + '</div>'
                + '<svg class="cat-arrow" style="width:18px;height:18px;color:#6b7280;transition:transform 0.2s;transform:rotate(' + (isOpen ? '180' : '0') + 'deg);flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">'
                + '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';

            // ── Body ──
            var body = document.createElement('div');
            body.className = 'border-t border-gray-800';
            if (!isOpen) body.style.display = 'none';

            // Search bar
            var searchWrap = document.createElement('div');
            searchWrap.style.cssText = 'padding:14px 24px;border-bottom:1px solid rgba(255,255,255,0.06)';
            var searchInput = document.createElement('input');
            searchInput.type = 'text';
            searchInput.placeholder = 'Rechercher dans ' + label + '…';
            searchInput.style.cssText = 'width:100%;background:#1f2937;border:1px solid #374151;border-radius:8px;padding:10px 14px;font-size:13px;color:white;outline:none;box-sizing:border-box';
            searchInput.onfocus   = function(){ this.style.borderColor='#6366f1'; };
            searchInput.onblur    = function(){ this.style.borderColor='#374151'; };
            searchWrap.appendChild(searchInput);

            // Video grid
            var grid = document.createElement('div');
            grid.className = 'p-4 grid grid-cols-3 gap-2 sm:grid-cols-4';

            catVids.forEach(function (v) { grid.appendChild(createVideoCard(v)); });

            searchInput.addEventListener('input', function () {
                var q = this.value.toLowerCase().trim();
                grid.querySelectorAll('.video-card').forEach(function (c) {
                    c.style.display = (!q || c.dataset.title.toLowerCase().includes(q)) ? '' : 'none';
                });
            });

            header.addEventListener('click', function () {
                isOpen = !isOpen;
                body.style.display = isOpen ? '' : 'none';
                header.querySelector('.cat-arrow').style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
            });

            body.appendChild(searchWrap);
            body.appendChild(grid);
            acc.appendChild(header);
            acc.appendChild(body);
            wrap.appendChild(acc);
        });

        container.appendChild(wrap);
    }

    function fmtTime(s) {
        if (isNaN(s)) return '0:00';
        var m = Math.floor(s / 60), sec = Math.floor(s % 60);
        return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function createVideoCard(v) {
        var card = document.createElement('div');
        card.className = 'video-card bg-gray-800/50 border border-gray-700/60 rounded-xl overflow-hidden';
        card.id = 'vcard-' + v.id;
        card.dataset.title = v.title;

        // ── Video wrapper (overflow-hidden clips the controls inside) ──
        var wrapper = document.createElement('div');
        wrapper.className = 'relative bg-black overflow-hidden';
        wrapper.style.aspectRatio = '16/9';

        var video = document.createElement('video');
        video.src = v.url;
        video.preload = 'metadata';
        video.className = 'w-full h-full object-contain cursor-pointer block';

        // ── Controls overlay (absolute, covers whole video area, flex-col justify-end) ──
        var ctrl = document.createElement('div');
        ctrl.style.cssText = 'position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;opacity:0;transition:opacity 0.15s;background:linear-gradient(to top,rgba(0,0,0,0.88) 0%,rgba(0,0,0,0.25) 55%,transparent 100%)';

        var ctrlInner = document.createElement('div');
        ctrlInner.style.cssText = 'padding:0 8px 6px';

        // Scrubber — native range input, styled via accent-color
        var scrubber = document.createElement('input');
        scrubber.type = 'range';
        scrubber.min = '0'; scrubber.max = '1000'; scrubber.value = '0';
        scrubber.style.cssText = 'display:block;width:100%;height:4px;margin-bottom:6px;cursor:pointer;accent-color:#6366f1;border-radius:9999px;outline:none;-webkit-appearance:none;appearance:none;background:rgba(255,255,255,0.25)';

        // Controls row
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:6px';

        // Play/pause
        var playBtn = document.createElement('button');
        playBtn.type = 'button';
        playBtn.style.cssText = 'color:white;background:none;border:none;padding:2px;cursor:pointer;flex-shrink:0;display:flex;align-items:center';
        playBtn.innerHTML = '<svg class="play-icon" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'
            + '<svg class="pause-icon" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';

        // Time
        var timeEl = document.createElement('span');
        timeEl.style.cssText = 'font-size:11px;color:#d1d5db;font-variant-numeric:tabular-nums;white-space:nowrap;flex-shrink:0';
        timeEl.textContent = '0:00';

        var spacer = document.createElement('span');
        spacer.style.flex = '1';

        // Speed — cycling button (0.25 → 0.5 → 1 → 1.25 → 1.5 → 2 → loop)
        // Speed <select>
        var speedBtn = document.createElement('select');
        speedBtn.style.cssText = 'font-size:11px;font-weight:600;color:white;background:rgba(20,20,30,0.85);border:1px solid rgba(255,255,255,0.2);border-radius:4px;padding:2px 4px;cursor:pointer;flex-shrink:0;outline:none';
        [0.25, 0.5, 1, 1.25, 1.5, 2].forEach(function (s) {
            var opt = document.createElement('option');
            opt.value = s; opt.textContent = s + '×'; if (s === 1) opt.selected = true;
            speedBtn.appendChild(opt);
        });

        // Fullscreen
        var fsBtn = document.createElement('button');
        fsBtn.type = 'button';
        fsBtn.style.cssText = 'color:white;background:none;border:none;padding:2px;cursor:pointer;flex-shrink:0;display:flex;align-items:center';
        fsBtn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>';

        row.appendChild(playBtn);
        row.appendChild(timeEl);
        row.appendChild(spacer);
        row.appendChild(speedBtn);
        row.appendChild(fsBtn);
        ctrlInner.appendChild(scrubber);
        ctrlInner.appendChild(row);
        ctrl.appendChild(ctrlInner);
        wrapper.appendChild(video);
        wrapper.appendChild(ctrl);

        // Hover
        wrapper.addEventListener('mouseenter', function () { ctrl.style.opacity = '1'; });
        wrapper.addEventListener('mouseleave', function () { ctrl.style.opacity = '0'; });

        // Play / pause — clic sur toute la zone vidéo (ctrl couvre la vidéo)
        function togglePlay() { video.paused ? video.play() : video.pause(); }
        // ctrl intercepts all clicks on the video area; buttons stop propagation
        ctrl.addEventListener('click', function () { togglePlay(); });
        playBtn.addEventListener('click', function (e) { e.stopPropagation(); togglePlay(); });
        video.addEventListener('play',  function () { playBtn.querySelector('.play-icon').style.display  = 'none';  playBtn.querySelector('.pause-icon').style.display = ''; });
        video.addEventListener('pause', function () { playBtn.querySelector('.play-icon').style.display  = '';      playBtn.querySelector('.pause-icon').style.display = 'none'; });

        // Scrubber sync
        video.addEventListener('loadedmetadata', function () {
            timeEl.textContent = '0:00 / ' + fmtTime(video.duration);
        });
        video.addEventListener('timeupdate', function () {
            if (video.duration > 0) {
                scrubber.value = Math.round(video.currentTime / video.duration * 1000);
                timeEl.textContent = fmtTime(video.currentTime) + ' / ' + fmtTime(video.duration);
            }
        });
        scrubber.addEventListener('mousedown', function (e) { e.stopPropagation(); });
        scrubber.addEventListener('input', function (e) {
            e.stopPropagation();
            if (video.duration > 0) video.currentTime = (this.value / 1000) * video.duration;
        });

        // Speed select
        speedBtn.addEventListener('change', function (e) {
            e.stopPropagation();
            video.playbackRate = parseFloat(this.value);
        });
        speedBtn.addEventListener('click', function (e) { e.stopPropagation(); });

        // Fullscreen
        fsBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var el = wrapper;
            (el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen || function(){}).call(el);
        });

        // ── Info row ──
        var info = document.createElement('div');
        info.style.cssText = 'padding:8px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px';

        var infoText = document.createElement('div');
        infoText.style.cssText = 'min-width:0;flex:1';
        infoText.innerHTML = '<p style="font-size:11px;font-weight:600;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + escHtml(v.title) + '</p>'
            + '<p style="font-size:10px;color:#6b7280;margin-top:2px">' + v.createdAt + '</p>';

        var delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.style.cssText = 'color:#6b7280;background:none;border:none;cursor:pointer;padding:2px;flex-shrink:0;margin-top:1px';
        delBtn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
        delBtn.addEventListener('mouseover', function () { this.style.color = '#f87171'; });
        delBtn.addEventListener('mouseout',  function () { this.style.color = '#6b7280'; });
        delBtn.addEventListener('click', function () {
            if (!confirm('Supprimer cette vidéo ?')) return;
            fetch('/athletes/' + athleteId + '/videos/' + v.id + '/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                body: '_token=' + encodeURIComponent(v.csrfToken || '')
            }).then(r => r.json()).then(function (d) {
                if (d.success) {
                    card.remove();
                    if (!document.querySelector('[id^="vcard-"]')) renderVideos([]);
                }
            }).catch(function () { location.reload(); });
        });

        info.appendChild(infoText);
        info.appendChild(delBtn);
        card.appendChild(wrapper);
        card.appendChild(info);
        return card;
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── File selection & drag-drop ──
    var dropzone = document.getElementById('video-dropzone');
    var fileInput = document.getElementById('video-file-input');

    fileInput.addEventListener('change', function () {
        if (this.files[0]) showFilePreview(this.files[0]);
    });

    var MAX_SIZE = 500 * 1024 * 1024; // 500 Mo

    function showFilePreview(file) {
        var err = document.getElementById('video-upload-error');
        if (file.size > MAX_SIZE) {
            err.textContent = 'Fichier trop lourd : ' + formatBytes(file.size) + ' — maximum 500 Mo.';
            err.classList.remove('hidden');
            fileInput.value = '';
            return;
        }
        err.classList.add('hidden');
        dropzone.classList.add('hidden');
        var preview = document.getElementById('video-file-preview');
        preview.classList.remove('hidden');
        preview.classList.add('flex');
        document.getElementById('vdz-filename').textContent = file.name;
        document.getElementById('vdz-filesize').textContent = formatBytes(file.size);
    }

    window.videoClearFile = function () {
        fileInput.value = '';
        document.getElementById('video-file-preview').classList.add('hidden');
        document.getElementById('video-file-preview').classList.remove('flex');
        dropzone.classList.remove('hidden');
        document.getElementById('video-file-label').textContent = 'Choisir un fichier — MP4, MOV, AVI… max 500 Mo';
    };

    function formatBytes(bytes) {
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' Ko';
        return (bytes / (1024 * 1024)).toFixed(1) + ' Mo';
    }

    // Drag & drop onto dropzone
    ['dragenter', 'dragover'].forEach(function (evt) {
        dropzone.addEventListener(evt, function (e) {
            e.preventDefault();
            dropzone.classList.add('border-indigo-500', 'bg-indigo-500/10');
        });
    });
    ['dragleave', 'drop'].forEach(function (evt) {
        dropzone.addEventListener(evt, function (e) {
            e.preventDefault();
            dropzone.classList.remove('border-indigo-500', 'bg-indigo-500/10');
        });
    });
    dropzone.addEventListener('drop', function (e) {
        e.preventDefault();
        var file = e.dataTransfer.files[0];
        if (!file) return;
        var dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;
        showFilePreview(file);
    });

    // ── Upload submit ──
    document.getElementById('video-upload-form').addEventListener('submit', function (e) {
        e.preventDefault();
        if (!fileInput.files[0]) return;
        var form = this;
        var btn  = document.getElementById('video-submit-btn');
        var err  = document.getElementById('video-upload-error');
        var progressWrap = document.getElementById('video-progress-wrap');
        var progressBar  = document.getElementById('video-progress-bar');
        var progressPct  = document.getElementById('video-progress-pct');

        err.classList.add('hidden');
        btn.disabled = true;
        progressWrap.classList.remove('hidden');
        progressBar.style.width = '0%';

        var fd = new FormData(form);
        var xhr = new XMLHttpRequest();
        var animRunning = true;
        var fakePct = 5;
        var lastTs = null;

        progressBar.style.width = '5%';
        progressPct.textContent = '5%';

        // rAF animation — runs every frame (~16ms), immune to fast server responses
        function animStep(ts) {
            if (!animRunning) return;
            if (!lastTs) lastTs = ts;
            var delta = ts - lastTs;
            lastTs = ts;
            if (fakePct < 88) {
                fakePct += delta * 0.04; // ~4% per 100ms
                if (fakePct > 88) fakePct = 88;
                progressBar.style.width = fakePct.toFixed(1) + '%';
                progressPct.textContent = Math.round(fakePct) + '%';
            }
            requestAnimationFrame(animStep);
        }
        requestAnimationFrame(animStep);
        var fakeTimer = { cancel: function() { animRunning = false; } };

        function finishUpload(success, errorMsg) {
            fakeTimer.cancel();
            btn.disabled = false;

            if (!success) {
                progressWrap.classList.add('hidden');
                progressBar.style.width = '0%';
                err.textContent = errorMsg;
                err.classList.remove('hidden');
                return;
            }

            // Animate to 100% then hide
            progressBar.style.width = '100%';
            progressPct.textContent = '100%';
            setTimeout(function () {
                progressWrap.classList.add('hidden');
                progressBar.style.width = '0%';
            }, 500);

            form.reset();
            videoClearFile();
            fetch(listUrl, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
                .then(r => r.json())
                .then(d => { loaded = true; renderVideos(d.videos); });
        }

        xhr.addEventListener('load', function () {
            console.log('[VIDEO UPLOAD] status:', xhr.status, 'response:', xhr.responseText.substring(0, 500));
            var data;
            try { data = JSON.parse(xhr.responseText); } catch (ex) {
                // Extraire le message d'erreur Symfony depuis le HTML
                var match = xhr.responseText.match(/<title[^>]*>([^<]+)<\/title>/i)
                         || xhr.responseText.match(/class="exception-message[^"]*">([^<]+)</i);
                var msg = match ? match[1].trim() : ('Erreur serveur ' + xhr.status + ' — voir console F12');
                finishUpload(false, msg);
                return;
            }
            if (xhr.status >= 400) {
                finishUpload(false, data.error || 'Erreur serveur (' + xhr.status + ').');
                return;
            }
            finishUpload(true);
        });

        xhr.addEventListener('error', function () {
            finishUpload(false, 'Erreur réseau lors de l\'upload.');
        });

        xhr.open('POST', uploadUrl);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.send(fd);
    });
}());

