        delBtn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
        delBtn.addEventListener('mouseover', function () { this.style.color = '#f87171'; });
        delBtn.addEventListener('mouseout',  function () { this.style.color = '#6b7280'; });
        delBtn.addEventListener('click', function () {
            if (!confirm('Supprimer cette vidéo ?')) return;
            fetch('/athletes/' + athleteId + '/videos/' + v.id + '/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                body: '_token=' + encodeURIComponent(v.csrfToken || '')
            }).then(r => r.json()).then(function (d) {
                if (d.success) {
                    card.remove();
