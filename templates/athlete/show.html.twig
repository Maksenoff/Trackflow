// ── Performances tab Alpine component ──────────────────────────────────────
function perfTab(data) {
    return {
        allPerfs:    data,
        activeSeason: '',
        activeDisc:   '',
        activeCat:    '',
        activePage:   0,
        pageSize:     50,

        init() {
            // Default to latest season
            if (this.seasons.length) {
                this.activeSeason = this.seasons[0][0];
            }
        },

        get seasons() {
            const counts = {};
            this.allPerfs.forEach(p => { counts[p.season] = (counts[p.season] || 0) + 1; });
            return Object.entries(counts).sort((a, b) => b[0].localeCompare(a[0]));
        },

        get disciplines() {
            const src = this.activeSeason ? this.allPerfs.filter(p => p.season === this.activeSeason) : this.allPerfs;
            return [...new Set(src.map(p => p.discipline))].sort();
        },

        get categories() {
            const src = this.activeSeason ? this.allPerfs.filter(p => p.season === this.activeSeason) : this.allPerfs;
            const cats = [...new Set(src.map(p => p.category).filter(Boolean))];
            const order = ['Poussin','Benjamin','Minime','Cadet','Junior','Espoir','Senior','Master'];
            return cats.sort((a, b) => order.indexOf(a) - order.indexOf(b));
        },

        get filtered() {
            return this.allPerfs.filter(p => {
                if (this.activeSeason && p.season !== this.activeSeason) return false;
                if (this.activeDisc   && p.discipline !== this.activeDisc) return false;
                if (this.activeCat    && p.category   !== this.activeCat)  return false;
                return true;
            });
        },

        get totalPages() {
            return Math.ceil(this.filtered.length / this.pageSize);
        },

        get paginated() {
            const start = this.activePage * this.pageSize;
            return this.filtered.slice(start, start + this.pageSize);
        },

        deletePerf(p) {
            if (!confirm('Supprimer cette performance ?')) return;
            const fd = new FormData();
            fd.append('_token', p.csrfToken);
            fetch(p.deleteUrl, { method: 'POST', body: fd })
                .then(r => r.ok ? (this.allPerfs = this.allPerfs.filter(x => x.id !== p.id)) : alert('Erreur suppression'));
        },
    };
}

// ── Manual sync button ──────────────────────────────────────────────────────
function triggerSync() {
    var btn   = document.getElementById('manual-sync-btn');
    var icon  = document.getElementById('sync-icon');
    var label = document.getElementById('sync-label');
    if (!btn) return;
    btn.disabled = true;
    icon.classList.add('animate-spin');
    label.textContent = 'Synchronisation…';

    fetch('{{ path('app_athlete_sync_ffa', {id: athlete.id}) }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        icon.classList.remove('animate-spin');
        btn.disabled = false;
        if (data.error) {
            label.textContent = data.error;
        } else if (data.cached) {
            label.textContent = 'À jour · ' + data.lastSync;
        } else if (data.imported > 0) {
            label.textContent = data.imported + ' résultat(s) importé(s) !';
            setTimeout(() => location.reload(), 1200);
        } else {
            label.textContent = 'Déjà à jour';
        }
    })
    .catch(() => { icon.classList.remove('animate-spin'); btn.disabled = false; label.textContent = 'Erreur réseau'; });
}
