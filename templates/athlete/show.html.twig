            vFill.style.width = (pct * 100) + '%';
            vThumb.style.left = 'calc(' + (pct * 100) + '% - 5.5px)';
            vTooltip.textContent = Math.round(pct * 100) + '%';
            vBtn.querySelector('.vol-on').style.display  = muted ? 'none' : '';
            vBtn.querySelector('.vol-off').style.display = muted ? '' : 'none';
