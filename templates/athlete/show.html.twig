        modal.appendChild(header);
        modal.appendChild(body);
        modal.appendChild(footer);
        overlay.appendChild(modal);
        document.body.appendChild(overlay);

        // Close logic
        function closeModal() {
            vid1.pause();
            vid2.pause();
            // Reset compare state
            compareSelected = [];
            document.querySelectorAll('.video-card').forEach(function(c) {
                var ov = c._compareOverlay;
                if (ov) {
                    ov.style.borderColor = 'transparent';
                    ov.style.background = 'transparent';
                    var ck = ov.querySelector('div');
                    if (ck) ck.style.display = 'none';
                }
            });
            overlay.remove();
        }

        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });

        function onKeyDown(e) {
            if (e.key === 'Escape') { closeModal(); document.removeEventListener('keydown', onKeyDown); }
        }
        document.addEventListener('keydown', onKeyDown);
        overlay.addEventListener('remove', function() { document.removeEventListener('keydown', onKeyDown); });
    }

}());

