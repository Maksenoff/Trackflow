(function () {
    var syncUrl  = '{{ path('app_athlete_sync_ffa', {id: athlete.id}) }}';
    var badge    = document.getElementById('ffa-sync-badge');
    var spin     = document.getElementById('ffa-spin');
    var syncText = document.getElementById('ffa-sync-text');

    function setSyncStatus(text, color) {
        syncText.textContent = text;
        badge.style.color = color || '';
        spin.classList.add('hidden');
    }

    // Show spinner
    spin.classList.remove('hidden');

    fetch(syncUrl, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.error) {
            setSyncStatus('Sync FFA : ' + data.error, '#9ca3af');
        } else if (data.cached) {
            setSyncStatus('Synchronisé à ' + data.lastSync, '#6b7280');
        } else if (data.imported > 0) {
            setSyncStatus(data.imported + ' résultat(s) importé(s) depuis athle.fr', '#34d399');
            // Reload page to show new performances
            setTimeout(function() { location.reload(); }, 1500);
        } else {
            setSyncStatus('Déjà à jour · ' + data.lastSync, '#6b7280');
        }
    })
    .catch(function() {
        setSyncStatus('Sync FFA indisponible', '#6b7280');
    });
}());
