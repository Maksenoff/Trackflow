{% extends 'base.html.twig' %}

{% block title %}{{ athlete.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <a href="{{ path('app_athlete_index') }}" class="hover:text-white transition-colors">Athlètes</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">{{ athlete.fullName }}</span>
{% endblock %}

{% block body %}
<div class="space-y-6" x-data="{ activeTab: 'performances', deleteOpen: false }">

    {# Athlete header #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex items-start justify-between">
            <div class="flex items-center gap-5">
                <div class="w-20 h-20 rounded-xl bg-indigo-600/20 flex items-center justify-center text-indigo-300 font-bold text-2xl overflow-hidden shrink-0">
                    {% if athlete.photo %}
                        <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}" class="w-full h-full object-cover">
                    {% else %}
                        {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                    {% endif %}
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">{{ athlete.fullName }}</h1>
                    <div class="flex flex-wrap gap-2 mt-2">
                        {% for disc in athlete.disciplines %}
                            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-200 bg-indigo-600/20 border border-indigo-500/30 px-3 py-1 rounded-lg">
                                <svg class="w-3.5 h-3.5 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                                {{ disc|capitalize }}
                            </span>
                        {% else %}
                            <span class="text-sm text-gray-500">Aucune discipline</span>
                        {% endfor %}
                    </div>
                    <div class="flex items-center gap-4 mt-2 text-sm text-gray-400">
                        {% if athlete.age %}
                            <span>{{ athlete.age }} ans</span>
                        {% endif %}
                        {% if athlete.gender %}
                            <span>{{ athlete.gender == 'M' ? 'Homme' : (athlete.gender == 'F' ? 'Femme' : 'Autre') }}</span>
                        {% endif %}
                        <span>Suivi depuis {{ athlete.createdAt|date('F Y') }}</span>
                    </div>
                </div>
            </div>
            <div class="flex gap-2">
                {% if canEdit %}
                <a href="{{ path('app_athlete_edit', {id: athlete.id}) }}"
                   class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Modifier
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <button type="button" @click="deleteOpen = true"
                        class="flex items-center gap-2 bg-gray-800 hover:bg-red-900/40 hover:text-red-400 hover:border-red-800 border border-gray-700 text-gray-300 px-3 py-2 rounded-lg text-sm transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Supprimer
                </button>

                {# Delete confirmation modal #}
                <div x-show="deleteOpen" x-transition.opacity
                     class="fixed inset-0 z-50 flex items-center justify-center p-4"
                     style="background: rgba(0,0,0,0.7)">
                    <div x-show="deleteOpen" x-transition.scale.origin.center
                         @click.outside="deleteOpen = false"
                         class="bg-gray-900 border border-gray-700 rounded-2xl p-6 max-w-sm w-full shadow-2xl">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-full bg-red-900/40 flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-semibold">Supprimer l'athlète</h3>
                                <p class="text-sm text-gray-400">{{ athlete.fullName }}</p>
                            </div>
                        </div>
                        <p class="text-sm text-gray-400 mb-6">Cette action est irréversible. Toutes les performances, séances et objectifs associés seront supprimés.</p>
                        <div class="flex gap-3">
                            <form action="{{ path('app_athlete_delete', {id: athlete.id}) }}" method="post" class="flex-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ athlete.id) }}">
                                <button type="submit"
                                        class="w-full cursor-pointer bg-red-600 hover:bg-red-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                                    Oui, supprimer
                                </button>
                            </form>
                            <button type="button" @click="deleteOpen = false"
                                    class="flex-1 cursor-pointer bg-gray-800 hover:bg-gray-700 text-gray-300 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                                Annuler
                            </button>
                        </div>
                    </div>
                </div>
                {% endif %}{# end ROLE_ADMIN #}
                {% endif %}{# end canEdit #}
            </div>
        </div>

        {% if athlete.notes %}
            <div class="mt-4 pt-4 border-t border-gray-800 text-sm text-gray-400">
                {{ athlete.notes }}
            </div>
        {% endif %}

        {% if athlete.ffaProfileUrl %}
        <div class="mt-4 pt-4 border-t border-gray-800 flex items-center gap-3 text-sm">
            <span class="text-gray-500">Profil athle.fr :</span>
            <a href="{{ athlete.ffaProfileUrl }}" target="_blank" class="text-indigo-400 hover:text-indigo-300 truncate max-w-xs transition-colors">bases.athle.fr</a>
            <span id="ffa-sync-badge" class="flex items-center gap-1.5 text-gray-500">
                <svg id="ffa-spin" class="w-3.5 h-3.5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
                <span id="ffa-sync-text">Synchronisation…</span>
            </span>
        </div>
        {% endif %}

        {# Quick stats #}
        <div class="grid grid-cols-4 gap-4 mt-5 pt-5 border-t border-gray-800">
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.athleteSessions|length }}</p>
                <p class="text-sm text-gray-400">Séances</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.performances|length }}</p>
                <p class="text-sm text-gray-400">Performances</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.goals|filter(g => g.status == 'achieved')|length }}</p>
                <p class="text-sm text-gray-400">Objectifs atteints</p>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">{{ athlete.goals|filter(g => g.status == 'in_progress')|length }}</p>
                <p class="text-sm text-gray-400">En cours</p>
            </div>
        </div>
    </div>

    {# Tabs #}
    <div class="flex gap-1 bg-gray-900 border border-gray-800 rounded-xl p-1">
        <button @click="activeTab = 'performances'"
                :class="activeTab === 'performances' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Performances
        </button>
        {% if canEdit %}
        <button @click="activeTab = 'sessions'"
                :class="activeTab === 'sessions' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Séances
        </button>
        {% endif %}
        <button @click="activeTab = 'goals'"
                :class="activeTab === 'goals' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Objectifs
        </button>
        {% if canEdit %}
        <button @click="activeTab = 'videos'; $nextTick(() => videoApp.load())"
                :class="activeTab === 'videos' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:text-white'"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-colors">
            Vidéos
        </button>
        {% endif %}
    </div>

    {# Performances tab #}
    <div x-show="activeTab === 'performances'" x-transition
         x-data="perfTab({{ performancesJson|json_encode }}, {{ athlete.disciplines|json_encode }})"
         x-init="init()">

        {# Header row #}
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <h2 class="text-lg font-semibold text-white">Performances</h2>
                <span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded-full"
                      x-text="filtered.length + ' résultat' + (filtered.length > 1 ? 's' : '')"></span>
            </div>
            {% if canEdit %}
            <div class="flex items-center gap-2">
                {% if athlete.ffaProfileUrl %}
                <button id="manual-sync-btn" @click="triggerSync()"
                        :disabled="syncing"
                        class="flex items-center gap-1.5 bg-gray-800 hover:bg-gray-700 disabled:opacity-60 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors">
                    <svg :class="syncing ? 'animate-spin' : ''" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    <span x-text="syncLabel"></span>
                </button>
                {% endif %}
                <a href="{{ path('app_performance_new', {athleteId: athlete.id}) }}"
                   class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Ajouter
                </a>
            </div>
            {% endif %}
        </div>

        <template x-if="allPerfs.length === 0">
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">
                Aucune performance enregistrée.
            </div>
        </template>

        {# ── Bilan annuel niveau (accordéon, style FFA) ── #}
        <template x-if="annualBilan.length > 0">
            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-4">

                {# Header / toggle #}
                <button type="button" @click="_bilanOpen = !_bilanOpen"
                        class="w-full flex items-center justify-between px-4 py-3 hover:bg-gray-800/40 transition-colors text-left">
                    <div class="flex items-center gap-3 flex-wrap min-w-0">
                        <svg :class="_bilanOpen ? 'rotate-90' : ''"
                             class="w-4 h-4 text-gray-500 transition-transform shrink-0"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        <span class="text-sm font-semibold text-white shrink-0">Bilan niveau</span>
                        {# Preview des 3 dernières années quand replié #}
                        <template x-if="!_bilanOpen">
                            <div class="flex items-center gap-3 flex-wrap">
                                <template x-for="row in annualBilan.slice(0,4)" :key="row.year">
                                    <div class="flex items-center gap-1.5">
                                        <span class="text-xs text-gray-500" x-text="row.year"></span>
                                        <span class="text-xs font-bold bg-violet-900/50 text-violet-200 border border-violet-700/40 px-2 py-0.5 rounded"
                                              x-text="row.level"></span>
                                    </div>
                                </template>
                            </div>
                        </template>
                    </div>
                    <span class="text-xs text-gray-600 shrink-0 ml-2" x-text="annualBilan.length + ' ans'"></span>
                </button>

                {# Corps — table style FFA #}
                <div x-show="_bilanOpen" x-transition.duration.150ms class="border-t border-gray-800">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-xs text-gray-600 uppercase tracking-wide border-b border-gray-800/60">
                                <th class="text-left px-4 py-2 font-medium w-14">Année</th>
                                <th class="text-left px-4 py-2 font-medium w-28">Niveau</th>
                                <th class="text-left px-4 py-2 font-medium">Top performances</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="row in annualBilan" :key="row.year">
                                <tr class="border-t border-gray-800/40 hover:bg-white/[0.02] transition-colors">
                                    <td class="px-4 py-2.5 text-gray-400 font-semibold text-sm" x-text="row.year"></td>
                                    <td class="px-4 py-2.5">
                                        <div class="flex items-center gap-1.5">
                                            <span class="text-xs font-bold bg-violet-900/50 text-violet-200 border border-violet-700/40 px-2 py-1 rounded-lg"
                                                  x-text="row.level"></span>
                                            <span class="text-xs text-gray-600" x-text="'(' + row.pts + ' pts)'"></span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-2.5">
                                        <div class="flex items-center gap-4 flex-wrap">
                                            <template x-for="(p, i) in row.top2" :key="i">
                                                <div class="flex items-center gap-1.5 text-xs">
                                                    <span class="text-gray-400" x-text="p.disc"></span>
                                                    <span class="text-gray-200 font-semibold" x-text="p.value"></span>
                                                    <template x-if="p.level">
                                                        <span class="text-[10px] font-semibold bg-violet-900/40 text-violet-300 border border-violet-700/30 px-1.5 py-0.5 rounded"
                                                              x-text="p.level + (p.pts ? ' · ' + p.pts + 'pts' : '')"></span>
                                                    </template>
                                                </div>
                                            </template>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </template>

        <template x-if="allPerfs.length > 0">
            <div class="space-y-3">

                {# ── Season tabs ── #}
                <div class="flex flex-wrap gap-2">
                    <button @click="activeSeason = ''"
                            :class="activeSeason === '' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'"
                            class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
                        Toutes
                        <span class="ml-1 text-xs opacity-70" x-text="'(' + allPerfs.length + ')'"></span>
                    </button>
                    <template x-for="[s, count] in seasons" :key="s">
                        <button @click="activeSeason = s; activeCat = ''"
                                :class="activeSeason === s ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'"
                                class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
                            <span x-text="s.replace('-20', '-')"></span>
                            <span class="ml-1 text-xs opacity-70" x-text="'(' + count + ')'"></span>
                        </button>
                    </template>
                </div>

                {# ── Category + Indoor/Outdoor filters ── #}
                <div class="flex flex-wrap gap-2 items-center">
                    <template x-if="categories.length > 1">
                        <div class="flex flex-wrap gap-2 items-center">
                            <span class="text-xs text-gray-500">Catégorie :</span>
                            <button @click="activeCat = ''"
                                    :class="activeCat === '' ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                                    class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors">Toutes</button>
                            <template x-for="c in categories" :key="c">
                                <button @click="activeCat = (activeCat === c ? '' : c)"
                                        :class="activeCat === c ? 'bg-gray-700 text-white' : 'bg-gray-800/50 text-gray-500 hover:text-white'"
                                        class="px-2.5 py-1 rounded-md text-xs font-medium transition-colors"
                                        x-text="c"></button>
                            </template>
                        </div>
                    </template>
                    <div class="flex gap-1 ml-auto">
                        <button @click="activeIndoor = (activeIndoor === null ? true : (activeIndoor === true ? false : null))"
                                :class="activeIndoor === true ? 'bg-indigo-800/60 text-indigo-300 border-indigo-700' : activeIndoor === false ? 'bg-amber-900/40 text-amber-300 border-amber-800' : 'bg-gray-800/50 text-gray-500 border-gray-700 hover:text-white'"
                                class="px-2.5 py-1 rounded-md text-xs font-medium border transition-colors">
                            <span x-text="activeIndoor === true ? '🏛 Indoor' : activeIndoor === false ? '🌤 Outdoor' : '🏛/🌤 Tous'"></span>
                        </button>
                    </div>
                </div>

                {# ── Discipline accordions ── #}
                <div class="space-y-2">
                    <template x-for="disc in disciplineGroups" :key="disc.name">
                        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden flex">

                            {# Left accent bar for specialties #}
                            <div class="w-1 shrink-0 rounded-l-xl transition-colors"
                                 :class="specialties.includes(disc.name) ? 'bg-indigo-500' : 'bg-gray-700'"></div>
                            <div class="flex-1 min-w-0">
                            {# Accordion header — always visible, shows PB & SB #}
                            <button type="button"
                                    @click="toggleDisc(disc.name)"
                                    class="w-full flex items-center justify-between px-4 py-3 hover:bg-gray-800/40 transition-colors text-left">
                                <div class="flex items-center gap-3 flex-1 min-w-0">
                                    <svg :class="isDiscOpen(disc.name) ? 'rotate-90' : ''"
                                         class="w-4 h-4 text-gray-500 transition-transform shrink-0"
                                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                    <span class="font-semibold text-white" x-text="disc.name"></span>
                                    <span class="text-xs bg-gray-800 text-gray-500 px-2 py-0.5 rounded-full shrink-0"
                                          x-text="disc.perfs.length + ' perf' + (disc.perfs.length > 1 ? 's' : '')"></span>
                                </div>
                                <div class="flex items-center shrink-0 ml-4">
                                    {# PB #}
                                    <div style="width:80px">
                                        <template x-if="disc.pb">
                                            <div class="border-l-2 border-yellow-400/70 pl-2.5">
                                                <div class="text-[9px] font-semibold text-gray-300 uppercase tracking-[0.12em]">PB</div>
                                                <div class="text-sm font-mono font-bold text-yellow-400 leading-tight" x-text="disc.pb"></div>
                                            </div>
                                        </template>
                                    </div>
                                    {# SB #}
                                    <div style="width:80px">
                                        <template x-if="disc.sb">
                                            <div class="border-l-2 border-emerald-400/70 pl-2.5">
                                                <div class="text-[9px] font-semibold text-gray-300 uppercase tracking-[0.12em]">SB</div>
                                                <div class="text-sm font-mono font-bold text-emerald-400 leading-tight" x-text="disc.sb"></div>
                                            </div>
                                        </template>
                                    </div>
                                </div>
                            </button>

                            {# Accordion body #}
                            <div x-show="isDiscOpen(disc.name)" x-transition.duration.150ms
                                 class="border-t border-gray-800">

                                {# Chart — canvas present always so init can find it; hidden when < 2 perfs #}
                                <div x-show="disc.hasChart" class="px-4 py-3">
                                    <div class="bg-gray-950 border border-gray-700/60 rounded-lg px-3 pt-3 pb-2">
                                        <canvas :data-disc="disc.name"
                                                :data-labels="JSON.stringify(disc.chartLabels)"
                                                :data-values="JSON.stringify(disc.chartValues)"
                                                :data-unit="disc.unit"
                                                :data-higher-is-better="disc.higherIsBetter ? 'true' : 'false'"
                                                class="perf-disc-chart" height="75">
                                        </canvas>
                                    </div>
                                </div>

                                {# Performances table #}
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="text-xs text-gray-600 uppercase tracking-wide border-t border-gray-800/60">
                                            <th class="text-left px-4 py-1.5 font-medium w-24">Date</th>
                                            <th class="text-left px-4 py-1.5 font-medium">Performance</th>
                                            <th class="text-left px-4 py-1.5 font-medium hidden sm:table-cell">Lieu</th>
                                            <th class="text-left px-4 py-1.5 font-medium hidden md:table-cell">Saison</th>
                                            <th class="text-left px-4 py-1.5 font-medium hidden md:table-cell">Cat.</th>
                                            <th class="text-left px-4 py-1.5 font-medium hidden md:table-cell">Niveau</th>
                                            <th class="w-14"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <template x-for="p in disc.perfs" :key="p.id">
                                            <tr class="border-t border-gray-800/40 hover:bg-white/[0.02] transition-colors group">
                                                <td class="px-4 py-2 text-gray-500 whitespace-nowrap text-xs" x-text="p.dateFormatted"></td>
                                                <td class="px-4 py-2">
                                                    <div class="flex items-center gap-1.5">
                                                        <span class="w-3 shrink-0 text-center text-xs leading-none"
                                                              :class="p.isPersonalBest ? 'text-yellow-400' : 'opacity-0'"
                                                              title="Record personnel">★</span>
                                                        <span :class="p.isPersonalBest ? 'text-yellow-300 font-bold' : 'text-gray-100 font-medium'"
                                                              x-text="p.formattedValue"></span>
                                                        <template x-if="p.isIndoor === true">
                                                            <span class="text-[10px] font-medium text-indigo-400 bg-indigo-950 px-1.5 py-0.5 rounded" title="Indoor">IN</span>
                                                        </template>
                                                        <template x-if="p.isIndoor === false">
                                                            <span class="text-[10px] font-medium text-amber-400 bg-amber-950/60 px-1.5 py-0.5 rounded" title="Outdoor">OUT</span>
                                                        </template>
                                                        <template x-if="p.wind !== null && p.wind !== undefined">
                                                            <span class="inline-flex items-center gap-0.5 text-[10px] font-medium text-sky-400 bg-sky-950/50 px-1.5 py-0.5 rounded"
                                                                  :title="'Vent : ' + p.wind + (p.wind !== 'NC' ? ' m/s' : '')">
                                                                <svg style="width:17px;height:17px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/>
                                                                </svg>
                                                                <span x-text="p.wind + (p.wind !== 'NC' ? ' m/s' : '')"></span>
                                                            </span>
                                                        </template>
                                                    </div>
                                                    <p x-show="p.notes" x-text="p.notes" class="text-xs text-gray-600 mt-0.5"></p>
                                                </td>
                                                <td class="px-4 py-2 hidden sm:table-cell">
                                                    <span class="text-xs text-gray-600" x-text="p.venue || ''"></span>
                                                </td>
                                                <td class="px-4 py-2 hidden md:table-cell">
                                                    <span class="text-xs text-gray-700" x-text="p.seasonShort"></span>
                                                </td>
                                                <td class="px-4 py-2 hidden md:table-cell">
                                                    <span x-show="p.category" x-text="p.category"
                                                          class="text-[10px] bg-gray-800 text-gray-500 px-2 py-0.5 rounded-full"></span>
                                                </td>
                                                <td class="px-4 py-2 hidden md:table-cell">
                                                    <template x-if="p.level || p.levelPoints">
                                                        <div class="flex items-center gap-1">
                                                            <span x-show="p.level" x-text="p.level"
                                                                  class="text-[10px] font-semibold bg-violet-900/40 text-violet-300 border border-violet-700/30 px-1.5 py-0.5 rounded"></span>
                                                            <span x-show="p.levelPoints" x-text="p.levelPoints + ' pts'"
                                                                  class="text-[10px] text-gray-500"></span>
                                                        </div>
                                                    </template>
                                                </td>
                                                <td class="px-3 py-2">
                                                    {% if canEdit %}
                                                    <div class="flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity">
                                                        <a :href="p.editUrl" class="text-gray-700 hover:text-indigo-400 p-1 rounded transition-colors">
                                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                                        </a>
                                                        <button @click="deletePerf(p)" class="text-gray-700 hover:text-red-400 p-1 rounded transition-colors">
                                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                                        </button>
                                                    </div>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        </template>
                                    </tbody>
                                </table>
                            </div>
                        </div>{# end flex-1 #}
                        </div>{# end flex card #}
                    </template>

                    <div x-show="disciplineGroups.length === 0" class="bg-gray-900 border border-gray-800 rounded-xl p-8 text-center text-gray-500 text-sm">
                        Aucun résultat pour ces filtres.
                    </div>
                </div>

            </div>
        </template>
    </div>

    {# Sessions tab #}
    <div x-show="activeTab === 'sessions'" x-transition>
        <div style="overflow:hidden">

            {# Prochaine séance #}
            {% if upcomingSessions is not empty %}
                {% set next = upcomingSessions[0] %}
                <div style="margin-top: 2.5rem">
                    <div class="flex items-center gap-3 mb-4">
                        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest">Prochaine séance</h2>
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    </div>
                    <div class="bg-gray-900 border border-indigo-600/40 rounded-xl overflow-hidden relative">
                        <div class="h-1" style="background: {{ next.colorBg }}"></div>
                        <div class="px-5 py-4 flex items-center justify-between gap-4">
                            <div class="flex items-center gap-5">
                                <div class="text-center shrink-0">
                                    <p class="text-2xl font-bold text-white leading-none">{{ next.date|date('d') }}</p>
                                    <p class="text-xs text-gray-400 uppercase mt-0.5">{{ next.date|date('M Y') }}</p>
                                </div>
                                <div class="w-px h-8 bg-gray-700"></div>
                                <div>
                                    <p class="text-base font-semibold text-white">{{ next.title }}</p>
                                    <div class="flex items-center gap-2 mt-1 flex-wrap">
                                        <span class="text-xs px-2 py-0.5 rounded font-medium"
                                              style="background: {{ next.colorBg }}22; color: {{ next.colorBg }}">
                                            {{ next.typeLabel }}
                                        </span>
                                        {% if next.durationMinutes %}
                                            <span class="text-xs text-gray-500">{{ next.durationMinutes }} min</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <a href="{{ path('app_calendar') }}"
                               class="text-xs text-indigo-400 hover:text-indigo-300 font-medium transition-colors shrink-0">
                                Voir le calendrier →
                            </a>
                        </div>
                        {% if upcomingSessions|length > 1 %}
                            <div class="border-t border-gray-800 px-5 py-2 flex gap-4 overflow-x-auto">
                                {% for s in upcomingSessions[1:] %}
                                    <span class="text-xs text-gray-500 whitespace-nowrap shrink-0">
                                        <span class="text-gray-400 font-medium">{{ s.date|date('d/m') }}</span>
                                        · {{ s.title }}
                                    </span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Séances à enregistrer #}
            {% if unloggedSessions is not empty %}
                <div style="margin-top: 2.5rem">
                    <div class="flex items-center gap-3 mb-4">
                        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest">À débriefer</h2>
                        <span class="text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2.5 py-0.5 rounded-full font-medium">
                            {{ unloggedSessions|length }}
                        </span>
                    </div>
                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
                        {% for session in unloggedSessions %}
                            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-amber-500/30 transition-colors">
                                <div class="h-0.5" style="background: {{ session.colorBg }}"></div>
                                <div class="px-3 py-3 flex flex-col gap-2">
                                    <div class="flex items-start justify-between gap-2">
                                        <div class="flex items-center gap-2">
                                            <div class="text-center shrink-0">
                                                <p class="text-lg font-bold text-white leading-none">{{ session.date|date('d') }}</p>
                                                <p class="text-[10px] text-gray-500 uppercase">{{ session.date|date('M') }}</p>
                                            </div>
                                        </div>
                                        <a href="{{ path('app_athlete_session_log', {athleteId: athlete.id, sessionId: session.id}) }}"
                                           class="flex items-center gap-1 bg-indigo-600 hover:bg-indigo-500 text-white px-2.5 py-1.5 rounded-lg text-[10px] font-semibold transition-colors shrink-0 shadow-sm">
                                            Débrief
                                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                                            </svg>
                                        </a>
                                    </div>
                                    <p class="text-xs font-medium text-white leading-tight">{{ session.title }}</p>
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-[10px] px-1.5 py-0.5 rounded font-medium"
                                              style="background: {{ session.colorBg }}22; color: {{ session.colorBg }}">
                                            {{ session.typeLabel }}
                                        </span>
                                        {% if session.durationMinutes %}
                                            <span class="text-[10px] text-gray-500">{{ session.durationMinutes }} min</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Historique #}
            <div style="margin-top: 2.5rem">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-4">Historique</h2>
                {% if loggedSessions is empty %}
                    <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500 text-sm">
                        Aucune séance enregistrée pour l'instant.
                    </div>
                {% else %}
                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
                        {% for as in loggedSessions %}
                            {% set s = as.session %}
                            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden flex flex-col">
                                <div class="h-0.5" style="background: {{ s.colorBg }}"></div>
                                <div class="px-3 py-3 flex-1 flex flex-col gap-2">
                                    {# Ligne 1 : date + boutons #}
                                    <div class="flex items-start justify-between gap-1">
                                        <div class="text-center shrink-0">
                                            <p class="text-lg font-bold text-white leading-none">{{ s.date|date('d') }}</p>
                                            <p class="text-[10px] text-gray-500 uppercase">{{ s.date|date('M') }}</p>
                                        </div>
                                        <div class="flex gap-0.5 shrink-0">
                                            <a href="{{ path('app_athlete_session_edit', {athleteId: athlete.id, id: as.id}) }}"
                                               class="text-gray-600 hover:text-indigo-400 p-1 rounded hover:bg-gray-800 transition-colors">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                            </a>
                                            <form action="{{ path('app_athlete_session_delete', {athleteId: athlete.id, id: as.id}) }}" method="post" class="inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-as' ~ as.id) }}">
                                                <button type="submit" onclick="return confirm('Supprimer ce ressenti ?')"
                                                        class="text-gray-600 hover:text-red-400 p-1 rounded hover:bg-gray-800 transition-colors">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    {# Ligne 2 : titre #}
                                    <p class="text-xs font-medium text-white leading-tight">{{ s.title }}</p>
                                    {# Ligne 3 : type #}
                                    <span class="text-[10px] px-1.5 py-0.5 rounded font-medium w-fit"
                                          style="background: {{ s.colorBg }}22; color: {{ s.colorBg }}">
                                        {{ s.typeLabel }}
                                    </span>
                                    {# Commentaire #}
                                    {% if as.comment %}
                                        <p class="text-[10px] text-gray-400 italic leading-relaxed line-clamp-2">"{{ as.comment }}"</p>
                                    {% endif %}
                                    {# Effort en bas à droite #}
                                    {% if as.difficulty is not null %}
                                        <div class="flex justify-end mt-auto pt-1">
                                            <span class="inline-flex items-center gap-1 text-[10px] font-bold px-2 py-1 rounded-lg
                                                {% if as.difficulty <= 3 %}bg-emerald-500/10 text-emerald-400
                                                {% elseif as.difficulty <= 6 %}bg-yellow-500/10 text-yellow-400
                                                {% else %}bg-red-500/10 text-red-400{% endif %}">
                                                <svg style="width:19px;height:19px;flex-shrink:0" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29l-1.43-1.43z"/>
                                                </svg>
                                                {{ as.difficulty }}/10
                                            </span>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

        </div>
    </div>

    {# Goals tab #}
    <div x-show="activeTab === 'goals'" x-transition>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-white">Objectifs</h2>
            {% if canEdit %}
            <a href="{{ path('app_goal_new', {athleteId: athlete.id}) }}"
               class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter
            </a>
            {% endif %}
        </div>

        {% if athlete.goals is empty %}
            <div id="goals-empty" class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">
                Aucun objectif défini.
            </div>
        {% else %}
            <div id="goals-list" class="space-y-3">
                {% for goal in athlete.goals %}
                    <div id="goal-{{ goal.id }}"
                         class="bg-gray-900 border rounded-xl px-5 py-4 transition-all
                        {% if goal.isAchieved %}border-emerald-800/50
                        {% elseif goal.isOverdue %}border-red-800/50
                        {% else %}border-gray-800{% endif %}">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-start gap-3">
                                <button type="button"
                                        onclick="goalToggle({{ goal.id }}, '{{ path('app_goal_toggle', {athleteId: athlete.id, id: goal.id}) }}', '{{ csrf_token('toggle-goal' ~ goal.id) }}')"
                                        class="mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-colors shrink-0
                                        {% if goal.isAchieved %}border-emerald-500 bg-emerald-500{% else %}border-gray-600 hover:border-emerald-500{% endif %}">
                                    {% if goal.isAchieved %}
                                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    {% endif %}
                                </button>
                                <div>
                                    <p class="font-medium {% if goal.isAchieved %}text-emerald-400 line-through{% else %}text-white{% endif %}">
                                        {{ goal.title }}
                                    </p>
                                    <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
                                        {% if goal.discipline %}
                                            <span>{{ goal.discipline }}</span>
                                        {% endif %}
                                        {% if goal.targetValue %}
                                            <span>Cible : {{ goal.targetValue }} {{ goal.unit }}</span>
                                        {% endif %}
                                        {% if goal.deadline %}
                                            <span class="{% if goal.isOverdue and not goal.isAchieved %}text-red-400{% endif %}">
                                                Échéance : {{ goal.deadline|date('d/m/Y') }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    {% if goal.notes %}
                                        <p class="text-xs text-gray-500 mt-1">{{ goal.notes }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <span class="goal-status-badge text-xs px-2 py-0.5 rounded-full font-medium
                                    {% if goal.isAchieved %}bg-emerald-900/50 text-emerald-400
                                    {% elseif goal.isOverdue %}bg-red-900/50 text-red-400
                                    {% else %}bg-blue-900/50 text-blue-400{% endif %}">
                                    {% if goal.isAchieved %}Atteint
                                    {% elseif goal.isOverdue %}En retard
                                    {% else %}En cours{% endif %}
                                </span>
                                {% if canEdit %}
                                <a href="{{ path('app_goal_edit', {athleteId: athlete.id, id: goal.id}) }}"
                                   class="text-gray-500 hover:text-indigo-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <button type="button"
                                        onclick="goalDelete({{ goal.id }}, '{{ path('app_goal_delete', {athleteId: athlete.id, id: goal.id}) }}', '{{ csrf_token('delete-goal' ~ goal.id) }}')"
                                        class="text-gray-500 hover:text-red-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

<script>
function goalToggle(id, url, token) {
    fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: '_token=' + encodeURIComponent(token)
    })
    .then(r => r.json())
    .then(data => {
        var el = document.getElementById('goal-' + id);
        if (!el) return;
        var btn = el.querySelector('button[onclick^="goalToggle"]');
        var title = el.querySelector('p.font-medium');
        var badge = el.querySelector('.goal-status-badge');

        if (data.achieved) {
            el.className = el.className.replace(/border-\S+/g, '').trim() + ' border-emerald-800/50';
            btn.className = btn.className.replace(/border-\S+|bg-\S+/g, '').trim() + ' border-emerald-500 bg-emerald-500';
            btn.innerHTML = '<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
            title.className = title.className.replace('text-white', 'text-emerald-400') + ' line-through';
            badge.className = badge.className.replace(/bg-\S+|text-\S+400/g, '').trim() + ' bg-emerald-900/50 text-emerald-400';
            badge.textContent = 'Atteint';
        } else {
            el.className = el.className.replace(/border-\S+/g, '').trim() + ' border-gray-800';
            btn.className = btn.className.replace(/border-\S+|bg-\S+/g, '').trim() + ' border-gray-600 hover:border-emerald-500';
            btn.innerHTML = '';
            title.className = title.className.replace('text-emerald-400', 'text-white').replace(' line-through', '');
            badge.className = badge.className.replace(/bg-\S+|text-\S+400/g, '').trim() + ' bg-blue-900/50 text-blue-400';
            badge.textContent = 'En cours';
        }
    })
    .catch(() => location.reload());
}

function goalDelete(id, url, token) {
    if (!confirm('Supprimer cet objectif ?')) return;
    fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: '_token=' + encodeURIComponent(token)
    })
    .then(r => r.json())
    .then(() => {
        var el = document.getElementById('goal-' + id);
        if (el) el.remove();
        var list = document.getElementById('goals-list');
        if (list && list.children.length === 0) {
            list.outerHTML = '<div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center text-gray-500">Aucun objectif défini.</div>';
        }
    })
    .catch(() => location.reload());
}
</script>

    {# Videos tab #}
    <div x-show="activeTab === 'videos'" x-transition id="videos-tab">

        {# Upload — compact collapsible #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-4" x-data="{ uploadOpen: false }">

            {# Toggle header #}
