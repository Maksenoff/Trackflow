        var isSharedSeeking = false;
        function sharedSeekFromEvent(e) {
            var rect = sharedProgressWrap.getBoundingClientRect();
            var pct = Math.max(0, Math.min((e.clientX - rect.left) / rect.width, 1));
            var dur = (vid1.duration > 0 ? vid1.duration : 0);
            var t = pct * dur;
            if (vid1.duration > 0) vid1.currentTime = t;
