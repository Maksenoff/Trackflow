{% extends 'base.html.twig' %}

{% block title %}Athlètes{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}" class="hover:text-white transition-colors">Tableau de bord</a>
    <span class="mx-2 text-gray-600">/</span>
    <span class="text-white font-medium">Athlètes</span>
{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Athlètes</h1>
            <p class="text-gray-400 mt-1">{{ athletes|length }} athlète{% if athletes|length > 1 %}s{% endif %} suivi{% if athletes|length > 1 %}s{% endif %}</p>
        </div>
        <a href="{{ path('app_athlete_new') }}"
           class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvel athlète
        </a>
    </div>

    {% if athletes is empty %}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-16 text-center">
            <svg class="w-16 h-16 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <h3 class="text-lg font-medium text-gray-300 mb-2">Aucun athlète</h3>
            <p class="text-gray-500 mb-6">Commencez par ajouter votre premier athlète.</p>
            <a href="{{ path('app_athlete_new') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter un athlète
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-3 gap-4">
            {% for athlete in athletes %}
                <a href="{{ path('app_athlete_show', {id: athlete.id}) }}"
                   class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-indigo-600/50 hover:bg-gray-800/50 transition-all group">
                    <div class="flex items-start gap-4">
                        <div class="w-14 h-14 rounded-xl bg-indigo-600/20 flex items-center justify-center text-indigo-300 font-bold text-lg shrink-0 overflow-hidden">
                            {% if athlete.photo %}
                                <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}" class="w-full h-full object-cover">
                            {% else %}
                                {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                            {% endif %}
                        </div>
                        <div class="flex-1 min-w-0">
                            <h3 class="font-semibold text-white group-hover:text-indigo-300 transition-colors">{{ athlete.fullName }}</h3>
                            <p class="text-sm text-indigo-400 mt-0.5">{{ athlete.discipline }}</p>
                            {% if athlete.age %}
                                <p class="text-xs text-gray-500 mt-1">{{ athlete.age }} ans · {{ athlete.gender == 'M' ? 'Homme' : (athlete.gender == 'F' ? 'Femme' : '') }}</p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex gap-4 mt-4 pt-4 border-t border-gray-800">
                        <div class="text-center">
                            <p class="text-lg font-bold text-white">{{ athlete.athleteSessions|length }}</p>
                            <p class="text-xs text-gray-500">séances</p>
                        </div>
                        <div class="text-center">
                            <p class="text-lg font-bold text-white">{{ athlete.performances|length }}</p>
                            <p class="text-xs text-gray-500">perfs</p>
                        </div>
                        <div class="text-center">
                            <p class="text-lg font-bold text-white">{{ athlete.goals|length }}</p>
                            <p class="text-xs text-gray-500">objectifs</p>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
