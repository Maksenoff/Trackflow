{% extends 'base.html.twig' %}
{% block title %}Athlètes{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <span class="current">Athlètes</span>
{% endblock %}

{% block body %}
<div>
    <div class="page-header">
        <div>
            <h1 class="section-title">Athlètes</h1>
            <p class="section-subtitle">{{ athletes|length }} athlète{% if athletes|length > 1 %}s{% endif %} suivi{% if athletes|length > 1 %}s{% endif %}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_athlete_new') }}" class="btn btn-primary">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouvel athlète
        </a>
        {% endif %}
    </div>

    {% if athletes is empty %}
        <div class="card">
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <h3>Aucun athlète</h3>
                <p>Commencez par ajouter votre premier athlète</p>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_athlete_new') }}" class="btn btn-primary" style="margin-top:16px;">+ Ajouter un athlète</a>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;" data-stagger>
            {% for athlete in athletes %}
                <a href="{{ path('app_athlete_show', {id: athlete.id}) }}"
                   class="card card-hover card-accent-hover"
                   style="display:block;text-decoration:none;padding:20px;cursor:pointer;">
                    <div style="display:flex;align-items:flex-start;gap:14px;">
                        <div class="avatar avatar-md avatar-sq">
                            {% if athlete.photo %}
                                <img src="/uploads/athletes/{{ athlete.photo }}" alt="{{ athlete.fullName }}">
                            {% else %}
                                {{ athlete.firstName|slice(0,1) }}{{ athlete.lastName|slice(0,1) }}
                            {% endif %}
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:15px;font-weight:700;color:var(--text-1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ athlete.fullName }}</div>
                            <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;">
                                {% for disc in athlete.disciplines %}
                                    <span class="badge badge-indigo" style="font-size:10.5px;">{{ disc|capitalize }}</span>
                                {% endfor %}
                            </div>
                            {% if athlete.age %}
                                <div style="font-size:12px;color:var(--text-3);margin-top:4px;">{{ athlete.age }} ans · {{ athlete.gender == 'M' ? 'Homme' : (athlete.gender == 'F' ? 'Femme' : '') }}</div>
                            {% endif %}
                        </div>
                    </div>

                    <div style="display:flex;gap:20px;margin-top:16px;padding-top:14px;border-top:1px solid var(--border);">
                        <div style="text-align:center;">
                            <div style="font-size:18px;font-weight:800;color:var(--text-1);" data-count="{{ athlete.athleteSessions|length }}">{{ athlete.athleteSessions|length }}</div>
                            <div style="font-size:11px;color:var(--text-3);">séances</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="font-size:18px;font-weight:800;color:var(--text-1);" data-count="{{ athlete.performances|length }}">{{ athlete.performances|length }}</div>
                            <div style="font-size:11px;color:var(--text-3);">perfs</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="font-size:18px;font-weight:800;color:var(--text-1);" data-count="{{ athlete.goals|length }}">{{ athlete.goals|length }}</div>
                            <div style="font-size:11px;color:var(--text-3);">objectifs</div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
