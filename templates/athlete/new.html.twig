{% extends 'base.html.twig' %}
{% block title %}Nouvel athlète{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_dashboard') }}">Tableau de bord</a>
    <span class="sep">/</span>
    <a href="{{ path('app_athlete_index') }}">Athlètes</a>
    <span class="sep">/</span>
    <span class="current">Nouvel athlète</span>
{% endblock %}

{% block body %}
<div id="js-form-ids"
    data-ffa-url="{{ form.ffaProfileUrl.vars.id }}"
    data-first-name="{{ form.firstName.vars.id }}"
    data-last-name="{{ form.lastName.vars.id }}"
    data-birth-date="{{ form.birthDate.vars.id }}"
    data-gender="{{ form.gender.vars.id }}"
    data-license-number="{{ form.licenseNumber.vars.id }}"
    style="display:none"></div>

<div style="max-width:640px;margin:0 auto;" x-data="newAthlete()" x-init="init()">

    <div style="margin-bottom:24px;">
        <h1 class="section-title">Nouvel athlète</h1>
        <p class="section-subtitle">Ajoutez un athlète à votre suivi</p>
    </div>

    {# Step 1 — Choose mode #}
    <div :style="step === 'choose' ? 'display:grid;grid-template-columns:repeat(2,1fr);gap:12px;' : 'display:none;'"
         style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
        <button type="button" @click="step = 'licence'"
                style="text-align:left;cursor:pointer;padding:24px;background:var(--bg-card-solid);border:1px solid var(--border);border-radius:var(--radius);transition:background var(--transition);width:100%;"
                onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='var(--bg-card-solid)'">
            <div style="width:40px;height:40px;border-radius:10px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:var(--accent-hover);"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--text-1);margin-bottom:6px;">Avec profil athle.fr</div>
            <div style="font-size:13px;color:var(--text-2);line-height:1.5;">Collez l'URL du profil athle.fr pour préremplir et synchroniser les résultats.</div>
        </button>

        <button type="button" @click="step = 'form'"
                style="text-align:left;cursor:pointer;padding:24px;background:var(--bg-card-solid);border:1px solid var(--border);border-radius:var(--radius);transition:background var(--transition);width:100%;"
                onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='var(--bg-card-solid)'">
            <div style="width:40px;height:40px;border-radius:10px;background:var(--bg-hover);display:flex;align-items:center;justify-content:center;margin-bottom:14px;border:1px solid var(--border);">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:var(--text-2);"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--text-1);margin-bottom:6px;">Manuellement</div>
            <div style="font-size:13px;color:var(--text-2);line-height:1.5;">Remplissez les informations vous-même.</div>
        </button>
    </div>

    {# Step 2 — URL lookup #}
    <div x-show="step === 'licence'" x-transition style="display:none;">
        <div class="card card-body">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
                <button type="button" @click="step = 'choose'" class="btn btn-ghost btn-icon">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <span style="font-size:15px;font-weight:700;color:var(--text-1);">Recherche via athle.fr</span>
            </div>

            <p style="font-size:13px;color:var(--text-2);margin-bottom:14px;">
                Allez sur <strong style="color:var(--text-1);">athle.fr</strong> ou <strong style="color:var(--text-1);">bases.athle.fr</strong>, cherchez l'athlète, puis copiez l'URL de sa page de profil.
            </p>

            <div style="display:flex;gap:10px;">
                <input type="text" x-model="urlInput" @keydown.enter="lookupUrl()"
                       placeholder="https://www.athle.fr/athlete/…"
                       class="form-input" style="flex:1;">
                <button type="button" @click="lookupUrl()" :disabled="lookupLoading || !urlInput.trim()" class="btn btn-primary">
                    <svg x-show="lookupLoading" style="animation:spin 1s linear infinite;width:15px;height:15px;" fill="none" viewBox="0 0 24 24"><circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path style="opacity:.75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                    <span x-text="lookupLoading ? 'Chargement…' : 'Importer'"></span>
                </button>
            </div>

            <p x-show="lookupError" x-text="lookupError"
               style="margin-top:12px;font-size:13px;color:var(--danger);background:var(--danger-bg);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:10px 14px;display:none;"></p>
        </div>
    </div>

    {# Step 3 — Form #}
    <div x-show="step === 'form'" style="display:none;">
        <div class="card card-body">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
                <button type="button" @click="step = 'choose'" class="btn btn-ghost btn-icon">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <span style="font-size:15px;font-weight:700;color:var(--text-1);">Informations de l'athlète</span>
                <span x-show="prefilled" class="badge badge-success">
                    <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Prérempli via athle.fr
                </span>
                <span x-show="syncReady" class="badge badge-indigo">
                    Sync activée
                </span>
            </div>

            {{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate', 'data-turbo': 'false'}}) }}

            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
                <div>{{ form_row(form.firstName) }}</div>
                <div>{{ form_row(form.lastName) }}</div>
            </div>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
                <div>{{ form_row(form.birthDate) }}</div>
                <div>{{ form_row(form.gender) }}</div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>{{ form_row(form.licenseNumber) }}</div>
                <div>{{ form_row(form.ffaProfileUrl) }}</div>
            </div>

            <div class="form-group">
                <label class="form-label">Spécialités</label>
                <input type="hidden" name="disciplines_raw" id="disciplines_raw_new" value="[]">
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;" id="disc-pills-new">
                    {% for label, value in disciplines %}
                        <button type="button"
                                class="disc-pill btn btn-secondary btn-sm"
                                data-value="{{ value }}"
                                data-hidden="disciplines_raw_new"
                                onclick="discPillToggle(this)">
                            {{ label }}
                        </button>
                    {% endfor %}
                </div>
            </div>

            {{ form_row(form.photoFile) }}

            <div style="display:flex;gap:10px;padding-top:8px;">
                <button type="submit" class="btn btn-primary">Créer l'athlète</button>
                <a href="{{ path('app_athlete_index') }}" class="btn btn-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>

</div>

<style>
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.disc-pill.active { background: var(--accent) !important; color: white !important; border-color: var(--accent) !important; }
</style>

<script>
(function () {
    var ids = document.getElementById('js-form-ids').dataset;

    function newAthlete() {
        return {
            step: 'choose',
            urlInput: '',
            lookupLoading: false,
            lookupError: '',
            prefilled: false,
            syncReady: false,

            init() {
                {% if form.vars.submitted %}
                this.step = 'form';
                {% endif %}
            },

            lookupUrl() {
                var url = this.urlInput.trim();
                if (!url) return;
                this.lookupLoading = true;
                this.lookupError   = '';
                var fd = new FormData();
                fd.append('url', url);
                fetch('{{ path('app_athlete_lookup_ffa') }}', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: fd,
                })
                .then(r => r.json())
                .then(data => {
                    this.lookupLoading = false;
                    if (data.error && !data.firstName && !data.lastName) {
                        this.lookupError = data.error;
                        return;
                    }
                    this.prefilled = !!data.firstName;
                    this.syncReady = !!data.basesUrl;
                    this.step = 'form';
                    this.$nextTick(() => this.prefill(data));
                })
                .catch(err => {
                    this.lookupLoading = false;
                    this.lookupError = 'Erreur réseau (' + err.message + ')';
                });
            },

            prefill(data) {
                var profileUrl = data.basesUrl || this.urlInput.trim();
                var fields = {
                    [ids.ffaUrl]:        profileUrl,
                    [ids.firstName]:     data.firstName     || '',
                    [ids.lastName]:      data.lastName      || '',
                    [ids.birthDate]:     data.birthDate     || '',
                    [ids.gender]:        data.gender        || '',
                    [ids.licenseNumber]: data.licenseNumber || '',
                };
                Object.entries(fields).forEach(([id, val]) => {
                    if (!val) return;
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.value = val;
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                    el.dispatchEvent(new Event('input',  { bubbles: true }));
                });
                if (data.discipline && data.discipline.length > 0) {
                    var discs = Array.isArray(data.discipline) ? data.discipline : [data.discipline];
                    document.querySelectorAll('#disc-pills-new .disc-pill').forEach(function(btn) {
                        if (discs.includes(btn.dataset.value) && !btn.classList.contains('active')) {
                            discPillToggle(btn);
                        }
                    });
                }
            },
        };
    }

    window.newAthlete = newAthlete;
}());

function discPillToggle(btn) {
    var hiddenInput = document.getElementById(btn.dataset.hidden);
    if (!hiddenInput) return;
    var selected = JSON.parse(hiddenInput.value || '[]');
    var val = btn.dataset.value;
    var idx = selected.indexOf(val);
    if (idx === -1) {
        selected.push(val);
        btn.classList.add('active');
    } else {
        selected.splice(idx, 1);
        btn.classList.remove('active');
    }
    hiddenInput.value = JSON.stringify(selected);
}
</script>
{% endblock %}
