{% extends 'base.html.twig' %}

{% block title %}Stats avancées — {{ athlete.fullName }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_athlete_show', {id: athlete.id}) }}">{{ athlete.fullName }}</a>
    <span class="sep">/</span>
    <span class="current">Stats avancées</span>
{% endblock %}

{% block body %}
<div x-data="statsPage()" x-init="init()" style="display:flex;flex-direction:column;gap:24px;">

    {# ── Header ── #}
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
        <div>
            <h1 class="section-title">Stats avancées</h1>
            <p class="section-subtitle">{{ athlete.fullName }}</p>
        </div>
        <a href="{{ path('app_athlete_show', {id: athlete.id}) }}" class="btn btn-secondary btn-sm" style="flex-shrink:0;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Fiche athlète
        </a>
    </div>

    {# ── Discipline tabs ── #}
    <div class="tf-tabs">
        <template x-for="disc in disciplines" :key="disc">
            <button @click="switchDisc(disc)"
                    class="tf-tab"
                    :class="activeDisc === disc ? 'active' : ''">
                <span x-text="disc"></span>
                <span style="margin-left:6px;font-size:11px;opacity:.5;" x-text="'(' + stats[disc].count + ')'"></span>
            </button>
        </template>
    </div>

    {# ── Year filter ── #}
    <template x-if="availableYears.length > 1">
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
            <span style="font-size:11px;color:var(--text-3);">Année :</span>
            <button @click="setYear('all')"
                    class="tf-tab"
                    :class="activeYear === 'all' ? 'active' : ''">
                Toutes
            </button>
            <template x-for="year in availableYears" :key="year">
                <button @click="setYear(year)"
                        class="tf-tab"
                        :class="activeYear === year ? 'active' : ''">
                    <span x-text="year"></span>
                </button>
            </template>
        </div>
    </template>

    {# ── Stats brutes (4 cards) ── #}
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;" class="lg-grid-4">

        {# Progression totale #}
        <div class="card card-body">
            <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0 0 12px;">Progression totale</p>
            <template x-if="d.progression.formatted && d.progression.improved !== null">
                <div>
                    <p style="font-size:24px;font-weight:700;font-family:monospace;line-height:1;margin:0;"
                       :style="d.progression.improved ? 'color:#34d399' : 'color:#f87171'"
                       x-text="(d.progression.improved ? '−' : '+') + d.progression.formatted"></p>
                    <p style="font-size:11px;color:var(--text-3);margin:8px 0 0;" x-text="'en ' + d.progression.months + ' mois'"></p>
                </div>
            </template>
            <template x-if="!d.progression.formatted">
                <p style="font-size:24px;font-weight:700;color:var(--border-2);margin:0;">—</p>
            </template>
        </div>

        {# Record personnel #}
        <div class="card card-body">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0;">Record personnel</p>
                <span style="font-size:9px;font-weight:700;color:#fbbf24;background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);padding:2px 6px;border-radius:4px;line-height:1.4;">PB</span>
            </div>
            <p style="font-size:24px;font-weight:700;font-family:monospace;color:#fbbf24;line-height:1;margin:0;" x-text="d.pb.formatted"></p>
            <p style="font-size:11px;color:var(--text-3);margin:8px 0 0;" x-text="d.pb.date"></p>
        </div>

        {# Meilleure amélioration en 1 séance #}
        <div class="card card-body">
            <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0 0 12px;">Meilleure séance</p>
            <template x-if="d.bestGain">
                <div>
                    <p style="font-size:24px;font-weight:700;font-family:monospace;color:var(--accent);line-height:1;margin:0;"
                       x-text="'−' + d.bestGain"></p>
                    <p style="font-size:11px;color:var(--text-3);margin:8px 0 0;">gain en une séance</p>
                </div>
            </template>
            <template x-if="!d.bestGain">
                <p style="font-size:24px;font-weight:700;color:var(--border-2);margin:0;">—</p>
            </template>
        </div>

        {# Régularité #}
        <div class="card card-body">
            <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0 0 12px;">Régularité</p>
            <p style="font-size:24px;font-weight:700;font-family:monospace;line-height:1;margin:0;"
               :style="consistencyStyle()"
               x-text="d.consistency.score + ' / 100'"></p>
            <p style="font-size:11px;margin:8px 0 0;" :style="consistencyStyle()" x-text="consistencyLabel()"></p>
        </div>
    </div>

    {# ── Progression chart ── #}
    <div class="card card-body">
        <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;margin-bottom:20px;">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0;">Progression</h2>
            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;font-size:11px;color:var(--text-3);">
                <span style="display:flex;align-items:center;gap:6px;">
                    <span style="width:8px;height:8px;border-radius:50%;background:#818cf8;display:inline-block;"></span> Entraînement
                </span>
                <span style="display:flex;align-items:center;gap:6px;">
                    <span style="width:8px;height:8px;border-radius:50%;background:#fbbf24;display:inline-block;"></span> Compétition
                </span>
                <span style="display:flex;align-items:center;gap:6px;">
                    <span style="width:20px;border-top:2px dashed var(--text-3);display:inline-block;"></span> Moy. mobile
                </span>
            </div>
        </div>
        <div style="position:relative;height:260px;">
            <canvas id="progressionChart"></canvas>
        </div>
    </div>

    {# ── Consistance + Distribution ── #}
    <div style="display:grid;grid-template-columns:1fr;gap:24px;" class="lg-grid-2">

        {# Consistance #}
        <div class="card card-body">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0 0 20px;">Consistance</h2>

            <div style="margin-bottom:20px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                    <span style="font-size:12px;color:var(--text-2);">Score de régularité</span>
                    <span style="font-size:13px;font-weight:700;font-family:monospace;" :style="consistencyStyle()"
                          x-text="d.consistency.score + ' / 100'"></span>
                </div>
                <div style="height:6px;background:var(--border-2);border-radius:99px;overflow:hidden;">
                    <div style="height:100%;border-radius:99px;transition:width .7s ease;"
                         :style="'width:' + d.consistency.score + '%;' + consistencyBgStyle()"></div>
                </div>
                <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:10px;color:var(--text-3);">
                    <span>Très irrégulier</span><span>Très régulier</span>
                </div>
            </div>

            <div style="border-top:1px solid var(--border);">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                    <span style="font-size:12px;color:var(--text-3);">Interprétation</span>
                    <span style="font-size:13px;font-weight:500;" :style="consistencyStyle()" x-text="consistencyLabel()"></span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                    <div style="display:flex;align-items:center;gap:6px;">
                        <span style="font-size:12px;color:var(--text-3);">Écart-type</span>
                        <span class="tooltip-wrap" title="À quel point les perfs varient entre elles. Bas = régulier." style="cursor:help;">
                            <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20" style="color:var(--text-3);">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                            </svg>
                        </span>
                    </div>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="d.consistency.stdDev + ' ' + d.unit"></span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                    <span style="font-size:12px;color:var(--text-3);">Coeff. de variation</span>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="d.consistency.cv + ' %'"></span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                    <span style="font-size:12px;color:var(--text-3);">Nombre de performances</span>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="d.count"></span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                    <span style="font-size:12px;color:var(--text-3);">Première perf</span>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="d.first.formatted + '  · ' + d.first.date"></span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;">
                    <span style="font-size:12px;color:var(--text-3);">Dernière perf</span>
                    <span style="font-size:12px;font-family:monospace;color:var(--text-2);" x-text="d.last.formatted + '  · ' + d.last.date"></span>
                </div>
            </div>
        </div>

        {# Distribution des résultats #}
        <div class="card card-body">
            <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0 0 20px;">Distribution des résultats</h2>
            <div x-show="d.bins && d.bins.length > 0" style="position:relative;height:200px;">
                <canvas id="distributionChart"></canvas>
            </div>
            <div x-show="!d.bins || d.bins.length === 0"
                 style="display:flex;align-items:center;justify-content:center;height:200px;font-size:13px;color:var(--text-3);">
                Pas assez de données (minimum 3 perfs)
            </div>
        </div>
    </div>

    {# ── Impact du vent ── #}
    <div x-show="d.wind && d.wind.length >= 2" class="card card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-1);margin:0 0 20px;">Impact du vent</h2>

        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:24px;" class="lg-grid-4">
            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:12px;padding:16px;">
                <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 8px;">Perfs relevées</p>
                <p style="font-size:22px;font-weight:700;font-family:monospace;color:var(--text-1);margin:0;" x-text="d.wind.length"></p>
            </div>
            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:12px;padding:16px;">
                <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 8px;">Meilleure légale (≤2.0)</p>
                <template x-if="d.bestLegal">
                    <div>
                        <p style="font-size:22px;font-weight:700;font-family:monospace;color:#34d399;margin:0;" x-text="d.bestLegal.formatted"></p>
                        <p style="font-size:11px;color:var(--text-3);margin:4px 0 0;" x-text="d.bestLegal.wind + ' m/s · ' + d.bestLegal.date"></p>
                    </div>
                </template>
                <template x-if="!d.bestLegal">
                    <p style="font-size:22px;font-weight:700;color:var(--border-2);margin:0;">—</p>
                </template>
            </div>
            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:12px;padding:16px;">
                <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 8px;">Vent moyen</p>
                <p style="font-size:22px;font-weight:700;font-family:monospace;color:var(--text-2);margin:0;"
                   x-text="(d.wind.reduce((s,w) => s + w.wind, 0) / d.wind.length).toFixed(1) + ' m/s'"></p>
            </div>
            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:12px;padding:16px;">
                <p style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin:0 0 8px;">Vent max</p>
                <p style="font-size:22px;font-weight:700;font-family:monospace;color:var(--text-2);margin:0;"
                   x-text="Math.max(...d.wind.map(w => w.wind)).toFixed(1) + ' m/s'"></p>
            </div>
        </div>

        <div style="position:relative;height:220px;">
            <canvas id="windChart"></canvas>
        </div>
        <p style="font-size:11px;color:var(--text-3);margin:6px 0 0;text-align:center;">
            Ligne grise = 0 · Lignes jaunes pointillées = limites légales ±2.0 m/s
        </p>
    </div>

</div>

<style>
@media(min-width:1024px){.lg-grid-4{grid-template-columns:repeat(4,1fr)!important}.lg-grid-2{grid-template-columns:repeat(2,1fr)!important}}
</style>

<script>
function statsPage() {
    const stats = {{ statsData|json_encode|raw }};
    const disciplines = {{ disciplines|json_encode|raw }};

    return {
        stats,
        disciplines,
        activeDisc: disciplines[0] ?? null,
        activeYear: 'all',
        _charts: {},
        _rebuildTimer: null,

        get availableYears() {
            const raw = (this.stats[this.activeDisc] ?? {}).rawPerfs ?? [];
            return [...new Set(raw.map(p => p.year))].sort((a, b) => b - a);
        },

        get d() {
            if (this.activeYear === 'all') return this.stats[this.activeDisc] ?? {};
            const base = this.stats[this.activeDisc] ?? {};
            const perfs = (base.rawPerfs ?? []).filter(p => p.year === this.activeYear);
            return perfs.length > 0 ? (this._computeStats(perfs, base.unit, base.lower) ?? base) : base;
        },

        init() {
            const rebuild = () => {
                clearTimeout(this._rebuildTimer);
                this._rebuildTimer = setTimeout(() => {
                    this._destroyCharts();
                    this.$nextTick(() => {
                        this._buildProgression();
                        if (this.d.bins && this.d.bins.length > 0) this._buildDistribution();
                        if (this.d.wind && this.d.wind.length >= 2) this._buildWind();
                    });
                }, 80);
            };
            this.$watch('activeDisc', () => { this.activeYear = 'all'; rebuild(); });
            this.$watch('activeYear', rebuild);
            this.$nextTick(() => {
                this._buildProgression();
                if (this.d.bins && this.d.bins.length > 0) this._buildDistribution();
                if (this.d.wind && this.d.wind.length >= 2) this._buildWind();
            });
        },

        switchDisc(disc) { this.activeDisc = disc; },
        setYear(year)    { this.activeYear = year; },

        _computeStats(perfs, unit, lower) {
            const vals  = perfs.map(p => p.value);
            const count = perfs.length;
            const first = perfs[0];
            const last  = perfs[count - 1];

            // PB
            const bestVal  = lower ? Math.min(...vals) : Math.max(...vals);
            const bestPerf = perfs[vals.indexOf(bestVal)];

            // Progression
            const rawDiff = last.value - first.value;
            const improved = lower ? rawDiff < 0 : rawDiff > 0;
            const daysDiff = count > 1
                ? (new Date(last.dateRaw) - new Date(first.dateRaw)) / 86400000 : 0;
            const months = daysDiff > 0 ? Math.round(daysDiff / 30.5 * 10) / 10 : 0;

            // Best single-session gain
            let bestSingleGain = 0;
            for (let i = 1; i < count; i++) {
                const gain = lower
                    ? perfs[i - 1].value - perfs[i].value
                    : perfs[i].value - perfs[i - 1].value;
                if (gain > bestSingleGain) bestSingleGain = gain;
            }

            // Consistency
            const mean     = vals.reduce((a, b) => a + b, 0) / count;
            const variance = vals.reduce((s, v) => s + (v - mean) ** 2, 0) / count;
            const stdDev   = Math.sqrt(variance);
            const cv       = mean > 0 ? (stdDev / mean) * 100 : 0;
            const score    = Math.max(0, Math.min(100, Math.round(100 - cv * 15)));

            // Wind — exclude indoor, keep only best at wind=0
            const windRaw = perfs.filter(p => p.wind !== null && !p.isIndoor);
            let bestAtZero = null;
            const windFiltered = [];
            for (const p of windRaw) {
                if (p.wind === 0) {
                    if (!bestAtZero || (lower ? p.value < bestAtZero.value : p.value > bestAtZero.value))
                        bestAtZero = p;
                } else {
                    windFiltered.push(p);
                }
            }
            if (bestAtZero) windFiltered.push(bestAtZero);
            const windData = windFiltered.map(p => ({
                wind: p.wind, value: p.value,
                formatted: this._fmt(p.value, unit), date: p.date, isComp: p.isComp,
            }));

            // Best legal (|wind| ≤ 2.0)
            const legalPerfs = windFiltered.filter(p => Math.abs(p.wind) <= 2.0);
            let bestLegal = null;
            if (legalPerfs.length) {
                const bl = legalPerfs.reduce((b, p) =>
                    (!b || (lower ? p.value < b.value : p.value > b.value)) ? p : b, null);
                if (bl) bestLegal = { formatted: this._fmt(bl.value, unit), wind: bl.wind, date: bl.date };
            }

            const formatDiff = abs => {
                if (unit === 's' || unit === 'min:s') {
                    if (abs >= 60) {
                        const m = Math.floor(abs / 60);
                        return m + ':' + (abs - m * 60).toFixed(2).padStart(5, '0');
                    }
                    return abs.toFixed(2) + 's';
                }
                return abs.toFixed(2) + ' ' + unit;
            };

            return {
                unit, lower, count,
                first: { formatted: this._fmt(first.value, unit), date: first.date },
                last:  { formatted: this._fmt(last.value, unit),  date: last.date  },
                pb:    { formatted: this._fmt(bestVal, unit),      date: bestPerf.date },
                progression: {
                    abs: Math.abs(rawDiff),
                    formatted: count > 1 ? formatDiff(Math.abs(rawDiff)) : null,
                    improved:  count > 1 ? improved : null,
                    months,
                },
                bestGain: bestSingleGain > 0 ? formatDiff(bestSingleGain) : null,
                consistency: {
                    score,
                    stdDev: Math.round(stdDev * 1000) / 1000,
                    cv:     Math.round(cv * 100) / 100,
                },
                wind: windData, bestLegal,
                bins: this._computeBins(vals, unit),
                chart: {
                    labels: perfs.map(p => p.dateRaw),
                    values: vals,
                    isComp: perfs.map(p => p.isComp),
                },
            };
        },

        _computeBins(vals, unit) {
            if (vals.length < 3) return [];
            const minV = Math.min(...vals), maxV = Math.max(...vals);
            if (maxV <= minV) return [];
            let baseStep = (unit === 's' || unit === 'min:s') ? 0.1
                         : unit === 'm'   ? 0.1
                         : unit === 'kg'  ? 1.0
                         : unit === 'pts' ? 50.0
                         : (maxV - minV) / 8;
            let step = baseStep;
            while ((maxV - minV) / step > 14) step *= 2;
            const dec = step < 1 ? 2 : (step < 10 ? 1 : 0);
            const lo0 = Math.floor(minV / step) * step;
            const sfx = (unit === 's' || unit === 'min:s') ? 's' : (unit === 'm' ? 'm' : '');
            const bins = [];
            for (let b = 0; ; b++) {
                const lo = Math.round((lo0 + b * step) * 1e6) / 1e6;
                const hi = Math.round((lo + step)      * 1e6) / 1e6;
                if (lo > maxV) break;
                const isLast = hi > maxV;
                const n = vals.filter(v => v >= lo && (isLast ? v <= maxV : v < hi)).length;
                bins.push({ label: lo.toFixed(dec) + sfx, count: n });
            }
            while (bins.length && bins[0].count === 0) bins.shift();
            while (bins.length && bins[bins.length - 1].count === 0) bins.pop();
            return bins;
        },

        _destroyCharts() {
            Object.values(this._charts).forEach(c => c.destroy());
            this._charts = {};
            // Remplace les canvas pour éviter les artefacts Chart.js
            ['progressionChart', 'distributionChart', 'windChart'].forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    const fresh = document.createElement('canvas');
                    fresh.id = id;
                    el.replaceWith(fresh);
                }
            });
        },

        consistencyLabel() {
            const s = this.d.consistency?.score ?? 0;
            if (s >= 80) return 'Très régulier';
            if (s >= 60) return 'Régulier';
            if (s >= 40) return 'Irrégulier';
            return 'Très irrégulier';
        },

        consistencyColor() {
            const s = this.d.consistency?.score ?? 0;
            if (s >= 80) return 'text-emerald-400';
            if (s >= 60) return 'text-blue-400';
            if (s >= 40) return 'text-amber-400';
            return 'text-red-400';
        },

        consistencyStyle() {
            const s = this.d.consistency?.score ?? 0;
            if (s >= 80) return 'color:#34d399';
            if (s >= 60) return 'color:#60a5fa';
            if (s >= 40) return 'color:#fbbf24';
            return 'color:#f87171';
        },

        consistencyBgStyle() {
            const s = this.d.consistency?.score ?? 0;
            if (s >= 80) return 'background:#34d399';
            if (s >= 60) return 'background:#60a5fa';
            if (s >= 40) return 'background:#fbbf24';
            return 'background:#f87171';
        },

        _fmt(v, unit) {
            if (unit === 's' || unit === 'min:s') {
                if (v >= 60) {
                    const m = Math.floor(v / 60);
                    const s = (v - m * 60).toFixed(2).padStart(5, '0');
                    return m + ':' + s;
                }
                return v.toFixed(2) + 's';
            }
            return v.toFixed(2) + ' ' + unit;
        },


        _buildProgression() {
            const ctx = document.getElementById('progressionChart');
            if (!ctx || this._charts.progression) return;
            const d = this.d;
            const unit = d.unit;
            const lower = d.lower;
            const vals = d.chart.values;

            // Moving average (window 3)
            const ma = vals.map((_, i) => {
                const from = Math.max(0, i - 2);
                const slice = vals.slice(from, i + 1);
                return slice.reduce((a, b) => a + b, 0) / slice.length;
            });

            this._charts.progression = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: d.chart.labels,
                    datasets: [
                        {
                            label: 'Performances',
                            data: vals,
                            borderColor: '#6366f1',
                            backgroundColor: 'transparent',
                            pointBackgroundColor: d.chart.isComp.map(c => c ? '#fbbf24' : '#818cf8'),
                            pointBorderColor:     d.chart.isComp.map(c => c ? '#f59e0b' : '#6366f1'),
                            pointRadius: 5,
                            pointHoverRadius: 7,
                            borderWidth: 1.5,
                            tension: 0.35,
                            fill: false,
                        },
                        {
                            label: 'Moyenne mobile',
                            data: ma,
                            borderColor: 'rgba(148,163,184,0.5)',
                            backgroundColor: 'transparent',
                            pointRadius: 0,
                            borderWidth: 1.5,
                            borderDash: [5, 4],
                            tension: 0.4,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#111827',
                            borderColor: '#374151',
                            borderWidth: 1,
                            titleColor: '#9ca3af',
                            bodyColor: '#f9fafb',
                            callbacks: {
                                label: (item) => {
                                    if (item.datasetIndex === 1) return null;
                                    const c = d.chart.isComp[item.dataIndex];
                                    return (c ? '🏆 ' : '·  ') + this._fmt(item.parsed.y, unit);
                                }
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: '#1f2937' }, ticks: { color: '#6b7280', maxTicksLimit: 8, font: { size: 11 } } },
                        y: {
                            reverse: lower,
                            grid: { color: '#1f2937' },
                            ticks: { color: '#6b7280', font: { size: 11 }, callback: v => this._fmt(v, unit) }
                        }
                    }
                }
            });
        },

        _buildDistribution() {
            const ctx = document.getElementById('distributionChart');
            if (!ctx || this._charts.distribution) return;
            const bins = this.d.bins;
            const maxN = Math.max(...bins.map(b => b.count));

            this._charts.distribution = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: bins.map(b => b.label),
                    datasets: [{
                        data: bins.map(b => b.count),
                        backgroundColor: bins.map(b => `rgba(99,102,241,${0.25 + (b.count / maxN) * 0.65})`),
                        borderColor: '#6366f1',
                        borderWidth: 1,
                        borderRadius: 4,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#111827',
                            borderColor: '#374151',
                            borderWidth: 1,
                            callbacks: {
                                label: i => i.raw + ' perf' + (i.raw > 1 ? 's' : '')
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#6b7280', font: { size: 10 }, maxRotation: 35 } },
                        y: { grid: { color: '#1f2937' }, ticks: { color: '#6b7280', font: { size: 11 }, stepSize: 1 } }
                    }
                }
            });
        },

        _buildWind() {
            const ctx = document.getElementById('windChart');
            if (!ctx || this._charts.wind) return;
            const wind = this.d.wind;
            const unit = this.d.unit;
            const lower = this.d.lower;

            // Plugin local (pas Chart.register) pour ne pas écraser les tooltips natifs
            const windRefPlugin = {
                id: 'windRefs',
                afterDatasetsDraw(chart) {
                    const { ctx, scales: { x, y } } = chart;
                    const refs = [
                        { val: 0,    color: 'rgba(226,232,240,0.7)',  dash: [],      label: '0',    labelColor: '#e2e8f0', bgColor: 'rgba(226,232,240,0.06)' },
                        { val: 2.0,  color: 'rgba(251,191,36,0.6)',   dash: [5, 4],  label: '+2.0', labelColor: '#fbbf24' },
                        { val: -2.0, color: 'rgba(251,191,36,0.6)',   dash: [5, 4],  label: '−2.0', labelColor: '#fbbf24' },
                    ];
                    ctx.save();
                    refs.forEach(({ val, color, dash, label, labelColor, bgColor }) => {
                        const xPx = x.getPixelForValue(val);
                        if (xPx < x.left || xPx > x.right) return;
                        if (bgColor) {
                            ctx.fillStyle = bgColor;
                            ctx.fillRect(xPx - 1, y.top, 2, y.bottom - y.top);
                        }
                        ctx.strokeStyle = color;
                        ctx.lineWidth = val === 0 ? 2 : 1.5;
                        ctx.setLineDash(dash);
                        ctx.beginPath();
                        ctx.moveTo(xPx, y.top);
                        ctx.lineTo(xPx, y.bottom);
                        ctx.stroke();
                        ctx.setLineDash([]);
                        ctx.font = 'bold 10px monospace';
                        ctx.textAlign = 'center';
                        const tw = ctx.measureText(label).width + 8;
                        const ty = y.bottom + 16;
                        ctx.fillStyle = val === 0 ? 'rgba(226,232,240,0.12)' : 'rgba(251,191,36,0.12)';
                        ctx.beginPath();
                        ctx.roundRect(xPx - tw / 2, ty - 10, tw, 13, 3);
                        ctx.fill();
                        ctx.fillStyle = labelColor;
                        ctx.fillText(label, xPx, ty);
                    });
                    ctx.restore();
                }
            };

            this._charts.wind = new Chart(ctx, {
                type: 'scatter',
                plugins: [windRefPlugin],
                data: {
                    datasets: [{
                        data: wind.map(w => ({ x: w.wind, y: w.value, ...w })),
                        backgroundColor: wind.map(w => w.isComp ? 'rgba(251,191,36,0.85)' : 'rgba(129,140,248,0.85)'),
                        pointRadius: 7,
                        pointHoverRadius: 10,
                        hitRadius: 10,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: { bottom: 18 } },
                    interaction: { mode: 'nearest', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#111827',
                            borderColor: '#374151',
                            borderWidth: 1,
                            titleColor: '#9ca3af',
                            bodyColor: '#f9fafb',
                            padding: 10,
                            displayColors: false,
                            callbacks: {
                                title: items => wind[items[0].dataIndex]?.date ?? '',
                                label: item => {
                                    const w = wind[item.dataIndex];
                                    if (!w) return '';
                                    const sign = w.wind >= 0 ? '+' : '';
                                    return [
                                        (w.isComp ? '🏆 ' : '· ') + this._fmt(w.value, unit),
                                        'Vent : ' + sign + w.wind.toFixed(1) + ' m/s',
                                    ];
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            title: { display: true, text: 'Vent (m/s)', color: '#6b7280', font: { size: 11 } },
                            grid: { color: '#1f2937' },
                            ticks: { color: '#6b7280', font: { size: 11 } }
                        },
                        y: {
                            reverse: lower,
                            title: { display: true, text: 'Performance', color: '#6b7280', font: { size: 11 } },
                            grid: { color: '#1f2937' },
                            ticks: { color: '#6b7280', font: { size: 11 }, callback: v => this._fmt(v, unit) }
                        }
                    }
                }
            });
        },
    };
}
</script>
{% endblock %}
